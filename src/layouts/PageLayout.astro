---
// Standard marketing-page shell: document + skip link + Header + <main> + Footer.
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  // The nav is a floating glass pill (position: fixed). Pages get top clearance by
  // default; hero pages (e.g. About) set `flushTop` so a full-bleed hero sits under it.
  flushTop?: boolean;
}
const { title, description, type = 'website', flushTop = false }: Props = Astro.props;
---

<BaseLayout title={title} description={description} type={type}>
  <slot name="head" slot="head" />
  <a
    href="#main"
    class="sr-only rounded-md focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-card focus:px-4 focus:py-2 focus:text-foreground focus:shadow-md"
  >
    Skip to content
  </a>
  <Header />
  <main id="main" class:list={[{ 'pt-24': !flushTop }]}>
    <slot />
  </main>
  <Footer />
</BaseLayout>
