---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import { cn } from '../../lib/cn';

const container = tv({
  base: 'mx-auto w-full px-6 sm:px-8',
  variants: {
    width: {
      prose: 'max-w-2xl',
      narrow: 'max-w-4xl',
      default: 'max-w-6xl',
      wide: 'max-w-7xl',
      full: 'max-w-none',
    },
  },
  defaultVariants: { width: 'default' },
});

type Props = VariantProps<typeof container> & HTMLAttributes<'div'>;
const { width, class: className, ...rest } = Astro.props;
---

<div class={cn(container({ width }), className)} {...rest}><slot /></div>
