---
// Page-level breadcrumb. Renders a labeled <nav><ol> with chevron-separated
// links to ancestor pages and the current page marked aria-current="page".
// Reusable across narrator detail pages, blog posts, and future profiles.

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[]; // last item should be the current page (no href)
  align?: 'left' | 'center';
}
const { items, align = 'left' }: Props = Astro.props;
---

<nav class:list={['bc', `is-${align}`]} aria-label="Breadcrumb">
  <ol>
    {
      items.map((c, i) => {
        const isLast = i === items.length - 1;
        return (
          <li>
            {c.href && !isLast ? (
              <a class="bc-link" href={c.href}>
                {i === 0 && (
                  <svg
                    aria-hidden="true"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="15 18 9 12 15 6" />
                  </svg>
                )}
                {c.label}
              </a>
            ) : (
              <span class="bc-here" aria-current={isLast ? 'page' : undefined}>
                {c.label}
              </span>
            )}
            {!isLast && (
              <span class="bc-sep" aria-hidden="true">
                /
              </span>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>

<style>
  .bc {
    width: 100%;
  }
  .bc.is-center ol {
    justify-content: center;
  }
  ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 13px;
    font-weight: 500;
    line-height: 1;
    color: var(--color-muted-foreground);
  }
  li {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .bc-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-muted-foreground);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .bc-link:hover {
    color: var(--color-foreground);
  }
  .bc-link svg {
    opacity: 0.7;
  }
  .bc-sep {
    color: var(--color-border);
  }
  .bc-here {
    color: var(--color-foreground);
  }
</style>
