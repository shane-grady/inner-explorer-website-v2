---
// Page-level breadcrumb (sits in the content column, not the global nav).
// Last item is the current page. Generic + reusable across detail pages.
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
  class?: string;
}
const { items, class: className }: Props = Astro.props;
const lastIndex = items.length - 1;
---

<nav class:list={['breadcrumb', className]} aria-label="Breadcrumb">
  <ol>
    {
      items.map((item, i) => (
        <li>
          {i > 0 && (
            <span class="sep" aria-hidden="true">
              /
            </span>
          )}
          {item.href ? (
            <a href={item.href}>
              {i === 0 && (
                <svg
                  class="chevron"
                  viewBox="0 0 24 24"
                  width="14"
                  height="14"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="15 18 9 12 15 6" />
                </svg>
              )}
              {item.label}
            </a>
          ) : (
            <span class="here" aria-current={i === lastIndex ? 'page' : undefined}>
              {item.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .breadcrumb ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 13px;
    font-weight: 500;
    line-height: 1;
    color: var(--color-muted-foreground);
  }
  .breadcrumb li {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .breadcrumb a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-muted-foreground);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .breadcrumb a:hover {
    color: var(--color-foreground);
  }
  .chevron {
    opacity: 0.7;
  }
  .sep {
    color: var(--color-border);
  }
  .here {
    color: var(--color-foreground);
  }
</style>
