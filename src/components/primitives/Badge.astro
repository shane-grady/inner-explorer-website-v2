---
import { tv, type VariantProps } from 'tailwind-variants';
import { cn } from '../../lib/cn';

const badge = tv({
  base: 'inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm font-medium',
  variants: {
    tone: {
      brand: 'bg-brand-subtle text-brand',
      accent: 'bg-accent-subtle text-accent',
      neutral: 'bg-muted text-muted-foreground',
      outline: 'border border-border text-foreground',
    },
  },
  defaultVariants: { tone: 'brand' },
});

type Variants = VariantProps<typeof badge>;
interface Props extends Variants {
  class?: string;
}
const { tone, class: className } = Astro.props;
---

<span class={cn(badge({ tone }), className)}><slot /></span>
