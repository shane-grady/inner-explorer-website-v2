---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import { cn } from '../../lib/cn';

const grid = tv({
  base: 'grid',
  variants: {
    cols: {
      1: 'grid-cols-1',
      2: 'grid-cols-1 sm:grid-cols-2',
      3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
      4: 'grid-cols-2 lg:grid-cols-4',
    },
    gap: { sm: 'gap-4', md: 'gap-6', lg: 'gap-8', xl: 'gap-12' },
  },
  defaultVariants: { cols: 3, gap: 'lg' },
});

type Props = VariantProps<typeof grid> & HTMLAttributes<'div'>;
const { cols, gap, class: className, ...rest } = Astro.props;
---

<div class={cn(grid({ cols, gap }), className)} {...rest}><slot /></div>
