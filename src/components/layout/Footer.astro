---
import Container from '../primitives/Container.astro';
import Link from '../primitives/Link.astro';

const year = new Date().getFullYear();

const groups = [
  {
    heading: 'Program',
    links: [
      { label: 'How it works', href: '/program' },
      { label: 'Research & impact', href: '/research' },
      { label: 'Pricing', href: '/pricing' },
    ],
  },
  {
    heading: 'Resources',
    links: [
      { label: 'Blog', href: '/blog' },
      { label: 'For educators', href: '/resources' },
      { label: 'Support', href: '/support' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Contact', href: '/contact' },
      { label: 'Careers', href: '/careers' },
    ],
  },
];
---

<footer class="border-t border-border bg-muted">
  <Container class="py-section-md">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <span class="font-serif text-lg font-semibold text-foreground">Inner Explorer</span>
        <p class="mt-3 max-w-xs text-sm text-muted-foreground">
          Daily audio-guided mindfulness practices for K-12 schools.
        </p>
      </div>
      {
        groups.map((group) => (
          <nav aria-label={group.heading}>
            <h2 class="text-sm font-semibold text-foreground">{group.heading}</h2>
            <ul class="mt-3 space-y-2">
              {group.links.map((link) => (
                <li>
                  <Link href={link.href} variant="nav" class="text-sm">
                    {link.label}
                  </Link>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>
    <div class="mt-10 border-t border-border pt-6">
      <p class="text-sm text-muted-foreground">
        &copy; {year} Inner Explorer. All rights reserved.
      </p>
    </div>
  </Container>
</footer>
