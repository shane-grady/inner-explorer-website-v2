---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Photo-led editorial list rows (e.g. a narrator's practices). `headingHtml` carries
// the serif+sans duet head. Each row links to its target; play/arrow are decorative.
interface Row {
  title: string;
  meta: string;
  image?: ImageMetadata;
  href?: string;
}
interface Props {
  eyebrow: string;
  headingHtml: string;
  rows: Row[];
  maxWidth?: string;
}
const { eyebrow, headingHtml, rows, maxWidth = '1200px' }: Props = Astro.props;
---

<section class="media" style={`--mw: ${maxWidth}`}>
  <div class="wrap">
    <div class="head">
      <span class="eyebrow">{eyebrow}</span>
      <h2 set:html={headingHtml} />
    </div>

    <div class="rows">
      {
        rows.map((row, i) => {
          const Tag = row.href ? 'a' : 'div';
          const num = String(i + 1).padStart(2, '0');
          return (
            <Tag class="row" href={row.href}>
              <span class="num">{num}</span>
              <div class="thumb">
                {row.image ? (
                  <Image src={row.image} alt="" widths={[200, 400]} sizes="200px" loading="lazy" />
                ) : (
                  <span class="thumb-fallback" aria-hidden="true" />
                )}
              </div>
              <div class="body">
                <h3 class="title">{row.title}</h3>
                <span class="meta">{row.meta}</span>
              </div>
              <span class="play" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </span>
              <span class="arrow" aria-hidden="true">
                <svg
                  viewBox="0 0 24 24"
                  width="18"
                  height="18"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 12h14" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </span>
            </Tag>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .media {
    padding: 40px 0 80px;
  }
  .wrap {
    max-width: var(--mw);
    margin: 0 auto;
    padding: 0 32px;
  }
  .head {
    max-width: 800px;
    margin-bottom: 48px;
  }
  .eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-muted-foreground);
  }
  .head h2 {
    margin: 14px 0 0;
    line-height: 1.05;
  }
  .head h2 :global(.serif) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(34px, 4.6vw, 56px);
    letter-spacing: -0.015em;
    color: var(--color-foreground);
  }
  .head h2 :global(.sans) {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(34px, 4.6vw, 56px);
    letter-spacing: -0.025em;
    color: var(--color-muted-foreground);
  }

  .row {
    display: grid;
    grid-template-columns: 60px 200px 1fr auto auto;
    align-items: center;
    gap: 28px;
    padding: 20px 4px;
    border-top: 1px solid var(--color-border);
    color: var(--color-foreground);
    text-decoration: none;
    transition:
      background var(--dur) var(--ease-out),
      padding var(--dur) var(--ease-out);
  }
  .row:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  a.row:hover {
    background: var(--color-muted);
    padding-left: 16px;
    padding-right: 16px;
  }
  .num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 32px;
    line-height: 1;
    color: var(--color-muted-foreground);
  }
  .thumb {
    width: 200px;
    height: 110px;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-muted);
  }
  .thumb :global(img),
  .thumb-fallback {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb-fallback {
    background:
      radial-gradient(ellipse 90% 80% at 30% 20%, var(--brand-700), transparent 70%),
      linear-gradient(150deg, var(--brand-900), var(--brand-950));
  }
  .body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .title {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }
  .meta {
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted-foreground);
  }
  .play {
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 2px;
    background: var(--color-brand-subtle);
    color: var(--color-brand-emphasis);
    border: 1px solid color-mix(in oklab, var(--color-brand) 18%, transparent);
    transition:
      background 0.2s,
      color 0.2s;
  }
  a.row:hover .play {
    background: var(--color-brand);
    color: var(--color-brand-foreground);
  }
  .arrow {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted-foreground);
    transition:
      transform 0.2s,
      color 0.2s;
  }
  a.row:hover .arrow {
    color: var(--color-foreground);
    transform: translateX(4px);
  }

  @media (max-width: 720px) {
    .row {
      grid-template-columns: 96px 1fr auto;
      gap: 16px;
    }
    .num,
    .arrow {
      display: none;
    }
    .thumb {
      width: 96px;
      height: 64px;
    }
  }
</style>
