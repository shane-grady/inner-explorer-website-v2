---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Wide editorial photo with a tint overlay, glass corner labels, and a
// serif-italic pull-quote. Reusable for narrator heroes and featured voices.
interface Props {
  image?: ImageMetadata;
  imageAlt: string;
  /** Top-left glass label (e.g. "PORTRAIT"). Paired with a brand status dot. */
  cornerStart?: string;
  /** Top-right glass label (e.g. a location/credit). */
  cornerEnd?: string;
  quote: { text: string; attrib?: string };
  /** Set for the LCP hero so the image loads eagerly. */
  eager?: boolean;
  maxWidth?: string;
}
const {
  image,
  imageAlt,
  cornerStart,
  cornerEnd,
  quote,
  eager = false,
  maxWidth = '1200px',
}: Props = Astro.props;
---

<section class="photo-wrap" style={`--mw: ${maxWidth}`}>
  <figure class="photo">
    {
      image ? (
        <Image
          class="photo-img"
          src={image}
          alt={imageAlt}
          widths={[800, 1200, 1800]}
          sizes="(max-width: 1264px) 100vw, 1136px"
          loading={eager ? 'eager' : 'lazy'}
          fetchpriority={eager ? 'high' : 'auto'}
        />
      ) : (
        <div class="photo-fallback" role="img" aria-label={imageAlt} />
      )
    }
    <div class="grad" aria-hidden="true"></div>

    {
      cornerStart && (
        <div class="corner start">
          <span class="dot" aria-hidden="true" />
          {cornerStart}
        </div>
      )
    }
    {cornerEnd && <div class="corner end">{cornerEnd}</div>}

    <figcaption class="quote">
      <span class="mark" aria-hidden="true">&ldquo;</span>
      <p>{quote.text}</p>
      {quote.attrib && <span class="attrib">{quote.attrib}</span>}
    </figcaption>
  </figure>
</section>

<style>
  .photo-wrap {
    max-width: var(--mw);
    margin: 0 auto;
    padding: 16px 32px 28px;
  }
  .photo {
    position: relative;
    margin: 0;
    aspect-ratio: 21 / 9;
    max-height: 520px;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .photo-img,
  .photo-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .photo-img {
    object-fit: cover;
    filter: brightness(0.94) saturate(1.05);
  }
  .photo-fallback {
    background:
      radial-gradient(ellipse 90% 70% at 30% 30%, var(--brand-700), transparent 70%),
      linear-gradient(150deg, var(--brand-900), var(--brand-950));
  }
  .grad {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        170deg,
        transparent 0%,
        transparent 45%,
        color-mix(in oklab, var(--color-black) 35%, transparent) 75%,
        color-mix(in oklab, var(--color-black) 72%, transparent) 100%
      ),
      linear-gradient(
        80deg,
        color-mix(in oklab, var(--color-black) 18%, transparent) 0%,
        transparent 50%
      );
  }
  .corner {
    position: absolute;
    top: 22px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--color-white) 8%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-white) 18%, transparent);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    color: var(--color-white);
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .corner.start {
    left: 22px;
  }
  .corner.end {
    right: 22px;
  }
  .corner .dot {
    width: 7px;
    height: 7px;
    border-radius: 9999px;
    background: var(--brand-300);
    box-shadow: 0 0 8px color-mix(in oklab, var(--brand-300) 70%, transparent);
  }
  .quote {
    position: absolute;
    left: 36px;
    right: 36px;
    bottom: 32px;
    max-width: 560px;
    color: var(--color-white);
  }
  .quote .mark {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 96px;
    line-height: 0.6;
    color: color-mix(in oklab, var(--color-white) 55%, transparent);
    margin-bottom: -22px;
  }
  .quote p {
    margin: 0 0 10px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(20px, 2.4vw, 24px);
    line-height: 1.32;
    letter-spacing: -0.005em;
    text-wrap: pretty;
  }
  .quote .attrib {
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: color-mix(in oklab, var(--color-white) 85%, transparent);
  }

  @media (max-width: 720px) {
    .photo {
      aspect-ratio: 4 / 5;
      max-height: none;
    }
    .corner {
      display: none;
    }
    .quote {
      left: 22px;
      right: 22px;
      bottom: 22px;
    }
    .quote p {
      font-size: 20px;
    }
  }
</style>
