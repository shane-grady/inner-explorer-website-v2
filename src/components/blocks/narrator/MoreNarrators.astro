---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// 4-up grid of "more narrators" related to the current detail page. Visually
// distinct from the wall NarratorCard (name below photo, no overlay, no langs
// chips, no play button) — kept as a separate component.

export interface MoreNarrator {
  name: string;
  slug: string;
  role?: string;
  photo: ImageMetadata;
}
interface Props {
  eyebrow: string;
  headingHtml: string;
  narrators: MoreNarrator[];
  hrefBase?: string;
}
const { eyebrow, headingHtml, narrators, hrefBase = '/narrators/' }: Props = Astro.props;
---

<section class="more">
  <div class="head">
    <span class="eb">{eyebrow}</span>
    <h2 class="hd" set:html={headingHtml} />
  </div>
  <div class="grid">
    {
      narrators.map((n) => (
        <a class="card" href={`${hrefBase}${n.slug}`}>
          <div class="photo">
            <Image
              src={n.photo}
              alt={`Portrait of ${n.name}`}
              widths={[240, 400]}
              sizes="(max-width: 920px) 45vw, 22vw"
              loading="lazy"
            />
          </div>
          <b class="nm">{n.name}</b>
          {n.role && <span class="role">{n.role}</span>}
        </a>
      ))
    }
  </div>
</section>

<style>
  .more {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 32px 96px;
  }
  .head {
    margin-bottom: 36px;
    max-width: 800px;
  }
  .eb {
    display: block;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-muted-foreground);
  }
  .hd {
    margin: 14px 0 0;
    font-size: 0;
    line-height: 1;
  }
  .hd :global(.serif) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-foreground);
  }
  .hd :global(.sans) {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--color-muted-foreground);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: var(--color-foreground);
  }
  .photo {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: 6px;
    background: var(--color-muted);
    transition: transform var(--dur) var(--ease-out);
  }
  .card:hover .photo {
    transform: translateY(-4px);
  }
  .photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .nm {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 24px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }
  .role {
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted-foreground);
  }

  @media (max-width: 920px) {
    .more {
      padding: 32px 16px 72px;
    }
    .grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo {
      transition: none;
    }
    .card:hover .photo {
      transform: none;
    }
  }
</style>
