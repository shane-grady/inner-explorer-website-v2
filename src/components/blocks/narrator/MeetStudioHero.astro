---
// D2 "Meet the Studio — Full-width headline" hero.
// Page-local because it's a singular full-width oversized-type composition
// (different DNA from AboutHero's image-backed hero). Background composes from
// --studio-hero-wash; the corona is a brand-tinted soft circle.

interface Cta {
  label: string;
  href: string;
}
interface Props {
  eyebrow: string;
  cornerLabel: string;
  headlineSans: string; // top line, sans, muted
  headlineSerif: string; // bottom line, italic serif, foreground
  subtitleHtml: string; // supports inline <em>
  primary: Cta;
  secondary?: Cta;
}
const {
  eyebrow,
  cornerLabel,
  headlineSans,
  headlineSerif,
  subtitleHtml,
  primary,
  secondary,
}: Props = Astro.props;
---

<section class="hero" aria-labelledby="hero-headline">
  <span class="corner" aria-hidden="true">
    <span class="corner-pip"></span>
    {cornerLabel}
  </span>

  <div class="inner">
    <div class="eyebrow">
      <span class="pip" aria-hidden="true"></span>
      <span>{eyebrow}</span>
      <span class="line" aria-hidden="true"></span>
    </div>

    <h1 class="title" id="hero-headline">
      <span class="sans">{headlineSans}</span>
      {headlineSerif}
    </h1>

    <div class="bottom">
      <p class="sub" set:html={subtitleHtml} />
      <div class="actions">
        <a class="btn-primary" href={primary.href}>
          {primary.label}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M8 5v14l11-7z"></path>
          </svg>
        </a>
        {
          secondary && (
            <a class="btn-ghost" href={secondary.href}>
              {secondary.label}
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(72px, 7vw, 110px) clamp(24px, 5vw, 64px) clamp(72px, 7vw, 96px);
    background: var(--studio-hero-wash);
    border-bottom: 1px solid var(--color-border);
  }
  /* Soft leaf-ring corona — faint brand-tinted radial behind the headline. */
  .hero::after {
    content: '';
    position: absolute;
    top: -180px;
    right: -200px;
    width: 720px;
    height: 720px;
    border-radius: 9999px;
    background: radial-gradient(
      circle at 50% 50%,
      color-mix(in oklab, var(--color-brand) 8%, transparent) 0%,
      color-mix(in oklab, var(--color-brand) 3%, transparent) 35%,
      transparent 60%
    );
    pointer-events: none;
  }

  .corner {
    position: absolute;
    /* Clear the global fixed glass nav (Header.astro extends to ~76px). */
    top: clamp(96px, 7vw, 110px);
    right: clamp(24px, 5vw, 64px);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-muted-foreground);
    z-index: 1;
  }
  .corner-pip {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--color-brand);
  }

  .inner {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 36px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-muted-foreground);
  }
  .pip {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--color-brand);
  }
  .line {
    flex: 1;
    max-width: 240px;
    height: 1px;
    background: var(--color-border);
  }

  /* Headline — sans top line, italic-serif bottom line. Scales fluidly so the
     ~116/184 desktop hits and the mobile hits both feel right. */
  .title {
    margin: 0 0 56px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(72px, 13vw, 184px);
    line-height: 0.9;
    letter-spacing: -0.035em;
    color: var(--color-foreground);
    text-wrap: balance;
    max-width: 14ch;
  }
  .title .sans {
    display: block;
    margin-bottom: 12px;
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 500;
    font-size: clamp(44px, 8vw, 116px);
    line-height: 0.92;
    letter-spacing: -0.05em;
    color: var(--color-muted-foreground);
  }

  .bottom {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) auto;
    gap: 64px;
    align-items: end;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
    max-width: 1100px;
  }
  .sub {
    margin: 0;
    max-width: 50ch;
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.55;
    color: var(--color-foreground);
    text-wrap: pretty;
  }
  .sub :global(em) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.55;
    color: var(--color-foreground);
  }

  .actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    height: 50px;
    padding: 0 24px;
    border-radius: 9999px;
    background: var(--color-foreground);
    color: var(--color-background);
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    transition:
      transform var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }
  .btn-primary:hover {
    transform: translateY(-1px);
    background: var(--color-black);
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    height: 50px;
    padding: 0 24px;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--color-white) 65%, transparent);
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .btn-ghost:hover {
    background: var(--color-white);
  }

  @media (max-width: 920px) {
    .bottom {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .actions {
      justify-content: flex-start;
    }
    .corner {
      /* On mobile, tuck corner inline with the eyebrow row (the nav is
         shorter but the eyebrow line is the same row). */
      top: 92px;
      right: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-primary,
    .btn-ghost {
      transition: none;
    }
    .btn-primary:hover {
      transform: none;
    }
  }
</style>
