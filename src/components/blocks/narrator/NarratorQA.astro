---
// "Five questions, on the practice." — numbered Q&A list with side-column
// number + tag pill, italic-serif question, sans answer.

export interface QAItem {
  n: string;
  q: string;
  a: string;
  tag: string;
}
interface Props {
  eyebrow: string;
  headingHtml: string;
  qa: QAItem[];
}
const { eyebrow, headingHtml, qa }: Props = Astro.props;
---

<section class="qa">
  <div class="head">
    <span class="eb">{eyebrow}</span>
    <h2 class="hd" set:html={headingHtml} />
  </div>

  <div class="list">
    {
      qa.map((item) => (
        <article class="item">
          <div class="side">
            <span class="num">{item.n}</span>
            <span class="tag">{item.tag}</span>
          </div>
          <div class="body">
            <h3 class="q">{item.q}</h3>
            <p class="a">{item.a}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .qa {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px 80px;
  }
  .head {
    margin-bottom: 48px;
    max-width: 800px;
  }
  .eb {
    display: block;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-muted-foreground);
  }
  .hd {
    margin: 14px 0 0;
    font-size: 0;
    line-height: 1;
  }
  .hd :global(.serif) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(36px, 4.4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-foreground);
  }
  .hd :global(.sans) {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(36px, 4.4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--color-muted-foreground);
  }

  .list {
    display: flex;
    flex-direction: column;
  }
  .item {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 56px;
    padding: 40px 0;
    border-top: 1px solid var(--color-border);
  }
  .item:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .side {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 6px;
  }
  .num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 48px;
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--color-brand);
  }
  .tag {
    width: fit-content;
    padding: 4px 12px;
    border-radius: 9999px;
    background: var(--brand-100);
    color: var(--brand-700);
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .body {
    min-width: 0;
  }
  .q {
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(24px, 2.8vw, 36px);
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
    text-wrap: balance;
  }
  .a {
    margin: 0;
    max-width: 62ch;
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.7;
    color: var(--color-foreground);
  }

  @media (max-width: 920px) {
    .qa {
      padding: 0 16px 56px;
    }
    .item {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 28px 0;
    }
    .side {
      flex-direction: row;
      align-items: center;
      gap: 16px;
      padding-top: 0;
    }
    .num {
      font-size: 36px;
    }
  }
</style>
