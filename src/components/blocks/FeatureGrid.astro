---
import Container from '../primitives/Container.astro';
import Section from '../layout/Section.astro';
import Heading from '../primitives/Heading.astro';
import Text from '../primitives/Text.astro';
import Grid from '../layout/Grid.astro';

interface Feature {
  title: string;
  description: string;
}
interface Props {
  heading?: string;
  intro?: string;
  features: Feature[];
  columns?: 2 | 3 | 4;
}
const { heading, intro, features, columns = 3 }: Props = Astro.props;
---

<Section space="lg">
  <Container>
    {
      heading && (
        <div class="mx-auto max-w-2xl text-center">
          <Heading as="h2" size="lg">
            {heading}
          </Heading>
          {intro && (
            <Text size="lg" tone="muted" class="mt-4">
              {intro}
            </Text>
          )}
        </div>
      )
    }
    <Grid cols={columns} gap="lg" class="mt-12">
      {
        features.map((feature) => (
          <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
            <Heading as="h3" size="sm" font="sans">
              {feature.title}
            </Heading>
            <Text tone="muted" class="mt-2">
              {feature.description}
            </Text>
          </div>
        ))
      }
    </Grid>
  </Container>
</Section>
