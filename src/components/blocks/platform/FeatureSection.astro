---
import Button from '../../primitives/Button.astro';
import SectionHead from './SectionHead.astro';
import LinkArrow from './LinkArrow.astro';
import FeatureVisual from './FeatureVisual.astro';
import PlatformIcon from './PlatformIcon.astro';

// The repeating product-feature section (Classroom / District / Home): a two-column
// head, two large visual cards (bespoke mockups via FeatureVisual), a four-cell
// connected feature grid, and a customer quote strip. Fully data-driven so all
// three instances share one component.

type VisualKind = 'immersive' | 'journal' | 'dashHero' | 'lineChart' | 'phone' | 'streak';
interface FeatureCard {
  visual: VisualKind;
  label: string;
  title: string;
  text: string;
}
interface GridCell {
  icon: string;
  title: string;
  text: string;
}
export interface FeatureSectionProps {
  id: string;
  eyebrow: string;
  headingHtml: string;
  desc: string;
  cta: { label: string; href: string };
  cards: [FeatureCard, FeatureCard];
  grid: GridCell[];
  customer: { badge: string; name: string; quote: string; egress: { label: string; href: string } };
}
type Props = FeatureSectionProps;
const { id, eyebrow, headingHtml, desc, cta, cards, grid, customer }: Props = Astro.props;
---

<section class="feat" id={id}>
  <div class="pwrap">
    <SectionHead eyebrow={eyebrow} headingHtml={headingHtml} desc={desc}>
      <Button href={cta.href} variant="solid" tone="neutral" shape="pill" size="sm"
        >{cta.label}</Button
      >
    </SectionHead>

    <div class="feat-cards">
      {
        cards.map((c) => (
          <article class="fcard">
            <FeatureVisual kind={c.visual} />
            <div class="body">
              <div class="label">{c.label}</div>
              <p class="ti">{c.title}</p>
              <p class="tx">{c.text}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="fgrid">
      {
        grid.map((cell) => (
          <div class="cell">
            <div class="ic">
              <PlatformIcon name={cell.icon} />
            </div>
            <p class="ti">{cell.title}</p>
            <p class="tx">{cell.text}</p>
          </div>
        ))
      }
    </div>

    <div class="custstrip">
      <div class="logo"><span class="badge">{customer.badge}</span> {customer.name}</div>
      <p class="quote">{customer.quote}</p>
      <LinkArrow label={customer.egress.label} href={customer.egress.href} />
    </div>
  </div>
</section>

<style>
  .feat {
    padding-bottom: 30px;
  }
  .pwrap {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
  }
  @media (min-width: 768px) {
    .pwrap {
      padding: 0 40px;
    }
  }

  .feat-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .fcard {
    border: 1px solid var(--color-border);
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    background: var(--color-card);
    box-shadow: var(--shadow-sm);
  }
  .fcard .body {
    padding: 24px;
  }
  .label {
    font-size: 11.5px;
    font-weight: 600;
    color: var(--color-muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    margin-bottom: 9px;
  }
  .fcard .ti {
    font-size: 17px;
    font-weight: 600;
    margin: 0 0 7px;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }
  .fcard .tx {
    font-size: 14px;
    color: var(--color-muted-foreground);
    line-height: 1.55;
    margin: 0;
    max-width: 46ch;
  }

  .fgrid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--color-border);
    border-radius: 18px;
    margin-top: 18px;
    overflow: hidden;
    background: var(--color-card);
    box-shadow: var(--shadow-sm);
  }
  .fgrid .cell {
    padding: 24px 22px;
    border-right: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    min-height: 178px;
  }
  .fgrid .cell:last-child {
    border-right: none;
  }
  .fgrid .cell .ic {
    width: 22px;
    height: 22px;
    color: var(--color-foreground);
    margin-bottom: auto;
    opacity: 0.85;
  }
  .fgrid .cell .ic :global(svg) {
    width: 22px;
    height: 22px;
  }
  .fgrid .cell .ti {
    font-size: 14.5px;
    font-weight: 600;
    margin: 16px 0 6px;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }
  .fgrid .cell .tx {
    font-size: 13px;
    color: var(--color-muted-foreground);
    line-height: 1.5;
    margin: 0;
  }

  .custstrip {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 16px;
    padding: 18px 22px;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background: var(--color-card);
    flex-wrap: wrap;
  }
  .custstrip .logo {
    font-weight: 700;
    font-size: 16px;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .custstrip .logo .badge {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: var(--brand-100);
    color: var(--brand-700);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
  }
  .custstrip .quote {
    color: var(--color-muted-foreground);
    font-size: 14px;
    flex: 1;
    min-width: 200px;
    margin: 0;
  }

  @media (max-width: 820px) {
    .feat-cards {
      grid-template-columns: 1fr;
    }
    .fgrid {
      grid-template-columns: 1fr 1fr;
    }
    .fgrid .cell:nth-child(2) {
      border-right: none;
    }
    .fgrid .cell:nth-child(1),
    .fgrid .cell:nth-child(2) {
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>
