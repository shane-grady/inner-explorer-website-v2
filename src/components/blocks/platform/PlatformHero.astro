---
import Button from '../../primitives/Button.astro';
import PlatformIcon from './PlatformIcon.astro';

// Platform hero: a two-column intro (duet headline + right-aligned subhead + CTAs)
// over a showcase panel that previews each platform — the Classroom practice arc,
// the District dashboard bento, and the Home TuneIn sync. The three views crossfade
// via a tiny vanilla tab script; Classroom is `.on` in markup so it's visible with
// no JS. The mockups are decorative (the page's real copy lives in the sections
// below), so the showcase is labelled but the device chrome is aria-hidden.

interface Cta {
  label: string;
  href: string;
}
interface Props {
  titleLine1: string;
  titleLine2: string;
  subtitle: string;
  primaryCta: Cta;
  secondaryCta: Cta;
}
const { titleLine1, titleLine2, subtitle, primaryCta, secondaryCta }: Props = Astro.props;
---

<section class="phero">
  <div class="phero-inner">
    <div class="hero-top">
      <div class="hero-lead">
        <h1>{titleLine1}<br /><span class="l2">{titleLine2}</span></h1>
        <div class="hero-actions">
          <Button href={primaryCta.href} tone="brand" shape="pill" size="sm"
            >{primaryCta.label}</Button
          >
          <Button href={secondaryCta.href} variant="outline" tone="neutral" shape="pill" size="sm">
            {secondaryCta.label}
          </Button>
        </div>
      </div>
      <p class="hero-sub">{subtitle}</p>
    </div>

    <div class="showcase">
      <div class="showcase-tabs" role="tablist" aria-label="Preview the platform">
        <button
          class="showcase-tab on"
          role="tab"
          type="button"
          aria-selected="true"
          aria-controls="hv-classroom"
          data-tab="classroom"
        >
          <span class="dot" aria-hidden="true"></span> Classroom
        </button>
        <button
          class="showcase-tab"
          role="tab"
          type="button"
          aria-selected="false"
          aria-controls="hv-district"
          data-tab="district"
        >
          <span class="dot" aria-hidden="true"></span> District
        </button>
        <button
          class="showcase-tab"
          role="tab"
          type="button"
          aria-selected="false"
          aria-controls="hv-home"
          data-tab="home"
        >
          <span class="dot" aria-hidden="true"></span> Home
        </button>
      </div>

      <div class="hstage">
        {/* ===== CLASSROOM · practice arc ===== */}
        <div
          class="hv on"
          id="hv-classroom"
          role="tabpanel"
          aria-label="Classroom"
          data-view="classroom"
        >
          <div class="hv-pad">
            <div class="arc-wrap">
              <div class="arc-rail" aria-hidden="true"></div>
              <div class="acard p1 mesh-dusk">
                <span class="grain"></span>
                <span class="ac-pill">8 min</span>
                <span class="ac-lbl">Mountain View</span>
              </div>
              <div class="acard p2 mesh-water">
                <span class="grain"></span>
                <span class="ac-pill">6 min</span>
                <span class="ac-lbl">River Path</span>
              </div>
              <div class="acard p3 mesh-forest is-active">
                <span class="grain"></span>
                <span class="ac-pill on">Day 14 · Today</span>
                <span class="ac-play"><PlatformIcon name="play" /></span>
                <span class="ac-lbl">Forest Walk</span>
              </div>
              <div class="acard p4 mesh-calm">
                <span class="grain"></span>
                <span class="ac-pill">4 min</span>
                <span class="ac-lbl">Lake Reflection</span>
              </div>
              <div class="acard p5 mesh-dawn">
                <span class="grain"></span>
                <span class="ac-pill">7 min</span>
                <span class="ac-lbl">Open Field</span>
              </div>
            </div>
            <div class="arc-foot">
              <div class="arc-meta">
                Day 14 of 21 · Calm Breathing series<b>Forest Walk · 5 min · Grades 3–5</b>
              </div>
              <a class="arc-cta" href={primaryCta.href}>
                Start practice <PlatformIcon name="arrow" />
              </a>
            </div>
          </div>
        </div>

        {/* ===== DISTRICT · dashboard bento ===== */}
        <div class="hv" id="hv-district" role="tabpanel" aria-label="District" data-view="district">
          <div class="dash" aria-hidden="true">
            <div class="dash-main">
              <div class="dash-head">
                <div class="dh-ti2">District Overview</div>
                <div class="dh-filters">
                  <span class="fpill"><PlatformIcon name="calendar" />Jan 01 – Jul 31</span>
                  <span class="fpill ghost">Daily <PlatformIcon name="chevron" /></span>
                  <span class="fpill ghost"
                    ><PlatformIcon name="building" />All Schools <PlatformIcon
                      name="chevron"
                    /></span
                  >
                </div>
              </div>

              <div class="dash-bento">
                <div class="brow top">
                  <div class="dcard">
                    <div class="dcard-h">
                      <span class="t">User Adoption</span><span class="menu">···</span>
                    </div>
                    <div class="ua-tabs">
                      <div class="uat"><span>Licensed Seats</span><b>2,400</b></div>
                      <div class="uat"><span>Registered</span><b>1,850</b></div>
                      <div class="uat on"><span>Active Users</span><b>1,240</b></div>
                      <div class="uat"><span>Engaged</span><b>890</b></div>
                      <div class="uat"><span>Champions</span><b>320</b></div>
                    </div>
                    <div class="ua-chart">
                      <div class="uabar" style="--h:100%"><span class="cap">2.4k</span></div>
                      <div class="uabar" style="--h:77%"><span class="cap">1.9k</span></div>
                      <div class="uabar active" style="--h:52%"><span class="cap">1.2k</span></div>
                      <div class="uabar" style="--h:37%"><span class="cap">890</span></div>
                      <div class="uabar" style="--h:14%"><span class="cap">320</span></div>
                    </div>
                  </div>
                  <div class="dcard">
                    <div class="dcard-h">
                      <span class="t">Mindful Minutes</span><span class="menu">···</span>
                    </div>
                    <div class="mm-big">41,540 <span class="mm-pill">↗ +15%</span></div>
                    <div class="mm-list">
                      <div class="mmr">
                        <div class="mmr-top">
                          <span>Elementary Schools</span><b>24,200 min</b>
                        </div><div class="seg green" style="--p:100%"></div>
                      </div>
                      <div class="mmr">
                        <div class="mmr-top"><span>Middle Schools</span><b>10,400 min</b></div><div
                          class="seg blue"
                          style="--p:43%"
                        >
                        </div>
                      </div>
                      <div class="mmr">
                        <div class="mmr-top"><span>High Schools</span><b>6,940 min</b></div><div
                          class="seg pink"
                          style="--p:29%"
                        >
                        </div>
                      </div>
                      <div class="mmr">
                        <div class="mmr-top"><span>Early Learning</span><b>3,200 min</b></div><div
                          class="seg purple"
                          style="--p:14%"
                        >
                        </div>
                      </div>
                      <div class="mmr">
                        <div class="mmr-top"><span>Support Staff</span><b>1,800 min</b></div><div
                          class="seg amber"
                          style="--p:8%"
                        >
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="brow bot">
                  <div class="dcard sm">
                    <div class="dcard-h">
                      <span class="t">Retention</span><span class="menu">···</span>
                    </div>
                    <div class="chip-sm">Peak: 42%</div>
                    <svg class="ret-line" viewBox="0 0 240 78" preserveAspectRatio="none">
                      <line class="rl-grid" x1="0" y1="20" x2="240" y2="20"></line>
                      <line class="rl-grid" x1="0" y1="45" x2="240" y2="45"></line>
                      <line class="rl-grid" x1="0" y1="70" x2="240" y2="70"></line>
                      <polyline
                        class="rl-trend"
                        fill="none"
                        stroke-width="2.5"
                        stroke-linejoin="round"
                        points="0,60 40,60 40,52 80,52 80,40 120,40 120,30 160,30 160,38 200,38 200,33 240,33"
                      ></polyline>
                    </svg>
                    <div class="ret-ax">
                      <span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span><span
                        >May</span
                      ><span>Jun</span>
                    </div>
                  </div>
                  <div class="dcard sm">
                    <div class="dcard-h">
                      <span class="t">Practice Sessions</span><span class="menu">···</span>
                    </div>
                    <div class="chip-sm">Peak: Wed</div>
                    <div class="sm-big">106k</div>
                    <div class="sm-cmp">vs last period <b>+34,002</b></div>
                    <div class="dotgrid green">
                      <i class="a"></i><i class="a"></i><i class="a"></i><i class="b"></i><i
                        class="a"></i><i class="a"></i><i class="a"></i><i class="b"></i><i
                        class="a"></i><i class="a"></i>
                      <i class="a"></i><i class="b"></i><i class="a"></i><i class="a"></i><i
                        class="a"></i><i class="b"></i><i class="a"></i><i class="a"></i><i></i><i
                      ></i>
                      <i class="a"></i><i class="a"></i><i class="b"></i><i class="a"></i><i></i><i
                      ></i><i></i><i></i><i></i><i></i>
                    </div>
                  </div>
                  <div class="dcard sm">
                    <div class="dcard-h">
                      <span class="t">Active Educators</span><span class="menu">···</span>
                    </div>
                    <div class="chip-sm">Highest: Thu</div>
                    <div class="sm-big">1,284</div>
                    <div class="sm-cmp">vs last period <b>+320</b></div>
                    <div class="dotgrid blue">
                      <i class="a"></i><i class="a"></i><i class="b"></i><i class="a"></i><i
                        class="a"></i><i class="b"></i><i class="a"></i><i class="a"></i><i></i><i
                      ></i>
                      <i class="a"></i><i class="b"></i><i class="a"></i><i class="a"></i><i
                        class="b"></i><i class="a"></i><i></i><i></i><i></i><i></i>
                      <i class="b"></i><i class="a"></i><i class="a"></i><i></i><i></i><i></i><i
                      ></i><i></i><i></i><i></i>
                    </div>
                  </div>
                  <div class="dcard ins">
                    <span class="grain"></span>
                    <div class="ins-pill">◇ Insights</div>
                    <div class="ins-big">75%</div>
                    <div class="ins-tx">
                      Engagement rate increased by 12% compared to last week.
                    </div>
                    <div class="ins-segs"><i class="on"></i><i></i><i></i></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* ===== HOME · TuneIn (classroom → home sync) ===== */}
        <div class="hv" id="hv-home" role="tabpanel" aria-label="Home" data-view="home">
          <div class="tunein">
            <div class="sync-source" aria-hidden="true">
              <div class="ss-eb">In class today</div>
              <div class="ss-card">
                <div class="ss-thumb mesh-forest"><span class="grain"></span></div>
                <div class="ss-meta">
                  <div class="ss-ti">Forest Walk</div>
                  <div class="ss-sub">Mrs. Palmer's Grade 3 · Day 14</div>
                </div>
              </div>
              <div class="ss-foot"><span class="ss-dot"></span>24 students practiced together</div>
            </div>

            <div class="sync-link" aria-hidden="true">
              <div class="sl-line"></div>
              <div class="sl-badge"><PlatformIcon name="link" /> TuneIn</div>
              <div class="sl-line"></div>
              <span class="sl-pulse"></span>
              <div class="sl-cap">syncs class → home</div>
            </div>

            <div class="phone phone-lg" aria-hidden="true">
              <div class="notch"></div>
              <div class="screen tiscreen">
                <div class="tih-top mesh-forest">
                  <span class="grain"></span>
                  <div class="ph-status"><span>8:32</span><span>●●●</span></div>
                  <div class="tih-brand"><PlatformIcon name="link" /> TuneIn</div>
                  <div class="tih-sync">
                    <span class="tih-syncdot"></span>Linked to Mrs. Palmer's class
                  </div>
                </div>
                <div class="tih-body">
                  <div class="tih-eb">Tonight · same as class today</div>
                  <div class="tih-prac">
                    <div class="tp-thumb mesh-forest">
                      <span class="grain"></span><span class="tp-play"
                        ><PlatformIcon name="play" /></span
                      >
                    </div>
                    <div class="tp-meta">
                      <div class="tp-ti">Forest Walk</div><div class="tp-sub">
                        5 min · Calm Breathing
                      </div>
                    </div>
                  </div>
                  <div class="tih-cta"><PlatformIcon name="play" /> Play at home</div>
                  <div class="tih-note">
                    The exact practice your child did in class today — listen together and the calm
                    carries home.
                  </div>
                  <div class="tih-fam">
                    <span class="avs"><span></span><span></span></span>You and Maya, tonight
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .phero {
    padding: clamp(96px, 11vh, 128px) 0 0;
  }
  .phero-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
  }
  @media (min-width: 768px) {
    .phero-inner {
      padding: 0 40px;
    }
  }

  /* ---- intro ---- */
  .hero-top {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 40px;
    align-items: end;
    padding-bottom: 34px;
  }
  .hero-lead h1 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(40px, 5vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 500;
    color: var(--color-foreground);
  }
  .hero-lead h1 .l2 {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .hero-actions {
    display: flex;
    gap: 10px;
    margin-top: 26px;
  }
  .hero-sub {
    color: var(--color-muted-foreground);
    font-size: 17px;
    line-height: 1.5;
    max-width: 440px;
    justify-self: end;
    margin: 0;
  }
  @media (max-width: 820px) {
    .hero-top {
      grid-template-columns: 1fr;
      gap: 20px;
      align-items: start;
    }
    .hero-sub {
      justify-self: start;
    }
  }

  /* ---- showcase shell ---- */
  .showcase {
    border-radius: 26px;
    overflow: hidden;
    background: var(--neutral-100);
    border: 1px solid var(--color-border);
  }
  .showcase-tabs {
    display: flex;
    gap: 6px;
    padding: 10px;
  }
  .showcase-tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 13px 10px;
    font-size: 14.5px;
    font-weight: 500;
    color: var(--color-muted-foreground);
    background: transparent;
    border: none;
    border-radius: 13px;
    cursor: pointer;
    transition: all 0.25s var(--ease-out);
  }
  .showcase-tab .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--neutral-400);
    transition: background 0.2s;
  }
  .showcase-tab:hover {
    color: var(--color-foreground);
  }
  .showcase-tab.on {
    background: var(--color-card);
    color: var(--color-foreground);
    box-shadow:
      0 1px 2px color-mix(in oklab, var(--neutral-900) 7%, transparent),
      0 6px 16px -6px color-mix(in oklab, var(--neutral-900) 12%, transparent);
  }
  .showcase-tab.on .dot {
    background: var(--color-brand);
  }

  .hstage {
    position: relative;
    height: 624px;
    overflow: hidden;
  }
  .hv {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transform: scale(0.992);
    transition:
      opacity 0.55s var(--ease-out),
      transform 0.55s var(--ease-out);
  }
  .hv.on {
    opacity: 1;
    visibility: visible;
    transform: none;
  }

  /* ---- Classroom · practice arc ---- */
  .hv-pad {
    position: relative;
    height: 100%;
    padding: 24px 18px 18px;
    display: flex;
    flex-direction: column;
  }
  .arc-wrap {
    position: relative;
    flex: 1;
    width: 100%;
    margin: 0 auto;
    overflow: visible;
  }
  .arc-rail {
    position: absolute;
    left: 50%;
    top: 138%;
    width: 1900px;
    height: 1900px;
    transform: translate(-50%, -50%);
    border-radius: 9999px;
    border: 1px dashed color-mix(in oklab, var(--neutral-900) 10%, transparent);
    pointer-events: none;
  }
  .acard {
    position: absolute;
    left: 50%;
    top: 34px;
    width: 228px;
    height: 316px;
    margin-left: -114px;
    border-radius: 24px;
    overflow: hidden;
    transform-origin: 50% 1500px;
    box-shadow: 0 22px 50px -16px color-mix(in oklab, var(--neutral-900) 42%, transparent);
  }
  .acard .grain {
    opacity: 0.42;
    z-index: 1;
  }
  .acard::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to top,
      color-mix(in oklab, var(--neutral-950) 46%, transparent),
      transparent 56%
    );
  }
  .ac-pill {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    padding: 6px 13px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--color-white) 24%, transparent);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border: 1px solid color-mix(in oklab, var(--color-white) 42%, transparent);
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-white);
    white-space: nowrap;
  }
  .ac-pill.on {
    background: color-mix(in oklab, var(--color-white) 92%, transparent);
    color: var(--brand-800);
    border-color: var(--color-white);
  }
  .ac-lbl {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 20px;
    z-index: 3;
    color: var(--color-white);
    text-align: center;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 24px;
    text-shadow: 0 2px 10px color-mix(in oklab, var(--neutral-950) 40%, transparent);
  }
  .ac-play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 56px;
    height: 56px;
    border-radius: 999px;
    background: var(--color-white);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 4;
    box-shadow: 0 6px 18px color-mix(in oklab, var(--neutral-950) 28%, transparent);
  }
  .ac-play :global(svg) {
    width: 19px;
    height: 19px;
    color: var(--color-foreground);
    margin-left: 2px;
  }
  .acard.is-active .ac-play {
    display: flex;
  }
  /* every card rotates around one shared pivot far below → a single true arc */
  .acard.p1 {
    transform: rotate(-28deg);
    opacity: 0.52;
    z-index: 1;
  }
  .acard.p2 {
    transform: rotate(-14deg);
    z-index: 3;
  }
  .acard.p3 {
    transform: scale(1.12);
    transform-origin: center;
    z-index: 6;
    box-shadow:
      0 40px 84px -20px color-mix(in oklab, var(--neutral-900) 55%, transparent),
      0 0 0 3px color-mix(in oklab, var(--color-white) 82%, transparent) inset;
  }
  .acard.p4 {
    transform: rotate(14deg);
    z-index: 3;
  }
  .acard.p5 {
    transform: rotate(28deg);
    opacity: 0.52;
    z-index: 1;
  }

  .arc-foot {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding-top: 8px;
    flex-shrink: 0;
  }
  .arc-meta {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.07em;
    color: var(--neutral-400);
    text-transform: uppercase;
    line-height: 1.4;
    text-align: center;
  }
  .arc-meta b {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 17px;
    color: var(--color-foreground);
    text-transform: none;
    letter-spacing: 0;
    margin-top: 3px;
  }
  .arc-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 20px;
    border-radius: 999px;
    background: var(--color-brand);
    color: var(--color-white);
    font-size: 14px;
    font-weight: 500;
    box-shadow: 0 1px 2px color-mix(in oklab, var(--brand-600) 30%, transparent);
    transition: background 0.2s;
  }
  .arc-cta:hover {
    background: var(--brand-700);
  }
  .arc-cta :global(svg) {
    width: 14px;
    height: 14px;
  }

  /* ---- District · dashboard bento ---- */
  .dash {
    position: absolute;
    inset: 0;
    display: flex;
  }
  .dash-main {
    flex: 1;
    padding: 18px 22px 20px;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .dash-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .dh-ti2 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 25px;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }
  .dh-filters {
    display: flex;
    gap: 8px;
  }
  .fpill {
    font-size: 11.5px;
    font-weight: 500;
    color: var(--neutral-700);
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 7px 12px;
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }
  .fpill :global(svg) {
    width: 12px;
    height: 12px;
    color: var(--neutral-400);
  }
  .fpill.ghost {
    color: var(--color-muted-foreground);
  }

  .dash-bento {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 11px;
    min-height: 0;
  }
  .brow {
    display: grid;
    gap: 11px;
    min-height: 0;
  }
  .brow.top {
    grid-template-columns: 1.62fr 1fr;
    flex: 1.24;
  }
