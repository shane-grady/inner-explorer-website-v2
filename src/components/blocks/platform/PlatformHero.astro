  // Hero showcase: tab switches between the three platform views (crossfade via the
  // `.on` class). Classroom is `.on` in markup, so the preview works with no JS.
  const tabs = document.querySelector<HTMLElement>('.showcase .showcase-tabs');
  const stage = document.querySelector<HTMLElement>('.showcase .hstage');
  if (tabs && stage) {
    const btns = Array.from(tabs.querySelectorAll<HTMLButtonElement>('.showcase-tab'));
    const views = Array.from(stage.querySelectorAll<HTMLElement>('.hv'));
    btns.forEach((b) => {
      b.addEventListener('click', () => {
        const v = b.getAttribute('data-tab');
        btns.forEach((x) => {
          const on = x === b;
          x.classList.toggle('on', on);
          x.setAttribute('aria-selected', String(on));
        });
        views.forEach((hv) => hv.classList.toggle('on', hv.getAttribute('data-view') === v));
      });
    });
  }
</script>
