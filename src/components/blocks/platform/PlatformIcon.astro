---
// Shared inline-SVG icon set for the Platform page (feature grids, safety cells,
// SSO benefits, link arrows). One source of truth so icon markup isn't copy-pasted
// across blocks. Stroke icons inherit `currentColor`; size is controlled by the
// consumer via CSS on the rendered <svg>. `play` is the only filled glyph.

interface Props {
  name: string;
  strokeWidth?: number;
  /** Intrinsic px size — only needed where no parent CSS sizes the <svg> (e.g.
      inside a Button slot). Omit to let consumer CSS control the size. */
  size?: number;
  class?: string;
}

const ICONS: Record<string, { fill?: boolean; body: string }> = {
  // generic
  play: { fill: true, body: '<path d="M8 5v14l11-7z"/>' },
  arrow: { body: '<path d="M5 12h14M13 6l6 6-6 6"/>' },
  chevron: { body: '<path d="m6 9 6 6 6-6"/>' },
  'chevron-right': { body: '<path d="M9 18l6-6-6-6"/>' },
  lock: {
    body: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  },
  link: { body: '<path d="M9 17H7A5 5 0 0 1 7 7h2M15 7h2a5 5 0 0 1 0 10h-2M8 12h8"/>' },
  calendar: {
    body: '<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>',
  },
  building: { body: '<path d="M3 21h18M5 21V8l7-5 7 5v13M9 21v-6h6v6"/>' },
  // classroom feature grid
  series: {
    body: '<path d="m12 2 9 5-9 5-9-5 9-5Z"/><path d="m3 12 9 5 9-5"/><path d="m3 17 9 5 9-5"/>',
  },
  journal: {
    body: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  },
  milestone: { body: '<circle cx="12" cy="8" r="6"/><path d="M15.5 13 17 22l-5-3-5 3 1.5-9"/>' },
  // district feature grid
  adoption: { body: '<path d="M3 17 9 11l4 4 8-8"/><path d="M17 7h4v4"/>' },
  engagement: { body: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>' },
  wellbeing: {
    body: '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/>',
  },
  reporting: {
    body: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M9 13h6M9 17h6"/>',
  },
  // home feature grid
  gift: {
    body: '<rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"/><path d="M12 8C12 8 12 2 8.5 2A2.5 2.5 0 0 0 8.5 8M12 8s0-6 3.5-6a2.5 2.5 0 0 1 0 6"/>',
  },
  moon: { body: '<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>' },
  flame: {
    body: '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.4-.5-2-1-3-1.1-2.1-.2-4 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.2.4-2.3 1-3a2.5 2.5 0 0 0 2.5 2.5Z"/>',
  },
  home: {
    body: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/>',
  },
  // safety
  'shield-check': {
    body: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/>',
  },
  users: {
    body: '<circle cx="9" cy="8" r="4"/><path d="M2 21a7 7 0 0 1 14 0"/><path d="M17 8a4 4 0 0 1 0 8M16 21a7 7 0 0 0-2-4.9"/>',
  },
  // sso benefits
  key: {
    body: '<circle cx="8" cy="15" r="4"/><path d="M10.85 12.15 19 4"/><path d="m18 5 2 2"/><path d="m15 8 2 2"/>',
  },
  refresh: {
    body: '<path d="M3 2v6h6"/><path d="M21 12A9 9 0 0 0 6 5.3L3 8"/><path d="M21 22v-6h-6"/><path d="M3 12a9 9 0 0 0 15 6.7l3-2.7"/>',
  },
  device: { body: '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>' },
};

const { name, strokeWidth = 2, size, class: className }: Props = Astro.props;
const icon = ICONS[name] ?? ICONS.play;
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill={icon.fill ? 'currentColor' : 'none'}
  stroke={icon.fill ? undefined : 'currentColor'}
  stroke-width={icon.fill ? undefined : strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class={className}
  set:html={icon.body}
/>
