---
import LinkArrow from './LinkArrow.astro';

// Impact showcase: a centered headline with an In-schools / In-research toggle, then
// three gradient "poster" cards. The toggle swaps which set of three is shown (the
// "schools" set is visible with no JS); a small vanilla script handles the switch.

type Theme = 'forest' | 'dawn' | 'dusk' | 'water' | 'calm' | 'nature' | 'space';
interface Story {
  tag: string;
  title: string;
  theme: Theme;
}
export interface ImpactStoriesProps {
  headingHtml: string;
  toggle: [{ id: string; label: string }, { id: string; label: string }];
  groups: Record<string, [Story, Story, Story]>;
  egress: { label: string; href: string };
}
type Props = ImpactStoriesProps;
const { headingHtml, toggle, groups, egress }: Props = Astro.props;
---

<section class="impact">
  <div class="pwrap">
    <div class="center">
      <h2 set:html={headingHtml} />
      <div class="tog" role="tablist" aria-label="Impact view">
        {
          toggle.map((t, i) => (
            <button
              class:list={['tog-btn', { on: i === 0 }]}
              type="button"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`impact-${t.id}`}
              data-impact-tab={t.id}
            >
              {t.label}
            </button>
          ))
        }
      </div>
    </div>

    {
      toggle.map((t, i) => (
        <div
          class:list={['impact-grid', { on: i === 0 }]}
          id={`impact-${t.id}`}
          role="tabpanel"
          aria-label={t.label}
          data-impact-panel={t.id}
        >
          {groups[t.id].map((s) => (
            <article class={`istory mesh-${s.theme}`}>
              <span class="grain" aria-hidden="true" />
              <div class="ct">
                <div class="tag">{s.tag}</div>
                <p class="h">{s.title}</p>
              </div>
            </article>
          ))}
        </div>
      ))
    }

    <div class="impact-egress">
      <LinkArrow label={egress.label} href={egress.href} />
    </div>
  </div>
</section>

<style>
  .impact {
    padding: 64px 0;
  }
  .pwrap {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
  }
  @media (min-width: 768px) {
    .pwrap {
      padding: 0 40px;
    }
  }
  .center {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 18px;
  }
  .center h2 {
    font-family: var(--font-sans);
    font-size: clamp(28px, 3.2vw, 40px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 500;
    margin: 0 0 18px;
    color: var(--color-foreground);
  }
  .center h2 :global(.em) {
    font-family: var(--font-display);
    font-style: italic;
  }
  .tog {
    display: inline-flex;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 4px;
    gap: 4px;
  }
  .tog-btn {
    border: none;
    background: transparent;
    padding: 8px 18px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-muted-foreground);
    cursor: pointer;
    transition:
      background 0.2s var(--ease-out),
      color 0.2s var(--ease-out);
  }
  .tog-btn.on {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .impact-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr 1fr;
    gap: 16px;
    margin-top: 34px;
    align-items: stretch;
  }
  .impact-grid:not(.on) {
    display: none;
  }
  .istory {
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    min-height: 300px;
    color: var(--color-white);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 24px;
    border: 1px solid var(--color-border);
  }
  .istory::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      color-mix(in oklab, var(--neutral-950) 82%, transparent),
      color-mix(in oklab, var(--neutral-950) 12%, transparent) 60%
    );
  }
  .istory .ct {
    position: relative;
    z-index: 2;
  }
  .istory .tag {
    font-size: 12px;
    font-weight: 600;
    opacity: 0.85;
    margin-bottom: 8px;
  }
  .istory .h {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    max-width: 30ch;
  }
  .impact-egress {
    text-align: center;
    margin-top: 30px;
  }
  @media (max-width: 820px) {
    .impact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Impact toggle: switch the visible poster set. "schools" is `.on` in markup, so
  // it shows with no JS.
  const tog = document.querySelector<HTMLElement>('.impact .tog');
  if (tog) {
    const btns = Array.from(tog.querySelectorAll<HTMLButtonElement>('.tog-btn'));
    const panels = Array.from(
      document.querySelectorAll<HTMLElement>('.impact [data-impact-panel]'),
    );
    btns.forEach((b) => {
      b.addEventListener('click', () => {
        const id = b.getAttribute('data-impact-tab');
        btns.forEach((x) => {
          const on = x === b;
          x.classList.toggle('on', on);
          x.setAttribute('aria-selected', String(on));
        });
        panels.forEach((p) => p.classList.toggle('on', p.getAttribute('data-impact-panel') === id));
      });
    });
  }
</script>
