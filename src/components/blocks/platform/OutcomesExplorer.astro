---
import LinkArrow from './LinkArrow.astro';

// Research "Outcomes Explorer": four sourced outcomes as selectable tabs, an honest
// animated before/after comparison (typical classroom indexed to 100 vs. Inner
// Explorer), a plain-language claim + citation, and a quiet provenance strip. The
// first outcome renders at its final state in markup, so the section is meaningful
// with no JS / reduced motion; the script only adds the count-up + bar-grow.

interface Outcome {
  id: string;
  label: string;
  statValue: string; // e.g. '+28%'
  kicker: string; // e.g. 'higher grades'
  sign: '+' | '−';
  fig: number;
  typ: number;
  ie: number;
  dir: string;
  claimHtml: string;
  src: string;
}
export interface OutcomesExplorerProps {
  eyebrow: string;
  headingHtml: string;
  desc: string;
  egress: { label: string; href: string };
  outcomes: Outcome[];
  provenance: string[];
}
type Props = OutcomesExplorerProps;
const { eyebrow, headingHtml, desc, egress, outcomes, provenance }: Props = Astro.props;

const first = outcomes[0];
const max0 = Math.max(first.typ, first.ie);
const typH0 = `${(first.typ / max0) * 100}%`;
const ieH0 = `${(first.ie / max0) * 100}%`;
---

<section class="research" id="research">
  <div class="pwrap">
    <div class="research-head">
      <div class="left">
        <span class="eyebrow up">{eyebrow}</span>
        <h2 set:html={headingHtml} />
      </div>
      <div class="right">
        <p class="desc">{desc}</p>
        <LinkArrow label={egress.label} href={egress.href} class="rx-head-link" />
      </div>
    </div>

    <div class="rx">
      <div class="rx-tabs" role="tablist" aria-label="Outcomes">
        {
          outcomes.map((o, i) => (
            <button
              class:list={['rx-tab', { on: i === 0 }]}
              type="button"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-rx-tab={o.id}
              data-sign={o.sign}
              data-fig={o.fig}
              data-typ={o.typ}
              data-ie={o.ie}
              data-dir={o.dir}
              data-claim={o.claimHtml}
              data-src={o.src}
            >
              <span class="rl">{o.label}</span>
              <span class="rv">{o.statValue}</span>
              <span class="rk">{o.kicker}</span>
            </button>
          ))
        }
      </div>

      <div class="rx-body">
        <div class="rx-viz">
          <div class="rx-figure">
            <span data-rx-fig>{first.sign}{first.fig}</span><span class="u">%</span>
          </div>
          <div class="rx-dir" data-rx-dir>{first.dir}</div>
          <div class="rx-plot">
            <div class="rx-col">
              <div class="rx-bar typ" data-rx-typ style={`height:${typH0}`}>
                <span class="rx-val">{first.typ}</span>
              </div>
            </div>
            <div class="rx-col">
              <div class="rx-bar ie" data-rx-ie style={`height:${ieH0}`}>
                <span class="rx-val">{first.ie}</span>
              </div>
            </div>
          </div>
          <div class="rx-caps">
            <span>Typical classroom</span>
            <span class="ie">With Inner Explorer</span>
          </div>
          <p class="rx-note">Indexed to a typical classroom = 100.</p>
        </div>
        <div class="rx-narr">
          <p class="rx-claim" data-rx-claim set:html={first.claimHtml} />
          <div class="rx-meta">
            <div class="rx-src" data-rx-src>{first.src}</div>
            <LinkArrow label="Read the research" href={egress.href} class="rx-link" />
          </div>
        </div>
      </div>
    </div>

    <div class="rx-prov">
      {provenance.map((p) => <span set:html={p} />)}
    </div>
  </div>
</section>

<style>
  .research {
    padding: 64px 0;
  }
  .pwrap {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
  }
  @media (min-width: 768px) {
    .pwrap {
      padding: 0 40px;
    }
  }

  .research-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: end;
    margin-bottom: 30px;
  }
  .eyebrow.up {
    display: block;
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted-foreground);
  }
  .research-head h2 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(28px, 3.2vw, 40px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    font-weight: 500;
    max-width: 16ch;
    color: var(--color-foreground);
  }
  .research-head h2 :global(.em) {
    font-family: var(--font-display);
    font-style: italic;
  }
  .research-head .right {
    justify-self: end;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .research-head .desc {
    color: var(--color-muted-foreground);
    font-size: 16px;
    line-height: 1.6;
    margin: 0;
  }
  .rx-head-link {
    margin-top: 18px;
  }

  .rx {
    border: 1px solid var(--color-border);
    border-radius: 22px;
    background: var(--color-card);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .rx-tabs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .rx-tab {
    position: relative;
    text-align: left;
    background: transparent;
    border: 0;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 20px 22px 19px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    cursor: pointer;
    transition: background 0.2s var(--ease-out);
  }
  .rx-tab:last-child {
    border-right: none;
  }
  .rx-tab:hover {
    background: var(--color-muted);
  }
  .rx-tab .rl {
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--color-muted-foreground);
  }
  .rx-tab .rv {
    font-size: 27px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .rx-tab .rk {
    font-size: 12.5px;
    color: var(--color-muted-foreground);
  }
  .rx-tab::after {
    content: '';
    position: absolute;
    left: -1px;
    right: -1px;
    bottom: -1px;
    height: 2px;
    background: var(--color-brand);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s var(--ease-out);
  }
  .rx-tab.on {
    background: var(--color-card);
  }
  .rx-tab.on .rv {
    color: var(--color-brand);
  }
  .rx-tab.on::after {
    transform: scaleX(1);
  }

  .rx-body {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
  }
  .rx-viz {
    padding: 38px 40px 34px;
    display: flex;
    flex-direction: column;
  }
  .rx-figure {
    font-size: clamp(58px, 7vw, 94px);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 0.86;
    color: var(--color-brand);
    font-variant-numeric: tabular-nums;
    display: flex;
    align-items: flex-start;
  }
  .rx-figure .u {
    font-size: 0.4em;
    font-weight: 500;
    margin-left: 3px;
    margin-top: 0.12em;
  }
  .rx-dir {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 25px;
    color: var(--color-foreground);
    margin-top: 12px;
  }
  .rx-plot {
    display: flex;
    align-items: flex-end;
    gap: 26px;
    height: 182px;
    margin-top: auto;
    padding-top: 30px;
    border-bottom: 1px solid var(--neutral-300);
  }
  .rx-col {
    flex: 1;
    max-width: 118px;
    height: 100%;
    display: flex;
    align-items: flex-end;
  }
  .rx-bar {
    width: 100%;
    border-radius: 9px 9px 0 0;
    position: relative;
    transition: height 0.9s var(--ease-out);
  }
  .rx-bar .rx-val {
    position: absolute;
    top: -25px;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--neutral-700);
  }
  .rx-bar.typ {
    background: var(--color-muted);
    border: 1px solid var(--neutral-300);
  }
  .rx-bar.ie {
    background: var(--color-brand);
  }
  .rx-bar.ie .rx-val {
    color: var(--color-brand);
  }
  .rx-caps {
    display: flex;
    gap: 26px;
    margin-top: 11px;
  }
  .rx-caps span {
    flex: 1;
    max-width: 118px;
    text-align: center;
    font-size: 12px;
    color: var(--color-muted-foreground);
    line-height: 1.3;
  }
  .rx-caps span.ie {
    color: var(--color-foreground);
    font-weight: 600;
  }
  .rx-note {
    font-size: 11.5px;
    color: var(--neutral-400);
    margin-top: 14px;
  }

  .rx-narr {
    padding: 38px 40px 34px;
    border-left: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
  }
  .rx-claim {
    font-size: 20px;
    line-height: 1.5;
    color: var(--neutral-700);
    margin: 0;
    letter-spacing: -0.01em;
    text-wrap: pretty;
  }
  .rx-claim :global(strong) {
    color: var(--color-foreground);
    font-weight: 600;
  }
  .rx-meta {
    margin-top: auto;
    padding-top: 26px;
  }
  .rx-src {
    font-size: 12.5px;
    color: var(--neutral-700);
    padding-top: 18px;
    border-top: 1px solid var(--color-border);
  }
  .rx-src::before {
    content: 'Source';
    display: block;
    font-size: 10px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--neutral-400);
    margin-bottom: 7px;
    font-weight: 600;
  }
  .rx-link {
    margin-top: 20px;
  }

  .rx-prov {
    display: flex;
    flex-wrap: wrap;
    margin-top: 16px;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background: var(--color-card);
    overflow: hidden;
  }
  .rx-prov span {
    flex: 1 1 0;
    min-width: 170px;
    text-align: center;
    font-size: 13px;
    color: var(--color-muted-foreground);
    padding: 17px 22px;
    border-right: 1px solid var(--color-border);
    line-height: 1.35;
  }
  .rx-prov span :global(b) {
    color: var(--color-foreground);
    font-weight: 600;
  }
  .rx-prov span:last-child {
    border-right: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .rx-bar,
    .rx-tab::after {
      transition: none;
    }
  }
  @media (max-width: 820px) {
    .research-head {
      grid-template-columns: 1fr;
      gap: 14px;
      align-items: start;
    }
    .research-head .right {
      justify-self: start;
    }
    .rx-tabs {
      grid-template-columns: 1fr 1fr;
    }
    .rx-tab:nth-child(2) {
      border-right: none;
    }
    .rx-body {
      grid-template-columns: 1fr;
    }
    .rx-narr {
      border-left: none;
      border-top: 1px solid var(--color-border);
    }
    .rx-prov span {
      flex-basis: 50%;
      border-bottom: 1px solid var(--color-border);
    }
    .rx-prov span:nth-child(2) {
      border-right: none;
    }
  }
</style>

<script>
  // Outcomes explorer: tab swaps the figure / bars / claim / source. Final state is
  // in markup (no-JS safe); JS resets to zero and grows on first scroll-in, and
  // re-animates on tab change. Reduced motion skips the count-up + grow.
  const root = document.querySelector<HTMLElement>('.rx');
  if (root) {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('.rx-tab'));
    const figEl = root.querySelector<HTMLElement>('[data-rx-fig]');
    const dirEl = root.querySelector<HTMLElement>('[data-rx-dir]');
    const claimEl = root.querySelector<HTMLElement>('[data-rx-claim]');
    const srcEl = root.querySelector<HTMLElement>('[data-rx-src]');
    const typBar = root.querySelector<HTMLElement>('[data-rx-typ]');
    const ieBar = root.querySelector<HTMLElement>('[data-rx-ie]');
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (figEl && dirEl && claimEl && srcEl && typBar && ieBar) {
      const typVal = typBar.querySelector<HTMLElement>('.rx-val');
      const ieVal = ieBar.querySelector<HTMLElement>('.rx-val');
      let rafId = 0;

      const countUp = (sign: string, target: number) => {
        if (rafId) cancelAnimationFrame(rafId);
        if (reduce) {
          figEl.textContent = sign + target;
          return;
        }
        let start = 0;
        const dur = 850;
        const step = (now: number) => {
          if (!start) start = now;
          const p = Math.min(1, (now - start) / dur);
          const e = 1 - Math.pow(1 - p, 3);
          figEl.textContent = sign + Math.round(target * e);
          if (p < 1) rafId = requestAnimationFrame(step);
        };
        rafId = requestAnimationFrame(step);
      };

      const render = (tab: HTMLButtonElement, animate: boolean) => {
        const d = tab.dataset;
        const sign = d.sign ?? '+';
        const fig = Number(d.fig ?? 0);
        const typ = Number(d.typ ?? 0);
        const ie = Number(d.ie ?? 0);
        tabs.forEach((t) => {
          const on = t === tab;
          t.classList.toggle('on', on);
          t.setAttribute('aria-selected', String(on));
        });
        dirEl.textContent = d.dir ?? '';
        claimEl.innerHTML = d.claim ?? '';
        srcEl.textContent = d.src ?? '';
        if (typVal) typVal.textContent = String(typ);
        if (ieVal) ieVal.textContent = String(ie);
        const max = Math.max(typ, ie) || 1;
        const th = `${(typ / max) * 100}%`;
        const ih = `${(ie / max) * 100}%`;
        if (animate && !reduce) {
          typBar.style.height = '0%';
          ieBar.style.height = '0%';
          requestAnimationFrame(() => {
            typBar.style.height = th;
            ieBar.style.height = ih;
          });
          countUp(sign, fig);
        } else {
          typBar.style.height = th;
          ieBar.style.height = ih;
          figEl.textContent = sign + fig;
        }
      };

      tabs.forEach((t) => t.addEventListener('click', () => render(t, true)));

      // Play the grow on first scroll-in (final state already in markup).
      if ('IntersectionObserver' in window && !reduce) {
        let played = false;
        typBar.style.height = '0%';
        ieBar.style.height = '0%';
        figEl.textContent = (tabs[0].dataset.sign ?? '+') + '0';
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting && !played) {
                played = true;
                render(tabs[0], true);
                io.disconnect();
              }
            });
          },
          { threshold: 0.35 },
        );
        io.observe(root);
        setTimeout(() => {
          if (!played) {
            played = true;
            render(tabs[0], true);
            io.disconnect();
          }
        }, 2600);
      }
    }
  }
</script>
