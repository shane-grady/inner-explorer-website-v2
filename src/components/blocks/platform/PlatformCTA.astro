---
import Button from '../../primitives/Button.astro';

// Closing CTA card: headline + two CTAs, then a tabbed strip of practice categories
// that swaps a feature trio. All panels render server-side (the first is shown), so
// it's meaningful with no JS; a tiny script toggles the active panel.

interface Feature {
  name: string;
  text: string;
}
interface Category {
  id: string;
  label: string;
  features: [Feature, Feature, Feature];
}
export interface PlatformCTAProps {
  headingHtml: string;
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
  categories: Category[];
}
type Props = PlatformCTAProps;
const { headingHtml, primaryCta, secondaryCta, categories }: Props = Astro.props;
---

<section class="cta">
  <div class="pwrap">
    <div class="cta-card">
      <div class="cta-top">
        <h2 set:html={headingHtml} />
        <div class="cta-actions">
          <Button href={secondaryCta.href} variant="outline" tone="neutral" shape="pill" size="sm">
            {secondaryCta.label}
          </Button>
          <Button href={primaryCta.href} tone="brand" shape="pill" size="sm"
            >{primaryCta.label}</Button
          >
        </div>
      </div>
      <div class="cta-show">
        <div class="cta-tabs" role="tablist" aria-label="Practice categories">
          {
            categories.map((c, i) => (
              <button
                class:list={['chip', { on: i === 0 }]}
                type="button"
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`cta-${c.id}`}
                data-cta-tab={c.id}
              >
                {c.label}
              </button>
            ))
          }
        </div>
        {
          categories.map((c, i) => (
            <div
              class:list={['cta-panel', { on: i === 0 }]}
              id={`cta-${c.id}`}
              role="tabpanel"
              aria-label={c.label}
              data-cta-panel={c.id}
            >
              {c.features.map((f) => (
                <div class="cta-feat">
                  <div class="nm">{f.name}</div>
                  <div class="tx">{f.text}</div>
                </div>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 30px 0 64px;
  }
  .pwrap {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
  }
  @media (min-width: 768px) {
    .pwrap {
      padding: 0 40px;
    }
  }
  .cta-card {
    border: 1px solid var(--color-border);
    border-radius: 24px;
    background: var(--color-card);
    overflow: hidden;
  }
  .cta-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 32px;
    gap: 20px;
    flex-wrap: wrap;
  }
  .cta-top h2 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(26px, 3vw, 40px);
    letter-spacing: -0.02em;
    font-weight: 500;
    color: var(--color-foreground);
  }
  .cta-top h2 :global(.em) {
    font-family: var(--font-display);
    font-style: italic;
  }
  .cta-actions {
    display: flex;
    gap: 10px;
  }
  .cta-show {
    border-top: 1px solid var(--color-border);
    padding: 24px 32px;
  }
  .cta-tabs {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 22px;
  }
  .chip {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--color-muted-foreground);
    padding: 8px 15px;
    border-radius: 999px;
    border: 1px solid transparent;
    background: transparent;
    cursor: pointer;
    transition: all 0.2s var(--ease-out);
  }
  .chip:hover {
    background: color-mix(in oklab, var(--color-foreground) 5%, transparent);
    color: var(--color-foreground);
  }
  .chip.on {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }
  .chip.on:hover {
    background: var(--color-foreground);
  }
  .cta-panel {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .cta-panel:not(.on) {
    display: none;
  }
  .cta-feat {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .cta-feat .nm {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-foreground);
  }
  .cta-feat .tx {
    font-size: 13.5px;
    color: var(--color-muted-foreground);
    line-height: 1.5;
  }
  @media (max-width: 820px) {
    .cta-panel {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // CTA category strip: show the chosen practice-category panel. The first is `.on`
  // in markup, so the panel is populated with no JS.
  const tabs = document.querySelector<HTMLElement>('.cta .cta-tabs');
  if (tabs) {
    const chips = Array.from(tabs.querySelectorAll<HTMLButtonElement>('.chip'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('.cta [data-cta-panel]'));
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const id = chip.getAttribute('data-cta-tab');
        chips.forEach((c) => {
          const on = c === chip;
          c.classList.toggle('on', on);
          c.setAttribute('aria-selected', String(on));
        });
        panels.forEach((p) => p.classList.toggle('on', p.getAttribute('data-cta-panel') === id));
      });
    });
  }
</script>
