---
// High-conviction closing testimonial row: brand "duet" headline (sans + serif
// italic) + supporting paragraph + optional CTA pair, with 3 quote cards below.
//
// Distinct from `Testimonials.astro` (which renders from the content collection
// with a simple sans heading). Use this when the page wants a strong editorial
// closer with inline quotes.

export interface Quote {
  /** Star rating (1–5). Pass 5 for the standard 5-star display. */
  stars?: number;
  body: string;
  who: string;
  where?: string;
}

interface QuoteCta {
  label: string;
  href: string;
  /** `primary` is the brand-green solid; `ghost` is the subtle outline. */
  variant?: 'primary' | 'ghost';
}

interface Props {
  /** Sans portion of the headline (e.g. "Days are"). */
  lead: string;
  /** Serif-italic portion (e.g. "long.") — sits inline after the lead. */
  leadDisplay: string;
  /** Supporting paragraph under the headline. */
  leadSub?: string;
  /** 0–2 CTAs that sit between headline and quotes. */
  ctas?: QuoteCta[];
  quotes: Quote[];
}

const { lead, leadDisplay, leadSub, ctas = [], quotes }: Props = Astro.props;
---

<section class="qrow" aria-label="What educators say">
  <div class="qrow-head">
    <p class="lead">
      <span class="lead-sans">{lead}</span>
      <span class="lead-serif"> {leadDisplay}</span>
    </p>
    {leadSub && <p class="lead-sub">{leadSub}</p>}
    {
      ctas.length > 0 && (
        <div class="ctas">
          {ctas.map((c) => (
            <a
              href={c.href}
              class:list={['btn', c.variant === 'ghost' ? 'btn-ghost' : 'btn-primary']}
            >
              {c.label}
            </a>
          ))}
        </div>
      )
    }
  </div>

  <div class="quotes">
    {
      quotes.map((q) => (
        <article class="card">
          {q.stars && q.stars > 0 && (
            <div class="stars" aria-label={`${q.stars} out of 5 stars`}>
              {Array.from({ length: q.stars }).map(() => (
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <polygon points="12 2 15 9 22 9 16 13 18 20 12 16 6 20 8 13 2 9 9 9" />
                </svg>
              ))}
            </div>
          )}
          <p class="body">{q.body}</p>
          <div class="who">{q.who}</div>
          {q.where && <div class="where">{q.where}</div>}
        </article>
      ))
    }
  </div>
</section>

<style>
  .qrow {
    padding: var(--spacing-section-lg) 32px;
    background: linear-gradient(
      180deg,
      color-mix(in oklab, var(--color-muted) 60%, var(--color-background)) 0%,
      color-mix(in oklab, var(--color-muted) 100%, transparent) 100%
    );
    text-align: center;
  }

  .qrow-head {
    max-width: 720px;
    margin: 0 auto 56px;
  }

  .lead {
    margin: 0 0 6px;
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-foreground);
    text-wrap: balance;
  }
  .lead-sans {
    font-family: var(--font-sans);
    font-weight: 400;
  }
  .lead-serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
  }

  .lead-sub {
    margin: 0 auto 36px;
    max-width: 540px;
    font-size: 17px;
    line-height: 1.55;
    color: var(--color-muted-foreground);
  }

  .ctas {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 42px;
    padding: 0 22px;
    border-radius: 9999px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    border: 1px solid transparent;
    transition:
      transform var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }
  .btn-primary {
    background: var(--color-brand);
    color: var(--color-brand-foreground);
    box-shadow:
      inset 0 1px 0 color-mix(in oklab, var(--color-white) 18%, transparent),
      0 4px 12px color-mix(in oklab, var(--color-brand) 22%, transparent);
  }
  .btn-primary:hover {
    transform: translateY(-1px);
    background: var(--color-brand-emphasis);
  }
  .btn-ghost {
    background: transparent;
    color: var(--color-foreground);
    border-color: var(--color-border);
  }
  .btn-ghost:hover {
    background: var(--color-muted);
  }

  .quotes {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    text-align: left;
  }

  .card {
    padding: 28px;
    background: var(--color-card);
    color: var(--color-card-foreground);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-sm);
  }

  .stars {
    display: flex;
    gap: 2px;
    margin-bottom: 14px;
    color: var(--color-brand);
  }
  .stars :global(svg) {
    width: 16px;
    height: 16px;
  }

  .body {
    margin: 0 0 18px;
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-foreground);
  }
  .who {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 13px;
    line-height: 1.3;
    color: var(--color-foreground);
  }
  .where {
    font-size: 13px;
    line-height: 1.3;
    color: var(--color-muted-foreground);
  }

  @media (max-width: 820px) {
    .quotes {
      grid-template-columns: 1fr;
    }
  }
</style>
