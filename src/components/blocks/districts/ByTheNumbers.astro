---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Part Two — "By the Numbers." Dark editorial centerfold: 3-col asymmetric grid
// (big primary number, anchor photograph, stacked secondary numbers), then a
// 3-column citation row beneath a hairline.

interface PrimaryStat {
  label: string;
  value: string; // e.g. "11"
  unit?: string; // e.g. "pts"
  caption: string;
  source: string;
}
interface SmallStat {
  label: string;
  value: string;
  unit?: string;
  caption: string;
  source: string;
}
interface Citation {
  label: string;
  emphasis: string;
  body: string;
  cite: string;
}
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  primary: PrimaryStat;
  small: SmallStat[];
  image: ImageMetadata;
  imageAlt: string;
  imageCaption: string;
  citations: Citation[];
}
const { eyebrow, title, intro, primary, small, image, imageAlt, imageCaption, citations }: Props =
  Astro.props;
---

<section class="btn" id="outcomes" aria-label="By the numbers">
  <div class="btn-glow-a" aria-hidden="true"></div>
  <div class="btn-glow-b" aria-hidden="true"></div>

  <div class="btn-inner">
    <div class="btn-head">
      <div>
        <div class="eyebrow">{eyebrow}</div>
        <h2 class="head-h">{title}</h2>
      </div>
      <p class="head-p">{intro}</p>
    </div>

    <div class="btn-spread">
      <div class="primary-col">
        <div class="lbl">{primary.label}</div>
        <div class="primary-num" data-value={primary.value}>
          {primary.value}
          {primary.unit && <span class="unit">{primary.unit}</span>}
        </div>
        <div class="primary-caption">{primary.caption}</div>
        <div class="primary-cite">{primary.source}</div>
      </div>

      <div class="photo-col">
        <div class="frame">
          <Image
            src={image}
            alt={imageAlt}
            widths={[480, 900, 1400]}
            sizes="(max-width: 920px) 100vw, 30vw"
            loading="lazy"
          />
          <div class="cap">{imageCaption}</div>
        </div>
      </div>

      <div class="small-col">
        {
          small.map((s) => (
            <div class="small-item">
              <div class="lbl">{s.label}</div>
              <div class="small-num" data-value={s.value}>
                {s.value}
                {s.unit && <span class="unit">{s.unit}</span>}
              </div>
              <div class="small-caption">{s.caption}</div>
              <div class="small-cite">{s.source}</div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="btn-cites">
      {
        citations.map((c) => (
          <div class="cite-cell">
            <div class="lbl">{c.label}</div>
            <p class="cite-body">
              <em>{c.emphasis}</em> <span>{c.body}</span>
            </p>
            <div class="cite-source">{c.cite}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .btn {
    background: var(--neutral-950);
    color: var(--color-white);
    padding: 140px 0;
    position: relative;
    overflow: hidden;
  }
  .btn-glow-a {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 60% at 25% 30%,
      color-mix(in oklab, var(--brand-600) 22%, transparent),
      transparent 65%
    );
    pointer-events: none;
  }
  .btn-glow-b {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 50% 40% at 85% 80%,
      color-mix(in oklab, var(--brand-500) 18%, transparent),
      transparent 65%
    );
    pointer-events: none;
  }
  .btn-inner {
    position: relative;
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .btn-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: end;
    margin-bottom: 96px;
  }
  .eyebrow {
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-white) 70%, transparent);
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: currentColor;
    opacity: 0.55;
  }
  .head-h {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(48px, 6.5vw, 92px);
    line-height: 0.98;
    letter-spacing: -0.022em;
    margin: 28px 0 0;
    text-wrap: balance;
  }
  .head-p {
    font-size: 18px;
    line-height: 1.65;
    color: color-mix(in oklab, var(--color-white) 72%, transparent);
    max-width: 480px;
    justify-self: end;
    margin: 0;
  }

  .btn-spread {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1.2fr;
    gap: 48px;
    margin-bottom: 96px;
  }
  .primary-col {
    border-top: 1px solid color-mix(in oklab, var(--color-white) 16%, transparent);
    padding-top: 28px;
  }
  .lbl {
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-white) 60%, transparent);
  }
  .primary-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(120px, 18vw, 208px);
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--color-white);
    margin-top: 8px;
    font-variant-numeric: tabular-nums;
  }
  .primary-num .unit {
    font-size: 0.42em;
    margin-left: 8px;
  }
  .primary-caption {
    margin-top: 12px;
    font-size: 17px;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-white);
    max-width: 320px;
  }
  .primary-cite {
    margin-top: 14px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    line-height: 1.45;
    color: color-mix(in oklab, var(--color-white) 50%, transparent);
  }

  .photo-col .frame {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-sm);
    align-self: stretch;
    min-height: 360px;
    background: var(--neutral-800);
  }
  .photo-col .frame :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .photo-col .cap {
    position: absolute;
    bottom: 14px;
    left: 14px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 11.5px;
    line-height: 1.3;
    color: var(--color-white);
    background: color-mix(in oklab, var(--neutral-950) 50%, transparent);
    padding: 6px 10px;
    border-radius: 4px;
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }

  .small-col {
    display: grid;
    gap: 36px;
    align-content: start;
  }
  .small-item {
    border-top: 1px solid color-mix(in oklab, var(--color-white) 16%, transparent);
    padding-top: 24px;
  }
  .small-num {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(64px, 7vw, 88px);
    line-height: 0.9;
    letter-spacing: -0.045em;
    color: var(--color-white);
    margin-top: 6px;
    font-variant-numeric: tabular-nums;
  }
  .small-num .unit {
    margin-left: 4px;
  }
  .small-caption {
    margin-top: 10px;
    font-size: 14.5px;
    font-weight: 500;
    line-height: 1.45;
    color: color-mix(in oklab, var(--color-white) 92%, transparent);
  }
  .small-cite {
    margin-top: 8px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    line-height: 1.45;
    color: color-mix(in oklab, var(--color-white) 50%, transparent);
  }

  .btn-cites {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid color-mix(in oklab, var(--color-white) 16%, transparent);
    padding-top: 32px;
  }
  .cite-cell {
    padding: 0 32px;
  }
  .cite-cell + .cite-cell {
    border-left: 1px solid color-mix(in oklab, var(--color-white) 16%, transparent);
  }
  .cite-body {
    margin: 16px 0 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-white);
  }
  .cite-body em {
    font-style: italic;
  }
  .cite-body span {
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 400;
    font-size: 0.7em;
    line-height: 1.4;
    color: color-mix(in oklab, var(--color-white) 88%, transparent);
  }
  .cite-source {
    margin-top: 16px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    line-height: 1.45;
    color: color-mix(in oklab, var(--color-white) 50%, transparent);
  }

  @media (max-width: 920px) {
    .btn-head {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .head-p {
      justify-self: start;
    }
    .btn-spread {
      grid-template-columns: 1fr;
      gap: 64px;
    }
    .btn-cites {
      grid-template-columns: 1fr;
    }
    .cite-cell {
      padding: 24px 0;
    }
    .cite-cell + .cite-cell {
      border-left: 0;
      border-top: 1px solid color-mix(in oklab, var(--color-white) 16%, transparent);
    }
  }
</style>

<script>
  // Count-up shared logic — runs on primary + small numbers.
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const cells = document.querySelectorAll<HTMLElement>('.btn [data-value]');
  if (cells.length && !reduce) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const raw = el.dataset.value ?? '';
          const m = raw.match(/([\d.,]+)(.*)$/);
          if (!m) return;
          const target = parseFloat(m[1].replace(/,/g, ''));
          // Preserve the existing unit span markup; restore on finish.
          const html = el.innerHTML;
          const start = performance.now();
          const dur = 1400;
          const tick = (t: number) => {
            const p = Math.min(1, (t - start) / dur);
            const eased = 1 - Math.pow(1 - p, 3);
            const v = target * eased;
            const decimals = (m[1].split('.')[1] || '').length;
            const shown =
              decimals > 0 ? v.toFixed(decimals) : Math.round(v).toLocaleString('en-US');
            // Re-render: replace the leading text before any nested element.
            if (el.firstChild) el.firstChild.nodeValue = shown;
            if (p < 1) requestAnimationFrame(tick);
            else el.innerHTML = html;
          };
          requestAnimationFrame(tick);
          io.unobserve(el);
        });
      },
      { threshold: 0.4 },
    );
    cells.forEach((c) => io.observe(c));
  }
</script>
