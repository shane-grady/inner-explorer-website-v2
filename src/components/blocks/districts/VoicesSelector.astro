---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Part Four — District Voices. Large 4:5 active portrait + quote/attribution +
// three-item selector list. Vanilla script swaps active state.

interface Voice {
  quote: string;
  who: string;
  role: string;
  photo: ImageMetadata;
  photoAlt: string;
}
interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  voices: Voice[];
}
const { eyebrow, title, intro, voices }: Props = Astro.props;
---

<section class="vs" id="voices" aria-label="District voices" data-voices>
  <div class="vs-inner">
    <div class="vs-head">
      <div>
        <div class="eyebrow">{eyebrow}</div>
        <h2 class="head-h">{title}</h2>
      </div>
      <p class="head-p">{intro}</p>
    </div>

    <div class="vs-body">
      <div class="vs-photo">
        {
          voices.map((v, i) => (
            <div class:list={['frame', { on: i === 0 }]} data-i={i}>
              <Image
                src={v.photo}
                alt={v.photoAlt}
                widths={[480, 900, 1200]}
                sizes="(max-width: 920px) 100vw, 40vw"
                loading="lazy"
              />
              <div class="cap">
                {v.who} · {v.role.split(',').pop()?.trim()}
              </div>
            </div>
          ))
        }
      </div>

      <div class="vs-detail">
        <svg
          width="56"
          height="56"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          class="quote-mark"
        >
          <path
            d="M9.5 6C6.5 6 4 8.5 4 11.5c0 2 1 4 3 5 .5.3 1 .8 1 1.5 0 1-1 2-2 2v2c3.5 0 6-2.5 6-6V11.5C12 8.5 12.5 6 9.5 6zM19.5 6C16.5 6 14 8.5 14 11.5c0 2 1 4 3 5 .5.3 1 .8 1 1.5 0 1-1 2-2 2v2c3.5 0 6-2.5 6-6V11.5C22 8.5 22.5 6 19.5 6z"
          ></path>
        </svg>

        <div class="quote-track">
          {
            voices.map((v, i) => (
              <div class:list={['slide', { on: i === 0 }]} data-i={i}>
                <blockquote class="quote">{v.quote}</blockquote>
                <div class="attribution">
                  <span class="rule" />
                  <div>
                    <div class="who">{v.who}</div>
                    <div class="role">{v.role}</div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <div class="selector">
          <div class="sel-eyebrow">More voices</div>
          <div class="sel-list" role="tablist">
            {
              voices.map((v, i) => (
                <button
                  type="button"
                  class:list={['sel-item', { on: i === 0 }]}
                  data-i={i}
                  role="tab"
                  aria-selected={i === 0}
                >
                  <span class="sel-num">0{i + 1}</span>
                  <span class="sel-text">
                    <span class="sel-who">{v.who}</span>
                    <span class="sel-org">{v.role.split(',').slice(-1)[0].trim()}</span>
                  </span>
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="sel-arrow"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </button>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .vs {
    background: var(--color-muted);
    color: var(--color-foreground);
    padding: 120px 0;
  }
  .vs-inner {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .vs-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: end;
    margin-bottom: 72px;
  }
  .eyebrow {
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: currentColor;
    opacity: 0.55;
  }
  .head-h {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(44px, 6vw, 88px);
    line-height: 0.98;
    letter-spacing: -0.022em;
    color: var(--color-foreground);
    margin: 28px 0 0;
    text-wrap: balance;
  }
  .head-p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--color-muted-foreground);
    max-width: 360px;
    justify-self: end;
    margin: 0;
  }

  .vs-body {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 64px;
    align-items: stretch;
  }

  .vs-photo {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-card);
  }
  .vs-photo .frame {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 500ms var(--ease-out);
  }
  .vs-photo .frame.on {
    opacity: 1;
  }
  .vs-photo .frame :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .vs-photo .cap {
    position: absolute;
    bottom: 14px;
    left: 14px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 11.5px;
    color: var(--color-white);
    background: color-mix(in oklab, var(--neutral-950) 50%, transparent);
    padding: 6px 10px;
    border-radius: 4px;
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }

  .vs-detail {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .quote-mark {
    color: var(--color-brand);
    opacity: 0.18;
  }
  .quote-track {
    position: relative;
    margin-top: 24px;
    min-height: 200px;
  }
  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 500ms var(--ease-out),
      transform 500ms var(--ease-out);
    pointer-events: none;
  }
  .slide.on {
    position: relative;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .quote {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(28px, 3.4vw, 38px);
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
    margin: 0;
  }
  .attribution {
    margin-top: 36px;
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .attribution .rule {
    width: 36px;
    height: 1px;
    background: var(--color-muted-foreground);
    opacity: 0.55;
  }
  .who {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-foreground);
  }
  .role {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-muted-foreground);
    margin-top: 6px;
  }

  .selector {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }
  .sel-eyebrow {
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
    margin-bottom: 18px;
  }
  .sel-list {
    display: grid;
    gap: 4px;
  }
  .sel-item {
    display: grid;
    grid-template-columns: 44px 1fr auto;
    gap: 18px;
    align-items: center;
    padding: 14px 16px;
    border-radius: var(--radius-sm);
    border: 0;
    background: transparent;
    text-align: left;
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .sel-item:hover {
    background: color-mix(in oklab, var(--color-brand) 6%, transparent);
  }
  .sel-item.on {
    background: color-mix(in oklab, var(--color-brand) 8%, transparent);
  }
  .sel-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    line-height: 1;
    color: color-mix(in oklab, var(--color-foreground) 35%, transparent);
  }
  .sel-item.on .sel-num,
  .sel-item.on .sel-arrow {
    color: var(--color-brand);
  }
  .sel-text {
    display: flex;
    flex-direction: column;
  }
  .sel-who {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-foreground);
  }
  .sel-org {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-muted-foreground);
    margin-top: 2px;
  }
  .sel-arrow {
    color: color-mix(in oklab, var(--color-foreground) 30%, transparent);
  }

  @media (max-width: 920px) {
    .vs-head {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .head-p {
      justify-self: start;
    }
    .vs-body {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-voices]');
  if (root) {
    const frames = Array.from(root.querySelectorAll<HTMLElement>('.vs-photo .frame'));
    const slides = Array.from(root.querySelectorAll<HTMLElement>('.quote-track .slide'));
    const buttons = Array.from(root.querySelectorAll<HTMLButtonElement>('.sel-item'));
    const select = (i: number) => {
      frames.forEach((el, idx) => el.classList.toggle('on', idx === i));
      slides.forEach((el, idx) => el.classList.toggle('on', idx === i));
      buttons.forEach((el, idx) => {
        el.classList.toggle('on', idx === i);
        el.setAttribute('aria-selected', idx === i ? 'true' : 'false');
      });
    };
    buttons.forEach((btn, idx) => btn.addEventListener('click', () => select(idx)));
  }
</script>
