---
import ROICalculator from './ROICalculator.astro';

// Funding guide — four federal/state pathway cards + the ROI calculator below.

interface Funding {
  id: string;
  name: string;
  fullName: string;
  blurb: string;
  coverage: number; // 0..1
}
interface Props {
  eyebrow: string;
  titleHtml: string;
  intro: string;
  funding: Funding[];
}
const { eyebrow, titleHtml, intro, funding }: Props = Astro.props;
---

<section class="fg" id="funding" aria-label="Funding guide">
  <div class="fg-inner">
    <div class="fg-head">
      <div class="eyebrow">{eyebrow}</div>
      <h2 class="head-h" set:html={titleHtml} />
      <p class="head-p">{intro}</p>
    </div>

    <div class="fg-grid">
      {
        funding.map((f) => (
          <div class="fg-card">
            <div class="fg-top">
              <span class="chip" aria-hidden="true">
                <svg
                  viewBox="0 0 24 24"
                  width="18"
                  height="18"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="8" cy="8" r="6" />
                  <path d="M18.09 10.37A6 6 0 1 1 10.34 18" />
                </svg>
              </span>
              <span class="pct">{Math.round(f.coverage * 100)}%</span>
            </div>
            <div class="name">{f.name}</div>
            <div class="sub">{f.fullName}</div>
            <p class="blurb">{f.blurb}</p>
          </div>
        ))
      }
    </div>

    <ROICalculator funding={funding} />
  </div>
</section>

<style>
  .fg {
    background: var(--color-muted);
    padding: 120px 0;
  }
  .fg-inner {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .fg-head {
    max-width: 720px;
    margin-bottom: 56px;
  }
  .eyebrow {
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: currentColor;
    opacity: 0.55;
  }
  .head-h {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.022em;
    color: var(--color-foreground);
    margin: 16px 0 0;
    text-wrap: balance;
  }
  .head-h :global(em) {
    color: var(--color-brand);
  }
  .head-p {
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-muted-foreground);
    margin: 12px 0 0;
    max-width: 640px;
  }

  .fg-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }
  .fg-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 24px;
  }
  .fg-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }
  .chip {
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--color-brand) 12%, transparent);
    color: var(--color-brand);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .pct {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-brand);
  }
  .name {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-foreground);
  }
  .sub {
    margin-top: 4px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-muted-foreground);
  }
  .blurb {
    margin: 12px 0 0;
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--color-muted-foreground);
  }

  @media (max-width: 920px) {
    .fg-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .fg-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
