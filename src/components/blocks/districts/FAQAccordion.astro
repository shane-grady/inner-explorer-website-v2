---
// Frequently asked questions. Two-column: heading copy + accordion. Built on
// native <details>/<summary> so the accordion still works without JS.

interface QA {
  q: string;
  a: string;
}
interface Props {
  eyebrow: string;
  titleHtml: string;
  intro: string;
  items: QA[];
}
const { eyebrow, titleHtml, intro, items }: Props = Astro.props;
---

<section class="faq" id="faq" aria-label="Frequently asked questions">
  <div class="faq-inner">
    <div class="faq-grid">
      <div>
        <div class="eyebrow">{eyebrow}</div>
        <h2 class="head-h" set:html={titleHtml} />
        <p class="head-p">{intro}</p>
      </div>
      <div>
        {
          items.map((it, i) => (
            <details class="qa" open={i === 0}>
              <summary>
                <span class="q">{it.q}</span>
                <span class="ico" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    width="14"
                    height="14"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                  >
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                  </svg>
                </span>
              </summary>
              <p class="a">{it.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .faq {
    background: var(--color-background);
    padding: 120px 0;
  }
  .faq-inner {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
  }
  .eyebrow {
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: currentColor;
    opacity: 0.55;
  }
  .head-h {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(36px, 4.4vw, 56px);
    line-height: 1.05;
    margin: 16px 0 0;
    color: var(--color-foreground);
  }
  .head-h :global(em) {
    color: var(--color-brand);
  }
  .head-p {
    margin: 20px 0 0;
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-muted-foreground);
    max-width: 420px;
  }

  details {
    border-bottom: 1px solid var(--color-border);
  }
  summary {
    list-style: none;
    cursor: pointer;
    padding: 24px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    text-align: left;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  .q {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 19px;
    line-height: 1.4;
    color: var(--color-foreground);
  }
  .ico {
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    color: var(--color-brand);
    display: grid;
    place-items: center;
    transition: transform var(--dur) var(--ease-out);
    flex-shrink: 0;
  }
  details[open] .ico {
    transform: rotate(45deg);
  }
  .a {
    margin: 0 0 24px;
    padding-right: 56px;
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-muted-foreground);
    max-width: 620px;
  }

  @media (max-width: 920px) {
    .faq-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
