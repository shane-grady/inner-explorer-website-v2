---
import StoryCover from './StoryCover.astro';
import type { Story } from './types';

// One editorial newsroom card: generative/photo cover on top, then an editorial
// category label · hairline · date, a balanced title, a two-line excerpt, and a
// footer (read time + animated "Read →"). The whole card is one accessible link.

interface Props {
  story: Story;
}
const { story }: Props = Astro.props;
const { cat, catLabel, title, excerpt, date, read, href = '#', cover } = story;

const dateLabel = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(new Date(`${date}T00:00:00`));

const tagTone = cat === 'research' ? 'forest' : cat === 'press' ? 'press' : 'brand';
---

<article class="card" data-cat={cat} data-date={date} data-pop={story.pop}>
  <a class="link" href={href} aria-label={title}></a>

  <StoryCover cover={cover} />

  <div class="body">
    <div class="meta">
      <span class:list={['tag', tagTone]}>{catLabel}</span>
      <span class="divider" aria-hidden="true"></span>
      <span class="date">{dateLabel}</span>
    </div>
    <h2 class="title">{title}</h2>
    <p class="excerpt">{excerpt}</p>
    <div class="foot">
      <span class="read">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="9"></circle>
          <path d="M12 7v5l3 2"></path>
        </svg>
        {read} min read
      </span>
      <span class="cta">
        Read
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </span>
    </div>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    isolation: isolate;
    transition:
      transform 0.34s var(--ease-out),
      box-shadow 0.34s var(--ease-out),
      border-color 0.34s var(--ease-out);
  }
  .card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in oklab, var(--color-brand) 45%, var(--color-border));
  }
  /* Whole-card link sits on top and catches clicks; it's the focusable element
     (global :focus-visible ring outlines the card). */
  .link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  /* Cover photo zoom on card hover (the image lives in StoryCover). */
  .card:hover :global(.cover-img) {
    transform: scale(1.06);
  }

  .body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 10px;
    padding: 18px 20px;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 11px;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.085em;
    white-space: nowrap;
    color: var(--color-brand-emphasis);
  }
  .tag.forest {
    color: var(--brand-900);
  }
  .tag.press {
    color: var(--color-muted-foreground);
  }
  .divider {
    width: 1px;
    height: 11px;
    background: var(--color-border);
    flex: none;
  }
  .date {
    font-size: 11px;
    font-weight: 600;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted-foreground);
  }
  .title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.011em;
    color: var(--color-foreground);
    text-wrap: balance;
    /* Block clamp (not -webkit-box) so text-wrap: balance still applies. */
    overflow: hidden;
    max-height: calc(1.3em * 3);
    transition: color 0.2s var(--ease-out);
  }
  .card:hover .title {
    color: var(--color-brand);
  }
  .excerpt {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-muted-foreground);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .foot {
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .read {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-muted-foreground);
  }
  .cta {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-brand);
  }
  .cta svg {
    transition: transform 0.25s var(--ease-out);
  }
  .card:hover .cta svg {
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .card:hover,
    .cta svg,
    .card:hover :global(.cover-img) {
      transition: none;
      transform: none;
    }
  }
</style>
