---
import { Image } from 'astro:assets';
import mark from '../../../assets/brand/inner-explorer-mark.png';
import type { Cover } from './types';

// Generative, on-brand cover art for newsroom story cards. Photos use warm
// classroom imagery; the abstract covers are built entirely from the Inner
// Explorer green family, glass surfaces, and the compass mark — no SVG
// illustration. Every colour comes from a brand token; geometry is plain CSS.

interface Props {
  cover: Cover;
}
const { cover }: Props = Astro.props;
const deep = 'tone' in cover && cover.tone === 'b';
---

{
  cover.kind === 'photo' && (
    <div class="cover">
      <Image
        class="cover-img"
        src={cover.photo}
        alt=""
        widths={[300, 460, 640]}
        sizes="(max-width: 680px) 100vw, (max-width: 1120px) 50vw, 25vw"
        loading="lazy"
      />
      <div class="veil" aria-hidden="true" />
    </div>
  )
}

{
  cover.kind === 'mesh' && (
    <div class={`cover mesh-${cover.tone ?? 'a'}`}>
      <div class="motif" aria-hidden="true">
        <span class="gm gm1" />
        <span class="gm gm2" />
        <span class="gm gm3" />
      </div>
      <Image class="watermark" src={mark} alt="" width={165} height={165} aria-hidden="true" />
      {cover.eyebrow && <span class="eyebrow light">{cover.eyebrow}</span>}
    </div>
  )
}

{
  cover.kind === 'compass' && (
    <div class="cover deep-a">
      <span class="rings" aria-hidden="true" />
      <Image class="compass" src={mark} alt="" width={118} height={118} aria-hidden="true" />
      {cover.eyebrow && <span class="eyebrow ondark">{cover.eyebrow}</span>}
    </div>
  )
}

{
  cover.kind === 'quote' && (
    <div class={deep ? 'cover deep-b' : 'cover mesh-a'}>
      {!deep && <span class="rings soft" aria-hidden="true" />}
      <span class:list={['quote-mark', { ondark: deep }]} aria-hidden="true">
        &ldquo;
      </span>
      <p class:list={['quote', { ondark: deep }]}>{cover.quote}</p>
    </div>
  )
}

{
  cover.kind === 'stat' && (
    <div class={deep ? 'cover deep-b' : 'cover mesh-b'}>
      <span class="rings soft" aria-hidden="true" />
      <div class="stat">
        <span class:list={['stat-value', { ondark: deep }]}>{cover.value}</span>
        <span class:list={['stat-unit', { ondark: deep }]}>{cover.unit}</span>
      </div>
    </div>
  )
}

{
  cover.kind === 'report' && (
    <div class="cover deep-b">
      <div class="report">
        <span class="rep-eyebrow">Inner Explorer</span>
        <span class="rep-label">{cover.label}</span>
        <span class="rep-year">{cover.year}</span>
      </div>
      <Image class="mark-sm" src={mark} alt="" width={32} height={32} aria-hidden="true" />
    </div>
  )
}

{
  cover.kind === 'award' && (
    <div class="cover award-bg">
      <div class="confetti" aria-hidden="true">
        <span class="cf c1" />
        <span class="cf c2" />
        <span class="cf c3" />
        <span class="cf c4" />
        <span class="cf c5" />
        <span class="cf c6" />
      </div>
      <div class="award">
        <span class="aw-year">{cover.year}</span>
        <span class="aw-title">
          Mindful Schools
          <br />
          Awards
        </span>
      </div>
    </div>
  )
}

<style>
  .cover {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-100);
  }

  /* ---- Backgrounds (mesh / deep / award) — brand-palette gradients ---- */
  .mesh-a {
    background: radial-gradient(
      120% 120% at 12% 8%,
      var(--brand-100) 0%,
      var(--brand-200) 34%,
      var(--brand-400) 78%,
      var(--brand-600) 100%
    );
  }
  .mesh-b {
    background: radial-gradient(
      120% 120% at 85% 12%,
      var(--brand-200) 0%,
      var(--brand-300) 30%,
      var(--brand-500) 72%,
      var(--brand-800) 100%
    );
  }
  .mesh-c {
    background: radial-gradient(
      120% 120% at 20% 90%,
      var(--brand-100) 0%,
      var(--brand-200) 40%,
      var(--brand-300) 80%,
      var(--brand-500) 100%
    );
  }
  .deep-a {
    background: linear-gradient(
      150deg,
      var(--brand-600) 0%,
      var(--brand-800) 55%,
      var(--brand-900) 100%
    );
  }
  .deep-b {
    background: linear-gradient(
      150deg,
      var(--brand-700) 0%,
      var(--brand-900) 70%,
      var(--brand-950) 100%
    );
  }
  .award-bg {
    background: radial-gradient(
      130% 120% at 30% 20%,
      var(--brand-100) 0%,
      var(--brand-200) 55%,
      var(--brand-300) 100%
    );
  }

  /* ---- Photo ---- */
  .cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out);
  }
  .veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      color-mix(in oklab, var(--brand-900) 22%, transparent),
      transparent 52%
    );
  }

  /* ---- Eyebrow pill ---- */
  .eyebrow {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 3;
    padding: 6px 12px;
    border-radius: 9999px;
    font-size: 11px;
    font-weight: 600;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
  }
  .eyebrow.light {
    background: color-mix(in oklab, var(--color-white) 82%, transparent);
    color: var(--brand-800);
    border: 1px solid color-mix(in oklab, var(--color-white) 70%, transparent);
  }
  .eyebrow.ondark {
    background: color-mix(in oklab, var(--color-white) 18%, transparent);
    color: var(--color-white);
    border: 1px solid color-mix(in oklab, var(--color-white) 32%, transparent);
  }

  /* ---- Glass mini-card motif (mesh) ---- */
  .motif {
    position: absolute;
    inset: 0;
  }
  .gm {
    position: absolute;
    background: color-mix(in oklab, var(--color-white) 62%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-white) 70%, transparent);
    border-radius: 9px;
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    box-shadow: 0 6px 16px color-mix(in oklab, var(--brand-900) 16%, transparent);
  }
  .gm::before {
    content: '';
    position: absolute;
    top: 9px;
    left: 9px;
    width: 40%;
    height: 6px;
    border-radius: 4px;
    background: var(--brand-500);
  }
  .gm::after {
    content: '';
    position: absolute;
    top: 23px;
    left: 9px;
    right: 9px;
    height: 5px;
    border-radius: 3px;
    background: color-mix(in oklab, var(--neutral-600) 18%, transparent);
    box-shadow: 0 11px 0 color-mix(in oklab, var(--neutral-600) 13%, transparent);
  }
  .gm1 {
    left: 9%;
    top: 30%;
    width: 46%;
    height: 42%;
  }
  .gm2 {
    right: 8%;
    top: 16%;
    width: 30%;
    height: 30%;
  }
  .gm3 {
    left: 30%;
    bottom: 11%;
    width: 36%;
    height: 26%;
    z-index: 2;
  }
  .watermark {
    position: absolute;
    right: -22px;
    bottom: -26px;
    width: 165px;
    height: 165px;
    object-fit: contain;
    opacity: 0.4;
    transform: rotate(-8deg);
  }

  /* ---- Compass ---- */
  .rings {
    position: absolute;
    width: 72%;
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1.5px solid color-mix(in oklab, var(--color-white) 18%, transparent);
    right: -10%;
    top: -20%;
  }
  .rings::after {
    content: '';
    position: absolute;
    inset: 14%;
    border-radius: 50%;
    border: 1.5px solid color-mix(in oklab, var(--color-white) 14%, transparent);
  }
  .rings.soft {
    border-color: color-mix(in oklab, var(--color-white) 55%, transparent);
  }
  .rings.soft::after {
    border-color: color-mix(in oklab, var(--color-white) 40%, transparent);
  }
  .compass {
    position: relative;
    z-index: 2;
    width: 42%;
    max-width: 118px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 8px 20px color-mix(in oklab, var(--color-black) 25%, transparent));
  }

  /* ---- Quote ---- */
  .quote-mark {
    position: absolute;
    top: -6px;
    left: 16px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 120px;
    line-height: 1;
    color: color-mix(in oklab, var(--brand-700) 28%, transparent);
  }
  .quote-mark.ondark {
    color: color-mix(in oklab, var(--color-white) 22%, transparent);
  }
  .quote {
    position: relative;
    z-index: 2;
    margin: 0;
    padding: 0 26px;
    text-align: center;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(20px, 3.1vw, 26px);
    line-height: 1.18;
    color: var(--brand-900);
    text-wrap: balance;
  }
  .quote.ondark {
    color: var(--color-white);
  }

  /* ---- Stat ---- */
  .stat {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .stat-value {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(46px, 7.5vw, 70px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--brand-900);
  }
  .stat-value.ondark {
    color: var(--color-white);
  }
  .stat-unit {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: color-mix(in oklab, var(--brand-800) 85%, transparent);
  }
  .stat-unit.ondark {
    color: color-mix(in oklab, var(--color-white) 85%, transparent);
  }

  /* ---- Report ---- */
  .report {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 22px 30px;
    border: 1px solid color-mix(in oklab, var(--color-white) 28%, transparent);
    border-radius: 14px;
  }
  .rep-eyebrow {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: color-mix(in oklab, var(--color-white) 72%, transparent);
  }
  .rep-label {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(22px, 3.4vw, 30px);
    color: var(--color-white);
  }
  .rep-year {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.02em;
    color: var(--brand-200);
  }
  .mark-sm {
    position: absolute;
    right: 16px;
    bottom: 14px;
    width: 32px;
    height: 32px;
    object-fit: contain;
    opacity: 0.9;
  }

  /* ---- Award ---- */
  .award {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }
  .aw-year {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 30px;
    color: var(--brand-700);
  }
  .aw-title {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(20px, 3vw, 25px);
    line-height: 1.06;
    letter-spacing: -0.01em;
    color: var(--brand-900);
  }
  .confetti .cf {
    position: absolute;
    border-radius: 50%;
  }
  .cf.c1 {
    width: 26px;
    height: 26px;
    background: var(--brand-500);
    left: 14%;
    top: 22%;
  }
  .cf.c2 {
    width: 16px;
    height: 16px;
    background: var(--brand-700);
    right: 18%;
    top: 18%;
    border-radius: 4px;
    transform: rotate(18deg);
  }
  .cf.c3 {
    width: 34px;
    height: 34px;
    background: var(--color-white);
    right: 12%;
    bottom: 20%;
    opacity: 0.85;
  }
  .cf.c4 {
    width: 14px;
    height: 14px;
    background: var(--brand-600);
    left: 22%;
    bottom: 18%;
  }
  .cf.c5 {
    width: 20px;
    height: 20px;
    background: var(--brand-400);
    right: 30%;
    top: 60%;
    border-radius: 5px;
    transform: rotate(-12deg);
  }
  .cf.c6 {
    width: 12px;
    height: 12px;
    background: var(--brand-800);
    left: 46%;
    top: 14%;
  }

  @media (prefers-reduced-motion: reduce) {
    .cover-img {
      transition: none;
    }
  }
</style>
