---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Shared cinematic closing CTA: full-bleed dark photo bg + mixed-style headline +
// lede + button row, with an optional "What you'll leave with" side card listing
// numbered items. Used by both Research and Districts. Differs from About's
// AboutCTA (center-aligned, no side card) — this is the editorial spread variant.

interface Cta {
  label: string;
  href: string;
}
interface SideCard {
  eyebrow: string;
  serial?: string;
  items: string[];
}
interface AssuranceItem {
  text: string;
}
interface Props {
  eyebrow: string;
  // Same headline contract as CinematicHero.
  headlineLines: { text: string; kind: 'sans' | 'serif'; tone?: 'default' | 'accent' }[];
  lede?: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  image: ImageMetadata;
  imageAlt: string;
  // Optional small "checked" assurances below the buttons (Districts CTA uses this).
  assurances?: AssuranceItem[];
  // Optional side card; if omitted, the headline column spans wider (Research CTA).
  sideCard?: SideCard;
}

const {
  eyebrow,
  headlineLines,
  lede,
  primaryCta,
  secondaryCta,
  image,
  imageAlt,
  assurances,
  sideCard,
}: Props = Astro.props;
---

<section class:list={['ed-cta', { 'has-side': !!sideCard }]}>
  <div class="ed-bg">
    <Image
      src={image}
      alt={imageAlt}
      widths={[768, 1280, 1800, 2000]}
      sizes="100vw"
      loading="lazy"
    />
  </div>
  <div class="ed-tint" aria-hidden="true"></div>

  <div class="ed-inner">
    <div class="ed-body">
      <span class="ed-eyebrow">{eyebrow}</span>
      <h2 class="ed-headline">
        {
          headlineLines.map((line) => (
            <span class:list={['stk', line.kind, { accent: line.tone === 'accent' }]}>
              {line.text}
            </span>
          ))
        }
      </h2>
      {lede && <p class="ed-lede">{lede}</p>}
      {
        (primaryCta || secondaryCta) && (
          <div class="ed-ctas">
            {primaryCta && (
              <a class="btn btn-primary" href={primaryCta.href}>
                {primaryCta.label}
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
            )}
            {secondaryCta && (
              <a class="btn btn-ghost" href={secondaryCta.href}>
                {secondaryCta.label}
              </a>
            )}
          </div>
        )
      }
      {
        assurances && assurances.length > 0 && (
          <ul class="ed-assurances">
            {assurances.map((a) => (
              <li>
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span>{a.text}</span>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    {
      sideCard && (
        <aside class="ed-side">
          <div class="ed-side-head">
            <span class="ed-side-eyebrow">{sideCard.eyebrow}</span>
            {sideCard.serial && <span class="ed-side-serial">{sideCard.serial}</span>}
          </div>
          <ol class="ed-side-list">
            {sideCard.items.map((item, i) => (
              <li>
                <span class="num">0{i + 1}</span>
                <span class="text">{item}</span>
              </li>
            ))}
          </ol>
        </aside>
      )
    }
  </div>
</section>

<style>
  .ed-cta {
    position: relative;
    overflow: hidden;
    background: var(--neutral-950);
    color: var(--color-white);
  }
  .ed-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .ed-bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
    opacity: 0.55;
  }
  .ed-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      color-mix(in oklab, var(--neutral-950) 85%, transparent) 0%,
      color-mix(in oklab, var(--neutral-950) 55%, transparent) 60%,
      color-mix(in oklab, var(--neutral-950) 25%, transparent) 100%
    );
    z-index: 1;
  }
  .ed-inner {
    position: relative;
    z-index: 2;
    max-width: 1360px;
    margin: 0 auto;
    padding: 140px 40px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
    align-items: center;
  }
  .ed-cta.has-side .ed-inner {
    grid-template-columns: 1.2fr 1fr;
  }

  .ed-body {
    max-width: 720px;
  }
  .ed-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-white) 70%, transparent);
    margin-bottom: 32px;
  }
  .ed-eyebrow::before {
    content: '';
    width: 28px;
    height: 1px;
    background: color-mix(in oklab, var(--brand-300) 60%, transparent);
  }
  .ed-headline {
    font-size: clamp(56px, 8vw, 108px);
    line-height: 0.95;
    letter-spacing: -0.025em;
    margin: 0;
    text-wrap: balance;
  }
  .ed-headline .stk {
    display: block;
  }
  .ed-headline .sans {
    font-family: var(--font-sans);
    font-weight: 300;
    letter-spacing: -0.03em;
    color: var(--color-white);
  }
  .ed-headline .serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.015em;
    color: var(--color-white);
  }
  .ed-headline .accent {
    color: var(--brand-300);
  }
  .ed-lede {
    font-size: clamp(16px, 1.3vw, 18px);
    line-height: 1.65;
    color: color-mix(in oklab, var(--color-white) 80%, transparent);
    max-width: 540px;
    margin: 32px 0 0;
  }
  .ed-ctas {
    margin-top: 40px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 26px;
    border-radius: 9999px;
    font-family: var(--font-sans);
    font-size: 14.5px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.01em;
    transition:
      transform var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
    white-space: nowrap;
  }
  .btn-primary {
    background: var(--brand-500);
    color: var(--color-white);
    box-shadow:
      inset 0 1px 0 color-mix(in oklab, var(--color-white) 18%, transparent),
      0 8px 24px color-mix(in oklab, var(--brand-700) 35%, transparent);
  }
  .btn-primary:hover {
    background: var(--brand-600);
    transform: translateY(-2px);
  }
  .btn-ghost {
    color: var(--color-white);
    background: color-mix(in oklab, var(--color-white) 6%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-white) 28%, transparent);
  }
  .btn-ghost:hover {
    background: color-mix(in oklab, var(--color-white) 12%, transparent);
  }

  .ed-assurances {
    margin: 36px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }
  .ed-assurances li {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: color-mix(in oklab, var(--color-white) 70%, transparent);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
  }
  .ed-assurances li svg {
    color: var(--brand-300);
  }

  .ed-side {
    padding: 40px;
    border: 1px solid color-mix(in oklab, var(--color-white) 18%, transparent);
    border-radius: var(--radius-md);
    background: color-mix(in oklab, var(--color-white) 4%, transparent);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
  }
  .ed-side-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 28px;
  }
  .ed-side-eyebrow {
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-white) 70%, transparent);
  }
  .ed-side-serial {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    color: color-mix(in oklab, var(--color-white) 50%, transparent);
  }
  .ed-side-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 22px;
  }
  .ed-side-list li {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 16px;
    align-items: baseline;
  }
  .ed-side-list .num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 22px;
    line-height: 1;
    color: var(--brand-300);
  }
  .ed-side-list .text {
    font-size: 16px;
    line-height: 1.5;
    color: color-mix(in oklab, var(--color-white) 92%, transparent);
  }

  @media (max-width: 920px) {
    .ed-inner {
      padding: 88px 24px;
      gap: 40px;
    }
    .ed-cta.has-side .ed-inner {
      grid-template-columns: 1fr;
    }
    .ed-headline {
      font-size: clamp(40px, 9vw, 64px);
    }
    .ed-side {
      padding: 28px;
    }
  }
</style>
