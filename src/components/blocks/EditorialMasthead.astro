---
// Centered editorial masthead — the brand "duet" headline.
//
// Three layouts share the same component:
//   stacked (default) — sans lead line above an oversized serif-italic display line
//                       (used by /narrators/[slug] and similar long-form pages).
//   inline            — a single-line sentence with the serif word painted brand-green,
//                       sized to fit on one line (`white-space: nowrap`). Used by the
//                       Contact page hero ("Reach a real person *now.*").
//   display           — display-only: just the serif-italic line (no lead). Used by the
//                       Support page hero ("FAQs.").
//
// Carries the page's single <h1>.
interface Props {
  /** Optional centered eyebrow text between the two hairline rules. */
  eyebrow?: string;
  /** Sans lead text. Optional in `display` layout; required for `stacked`/`inline`. */
  lead?: string;
  /** Serif-italic display text (e.g. "Maya Castellanos." or "FAQs."). */
  display: string;
  /** Supporting paragraph below the headline. */
  intro?: string;
  /** Inner content width (any CSS length). */
  maxWidth?: string;
  /** Layout style. */
  layout?: 'stacked' | 'inline' | 'display';
}
const {
  eyebrow,
  lead,
  display,
  intro,
  maxWidth = '1200px',
  layout = 'stacked',
}: Props = Astro.props;
---

<section class="masthead" data-layout={layout} style={`--mw: ${maxWidth}`}>
  <div class="wrap">
    {
      eyebrow && (
        <div class="eb">
          <span class="rule" aria-hidden="true" />
          <span class="eb-text">{eyebrow}</span>
          <span class="rule" aria-hidden="true" />
        </div>
      )
    }
    <h1 class="display">
      {lead && <span class="lead">{lead}</span>}
      <span class="serif">{display}</span>
    </h1>
    {intro && <p class="intro">{intro}</p>}
  </div>
</section>

<style>
  .masthead {
    padding: 56px 0;
    text-align: center;
  }
  .wrap {
    max-width: var(--mw);
    margin: 0 auto;
    padding: 0 32px;
  }
  .eb {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-bottom: 28px;
    color: var(--color-muted-foreground);
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
  .rule {
    width: 60px;
    height: 1px;
    background: var(--color-border);
  }
  .display {
    margin: 0;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  /* Stacked (default): lead block sits above the oversized serif display block. */
  [data-layout='stacked'] .lead {
    display: block;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(36px, 6vw, 64px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--color-muted-foreground);
  }
  [data-layout='stacked'] .serif {
    display: block;
    margin-top: 4px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(56px, 11vw, 128px);
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--color-foreground);
  }

  /* Inline: one sentence on a single line, serif word painted brand-green. */
  [data-layout='inline'] .display {
    font-size: clamp(28px, 5.2vw, 56px);
    line-height: 1.05;
    white-space: nowrap;
    letter-spacing: -0.02em;
  }
  [data-layout='inline'] .lead {
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--color-foreground);
  }
  [data-layout='inline'] .serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    color: var(--color-brand);
  }

  /* Display: single oversized serif-italic line (no lead). */
  [data-layout='display'] .serif {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(56px, 9vw, 120px);
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--color-foreground);
  }

  .intro {
    margin: 28px auto 0;
    max-width: 56ch;
    font-size: 18px;
    line-height: 1.55;
    color: var(--color-muted-foreground);
    text-wrap: pretty;
  }
  [data-layout='inline'] .intro {
    margin-top: 22px;
  }
</style>
