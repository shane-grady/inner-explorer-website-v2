---
import { getCollection } from 'astro:content';
import Container from '../primitives/Container.astro';
import Section from '../layout/Section.astro';
import Heading from '../primitives/Heading.astro';
import Text from '../primitives/Text.astro';
import Grid from '../layout/Grid.astro';

interface Props {
  heading?: string;
}
const { heading = 'Trusted by educators' }: Props = Astro.props;

const testimonials = (await getCollection('testimonials')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Section space="lg" surface="muted">
  <Container>
    <Heading as="h2" size="lg" class="text-center">{heading}</Heading>
    <Grid cols={3} gap="lg" class="mt-12">
      {
        testimonials.map((t) => (
          <figure class="flex flex-col rounded-xl border border-border bg-card p-6 shadow-sm">
            <blockquote class="flex-1">
              <Text>&ldquo;{t.data.quote}&rdquo;</Text>
            </blockquote>
            <figcaption class="mt-4">
              <Text weight="semibold" size="sm">
                {t.data.name}
              </Text>
              <Text tone="muted" size="sm">
                {t.data.role}
                {t.data.org ? `, ${t.data.org}` : ''}
              </Text>
            </figcaption>
          </figure>
        ))
      }
    </Grid>
  </Container>
</Section>
