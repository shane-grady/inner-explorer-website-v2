---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Person {
  name: string;
  role: string;
  location: string;
  pin: string;
  founder?: boolean;
  photo: ImageMetadata;
}
interface Props {
  eyebrow: string;
  headingHtml: string;
  meta: string;
  people: Person[];
  note: string;
  cta: { label: string; href: string };
}
const { eyebrow, headingHtml, meta, people, note, cta }: Props = Astro.props;
---

<section class="team" id="team">
  <div class="team-wrap">
    <div class="team-head">
      <div>
        <span class="eyebrow">{eyebrow}</span>
        <h2 class="display-h" set:html={headingHtml} />
      </div>
      <p class="meta">{meta}</p>
    </div>

    <ul class="team-grid">
      {
        people.map((p) => (
          <li class="person">
            <div class="portrait">
              <span class:list={['pin', { founder: p.founder }]}>{p.pin}</span>
              <Image
                src={p.photo}
                alt={`Portrait of ${p.name}`}
                widths={[240, 480, 800]}
                sizes="(max-width: 920px) 45vw, 18vw"
                loading="lazy"
              />
            </div>
            <div class="info">
              <span class="nm">{p.name}</span>
              <span class="rl">{p.role}</span>
              <span class="loc">
                <span class="dot" aria-hidden="true" />
                {p.location}
              </span>
            </div>
          </li>
        ))
      }
    </ul>

    <div class="team-foot">
      <p class="note">{note}</p>
      <a class="careers" href={cta.href}>
        {cta.label}
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14"></path>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .team {
    padding: 140px 0;
    background: var(--color-background);
    position: relative;
  }
  .team-wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .team-head {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 60px;
    margin-bottom: 72px;
    align-items: end;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brand);
  }
  .eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: currentColor;
  }
  .display-h {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(40px, 5vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 16px 0 0;
    max-width: 620px;
    color: var(--color-foreground);
    text-wrap: balance;
  }
  .display-h :global(.accent) {
    color: var(--color-brand);
  }
  .team-head .meta {
    text-align: right;
    color: var(--color-muted-foreground);
    font-size: 14px;
    line-height: 1.6;
    max-width: 320px;
    margin: 0 0 0 auto;
  }

  .team-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 28px 24px;
  }
  .person {
    display: flex;
    flex-direction: column;
  }
  .portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-muted);
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.95);
    transition:
      transform 1.2s var(--ease-out),
      filter var(--dur) var(--ease-out);
  }
  .person:hover .portrait {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .person:hover .portrait :global(img) {
    transform: scale(1.04);
    filter: saturate(1.05);
  }
  .portrait::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 60%,
      color-mix(in oklab, var(--color-black) 18%, transparent) 100%
    );
    pointer-events: none;
  }
  .pin {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 5px 10px;
    border-radius: 9999px;
    background: var(--glass-bg-strong);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border: 1px solid var(--glass-border);
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground);
    z-index: 2;
  }
  .pin.founder {
    background: var(--color-brand);
    color: var(--color-white);
    border-color: transparent;
  }
  .info {
    padding-top: 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .nm {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.25;
    color: var(--color-foreground);
    letter-spacing: -0.005em;
  }
  .rl {
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-muted-foreground);
  }
  .loc {
    margin-top: 6px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    color: var(--color-muted-foreground);
    letter-spacing: 0.04em;
  }
  .loc .dot {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--brand-400);
  }

  .team-foot {
    margin-top: 72px;
    padding-top: 36px;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .team-foot .note {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    line-height: 1.3;
    color: var(--color-foreground);
    max-width: 540px;
    letter-spacing: -0.005em;
    margin: 0;
  }
  .careers {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    height: 46px;
    padding: 0 22px;
    border-radius: 9999px;
    background: var(--color-foreground);
    color: var(--color-background);
    font-size: 13.5px;
    font-weight: 500;
    line-height: 1;
    transition: opacity var(--dur-fast);
  }
  .careers:hover {
    opacity: 0.88;
  }

  @media (max-width: 920px) {
    .team-head {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .team-head .meta {
      text-align: left;
      margin-left: 0;
    }
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 16px;
    }
    .team-foot {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
