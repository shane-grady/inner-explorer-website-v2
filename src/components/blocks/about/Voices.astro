---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Voice {
  quote: string;
  name: string;
  role: string;
  avatar: ImageMetadata;
  featured?: boolean;
  bg?: ImageMetadata;
  bgAlt?: string;
}
interface Props {
  eyebrow: string;
  headingHtml: string;
  meta: string;
  voices: Voice[];
}
const { eyebrow, headingHtml, meta, voices }: Props = Astro.props;
---

<section class="voices">
  <div class="voices-wrap">
    <div class="voices-head">
      <div>
        <span class="eyebrow">{eyebrow}</span>
        <h2 class="display-h" set:html={headingHtml} />
      </div>
      <p class="meta">{meta}</p>
    </div>

    <div class="voices-grid">
      {
        voices.map((v) => (
          <figure class:list={['voice', { featured: v.featured }]}>
            {v.featured && v.bg && (
              <div class="voice-bg" aria-hidden="true">
                <Image
                  src={v.bg}
                  alt=""
                  widths={[480, 900]}
                  sizes="(max-width: 920px) 90vw, 32vw"
                  loading="lazy"
                />
              </div>
            )}
            <span class="mark" aria-hidden="true">
              &ldquo;
            </span>
            <blockquote class="quote">{v.quote}</blockquote>
            <figcaption class="author">
              <span class="av">
                <Image
                  src={v.avatar}
                  alt={`Portrait of ${v.name}`}
                  widths={[48, 96]}
                  sizes="48px"
                  loading="lazy"
                />
              </span>
              <span class="who-wrap">
                <span class="who">{v.name}</span>
                <span class="role">{v.role}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .voices {
    padding: 120px 0;
    background: var(--color-background);
    position: relative;
    overflow: hidden;
  }
  .voices-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .voices-head {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 60px;
    margin-bottom: 64px;
    align-items: end;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brand);
  }
  .eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: currentColor;
  }
  .display-h {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(40px, 5vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 16px 0 0;
    color: var(--color-foreground);
    text-wrap: balance;
  }
  .display-h :global(.accent) {
    color: var(--color-brand);
  }
  .voices-head .meta {
    text-align: right;
    color: var(--color-muted-foreground);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }

  .voices-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1.1fr;
    gap: 24px;
  }
  .voice {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: 36px 32px;
    margin: 0;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .voice:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .voice > :not(.voice-bg) {
    position: relative;
    z-index: 1;
  }
  .mark {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 64px;
    line-height: 0.6;
    color: var(--brand-200);
    margin: 0 0 0 -4px;
    user-select: none;
  }
  .quote {
    flex: 1;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    line-height: 1.4;
    letter-spacing: -0.005em;
    color: var(--color-foreground);
    margin: 12px 0 24px;
  }
  .author {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }
  .av {
    width: 48px;
    height: 48px;
    border-radius: 9999px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--brand-200);
    display: block;
  }
  .av :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .who-wrap {
    display: flex;
    flex-direction: column;
  }
  .who {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-foreground);
  }
  .role {
    font-size: 13px;
    line-height: 1.3;
    color: var(--color-muted-foreground);
  }

  /* Dark / themed featured card */
  .voice.featured {
    background: var(--voice-featured-bg);
    color: var(--color-white);
    border-color: color-mix(in oklab, var(--color-white) 6%, transparent);
  }
  .voice-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .voice-bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .voice-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--voice-featured-overlay);
  }
  .voice.featured .mark {
    color: color-mix(in oklab, var(--brand-300) 40%, transparent);
  }
  .voice.featured .quote {
    color: var(--color-white);
  }
  .voice.featured .author {
    border-top-color: color-mix(in oklab, var(--color-white) 15%, transparent);
  }
  .voice.featured .av {
    background: color-mix(in oklab, var(--color-white) 18%, transparent);
  }
  .voice.featured .who {
    color: var(--color-white);
  }
  .voice.featured .role {
    color: color-mix(in oklab, var(--color-white) 70%, transparent);
  }

  @media (max-width: 920px) {
    .voices-head {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .voices-head .meta {
      text-align: left;
    }
    .voices-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
