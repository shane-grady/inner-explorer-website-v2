---
interface Partner {
  name: string;
  sub: string;
}
interface Props {
  eyebrow: string;
  heading: string;
  partners: Partner[];
}
const { eyebrow, heading, partners }: Props = Astro.props;
---

<section class="partners">
  <div class="partners-head">
    <span class="eyebrow">{eyebrow}</span>
    <h2>{heading}</h2>
  </div>
  <div class="partners-wrap">
    <ul class="partners-grid">
      {
        partners.map((p) => (
          <li class="partner-cell">
            {p.name}
            <em>{p.sub}</em>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .partners {
    padding: 96px 0 120px;
    background: var(--color-card);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .partners-head {
    max-width: 1280px;
    margin: 0 auto 56px;
    padding: 0 32px;
    text-align: center;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brand);
  }
  .partners-head h2 {
    margin: 12px 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 36px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
    text-wrap: balance;
  }
  .partners-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .partners-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }
  .partner-cell {
    padding: 36px 24px;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    font-size: 17px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
    background: var(--color-card);
    transition: background var(--dur-fast);
    text-align: center;
    min-height: 120px;
  }
  .partner-cell:hover {
    background: var(--color-background);
  }
  .partner-cell:nth-child(6n) {
    border-right: 0;
  }
  .partner-cell:nth-last-child(-n + 6) {
    border-bottom: 0;
  }
  .partner-cell em {
    font-style: normal;
    color: var(--color-muted-foreground);
    font-weight: 500;
    font-size: 0.85em;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 920px) {
    .partners-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .partner-cell {
      border-right: 1px solid var(--color-border);
    }
    .partner-cell:nth-child(2n) {
      border-right: 0;
    }
    .partner-cell:nth-last-child(-n + 6) {
      border-bottom: 1px solid var(--color-border);
    }
    .partner-cell:nth-last-child(-n + 2) {
      border-bottom: 0;
    }
  }
</style>
