---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Photo {
  src: ImageMetadata;
  alt: string;
}
interface Props {
  eyebrow: string;
  headingHtml: string; // accent word wrapped in <span class="accent">
  paragraphs: string[];
  signed: { initials: string; name: string; role: string };
  large: Photo;
  small: Photo;
  chip: { quote: string; source: string };
}
const { eyebrow, headingHtml, paragraphs, signed, large, small, chip }: Props = Astro.props;
---

<section class="origin">
  <div class="origin-grid">
    <div class="origin-photos">
      <div class="ph large">
        <Image
          src={large.src}
          alt={large.alt}
          widths={[480, 768, 960]}
          sizes="(max-width: 920px) 90vw, 38vw"
        />
      </div>
      <div class="ph small">
        <Image
          src={small.src}
          alt={small.alt}
          widths={[320, 480]}
          sizes="(max-width: 920px) 45vw, 22vw"
        />
      </div>
      <figure class="quote-chip">
        <blockquote class="q">{chip.quote}</blockquote>
        <figcaption class="src">
          <span class="dot" aria-hidden="true"></span>{chip.source}
        </figcaption>
      </figure>
    </div>

    <div class="origin-text">
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="display-h" set:html={headingHtml} />
      {paragraphs.map((p) => <p>{p}</p>)}
      <div class="signed">
        <div class="av" aria-hidden="true">{signed.initials}</div>
        <div>
          <div class="who">{signed.name}</div>
          <div class="role">{signed.role}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .origin {
    background: var(--color-card);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 120px 0;
  }
  .origin-grid {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .origin-photos {
    position: relative;
    height: 640px;
  }
  .ph {
    position: absolute;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: var(--color-muted);
  }
  .ph :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ph.large {
    width: 78%;
    height: 80%;
    top: 0;
    left: 0;
  }
  .ph.small {
    width: 48%;
    height: 44%;
    right: 0;
    bottom: 0;
    border: 6px solid var(--color-card);
  }
  .quote-chip {
    position: absolute;
    top: 50%;
    right: -8%;
    transform: translateY(-40%);
    margin: 0;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    padding: 22px 26px;
    width: 280px;
    z-index: 3;
  }
  .quote-chip .q {
    margin: 0 0 12px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 18px;
    line-height: 1.4;
    color: var(--color-foreground);
  }
  .quote-chip .src {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-muted-foreground);
  }
  .quote-chip .dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--color-brand);
  }

  .origin-text {
    padding-right: 20px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brand);
  }
  .eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: currentColor;
  }
  .display-h {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(40px, 5vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 16px 0 0;
    color: var(--color-foreground);
    text-wrap: balance;
  }
  .display-h :global(.accent) {
    color: var(--color-brand);
  }
  .origin-text p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-foreground);
    margin: 22px 0 0;
  }
  .origin-text p:first-of-type {
    margin-top: 32px;
  }
  .origin-text p:first-of-type::first-letter {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 80px;
    line-height: 0.85;
    float: left;
    margin: 6px 12px 0 -2px;
    color: var(--color-brand);
  }
  .signed {
    margin-top: 32px;
    display: flex;
    align-items: center;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .signed .av {
    width: 48px;
    height: 48px;
    border-radius: 9999px;
    background: linear-gradient(135deg, var(--brand-400), var(--brand-700));
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 15px;
  }
  .signed .who {
    font-weight: 600;
    font-size: 15px;
    line-height: 1.3;
  }
  .signed .role {
    font-size: 13px;
    line-height: 1.3;
    color: var(--color-muted-foreground);
  }

  @media (max-width: 920px) {
    .origin-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .origin-text {
      padding-right: 0;
    }
    .quote-chip {
      right: 0;
    }
  }
</style>
