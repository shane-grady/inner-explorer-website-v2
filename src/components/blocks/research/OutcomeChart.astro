---
// Bespoke editorial charts for Chapter III. All animations are triggered by
// IntersectionObserver via a shared vanilla script at the bottom of the file.
// Reduced-motion users see the final state instantly (no transitions).

type Kind = 'bars' | 'before-after' | 'dial' | 'line' | 'competencies';
interface BarsDatum {
  label: string;
  value: number;
}
interface BeforeAfterDatum {
  label: string;
  before: number;
  after: number;
}
interface DialDatum {
  label: string;
  value: number;
}
interface LineDatum {
  week: number;
  stress: number;
  control: number;
}
interface CompDatum {
  label: string;
  value: number;
}

interface Props {
  kind: Kind;
  data: unknown;
}

const { kind, data }: Props = Astro.props;

// Line chart geometry (must be computed at render time since we render the path attrs).
let linePaths: {
  lineA: string;
  lineB: string;
  areaA: string;
  points: { week: number; cx: number; cy: number }[];
  gridY: { v: number; y: number }[];
  weekX: { week: number; x: number }[];
  W: number;
  H: number;
  P: { l: number; r: number; t: number; b: number };
} | null = null;

if (kind === 'line') {
  const lineData = data as LineDatum[];
  const W = 500,
    H = 260,
    P = { l: 40, r: 16, t: 20, b: 36 };
  const xs = lineData.map((d) => d.week);
  const minX = Math.min(...xs);
  const maxX = Math.max(...xs);
  const ys = [...lineData.map((d) => d.stress), ...lineData.map((d) => d.control)];
  const minY = Math.min(...ys, 65);
  const maxY = Math.max(...ys, 105);
  const x = (w: number) => P.l + ((w - minX) / (maxX - minX)) * (W - P.l - P.r);
  const y = (v: number) => P.t + (1 - (v - minY) / (maxY - minY)) * (H - P.t - P.b);
  const lineA = lineData
    .map((d, i) => `${i === 0 ? 'M' : 'L'} ${x(d.week)} ${y(d.stress)}`)
    .join(' ');
  const lineB = lineData
    .map((d, i) => `${i === 0 ? 'M' : 'L'} ${x(d.week)} ${y(d.control)}`)
    .join(' ');
  const areaA = `${lineA} L ${x(maxX)} ${H - P.b} L ${x(minX)} ${H - P.b} Z`;
  linePaths = {
    lineA,
    lineB,
    areaA,
    points: lineData.map((d) => ({ week: d.week, cx: x(d.week), cy: y(d.stress) })),
    gridY: [70, 80, 90, 100].map((v) => ({ v, y: y(v) })),
    weekX: lineData.map((d) => ({ week: d.week, x: x(d.week) })),
    W,
    H,
    P,
  };
}
---

{
  kind === 'bars' && (
    <div class="chart bars-chart" data-chart>
      <div class="title">Grade gains vs. control</div>
      <div class="sub">Treatment classes, quarterly grade points</div>
      <div class="bars">
        {(data as BarsDatum[]).map((d, i) => {
          const max = Math.max(...(data as BarsDatum[]).map((x) => x.value), 20);
          const pct = (d.value / max) * 100;
          return (
            <div class="bar-row">
              <div class="bar-head">
                <span class="bar-label">{d.label}</span>
                <span class="bar-value">+{d.value}%</span>
              </div>
              <div class="bar-track">
                <div class="bar-fill" style={`--pct: ${pct}%; --i: ${i}`} />
              </div>
            </div>
          );
        })}
      </div>
      <div class="foot">Bakosh 2016 · 2018 · Dunlap 2023</div>
    </div>
  )
}

{
  kind === 'before-after' && (
    <div class="chart ba-chart" data-chart>
      <div class="title">Before · After</div>
      <div class="sub">Indexed to pre-program baseline = 100</div>
      <div class="ba">
        {(data as BeforeAfterDatum[]).map((d, i) => (
          <div class="ba-row" style={`--i: ${i}`}>
            <div class="ba-label">{d.label}</div>
            <div class="ba-pair">
              <div class="ba-box ba-before">
                <span class="tag">Before</span>
                <span class="big">{d.before}</span>
              </div>
              <div class="ba-arrow">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5l7 7-7 7" />
                </svg>
              </div>
              <div class="ba-box ba-after">
                <span class="tag">After</span>
                <span class="big">{d.after}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="foot">Lopez 2020, RCT · 39 Head Start classrooms</div>
    </div>
  )
}

{
  kind === 'dial' && (
    <div class="chart dial-chart" data-chart>
      <div class="title">Teacher outcomes</div>
      <div class="sub">Change vs. baseline, end of school year</div>
      <div class="dials">
        {(data as DialDatum[]).map((d, i) => {
          const mag = Math.min(50, Math.abs(d.value));
          const pct = mag / 50;
          const C = Math.PI * 44;
          return (
            <div class="dial" style={`--i: ${i}`}>
              <svg viewBox="0 0 110 60" width="110" height="60" aria-hidden="true">
                <path
                  d="M 8 54 A 44 44 0 0 1 102 54"
                  fill="none"
                  stroke="var(--color-muted)"
                  stroke-width="6"
                  stroke-linecap="round"
                />
                <path
                  d="M 8 54 A 44 44 0 0 1 102 54"
                  fill="none"
                  stroke="var(--color-brand)"
                  stroke-width="6"
                  stroke-linecap="round"
                  stroke-dasharray={C}
                  stroke-dashoffset={C}
                  style={`--final-offset: ${C * (1 - pct)}`}
                  class="dial-path"
                />
              </svg>
              <div class="dial-val">
                {d.value > 0 ? '+' : ''}
                {d.value}
                <sup>%</sup>
              </div>
              <div class="dial-label">{d.label}</div>
            </div>
          );
        })}
      </div>
      <div class="foot">Lopez 2020, RCT · University of South Florida</div>
    </div>
  )
}

{
  kind === 'line' && linePaths && (
    <div class="chart line-chart" data-chart>
      <div class="title">Stress over eight weeks</div>
      <div class="sub">Active control vs. Inner Explorer at home</div>
      <svg viewBox={`0 0 ${linePaths.W} ${linePaths.H}`} class="line-svg" aria-hidden="true">
        <defs>
          <linearGradient id="line-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" class="line-grad-top" />
            <stop offset="100%" class="line-grad-bot" />
          </linearGradient>
        </defs>
        {linePaths.gridY.map((g) => (
          <g>
            <line
              x1={linePaths.P.l}
              x2={linePaths.W - linePaths.P.r}
              y1={g.y}
              y2={g.y}
              class="line-grid"
            />
            <text x={linePaths.P.l - 8} y={g.y + 4} text-anchor="end" class="line-axis-y">
              {g.v}
            </text>
          </g>
        ))}
        {linePaths.weekX.map((w) => (
          <text
            x={w.x}
            y={linePaths.H - linePaths.P.b + 20}
            text-anchor="middle"
            class="line-axis-x"
          >
            wk {w.week}
          </text>
        ))}
        <path d={linePaths.areaA} fill="url(#line-grad)" class="line-area" />
        <path d={linePaths.lineB} class="line-control" />
        <path d={linePaths.lineA} class="line-treatment" />
        {linePaths.points.map((p, i) => (
          <circle cx={p.cx} cy={p.cy} r="4" class="line-point" style={`--i: ${i}`} />
        ))}
      </svg>
      <div class="line-legend">
        <span>
          <i class="legend-treatment" />
          Inner Explorer
        </span>
        <span>
          <i class="legend-control" />
          Active control
        </span>
      </div>
      <div class="foot">Treves 2023, RCT · MIT McGovern Institute</div>
    </div>
  )
}

{
  kind === 'competencies' && (
    <div class="chart comp-chart" data-chart>
      <div class="title">CASEL coverage</div>
      <div class="sub">Practices explicitly mapping to each competency</div>
      <div class="comp">
        {(data as CompDatum[]).map((d, i) => (
          <div class="comp-row" style={`--i: ${i}`}>
            <div class="comp-label">{d.label}</div>
            <div class="comp-bar">
              <div class="comp-bar-fill" style={`--pct: ${d.value}%`} />
            </div>
            <div class="comp-pct">{d.value}%</div>
          </div>
        ))}
      </div>
      <div class="foot">CASEL Program Guide</div>
    </div>
  )
}

<style>
  .chart {
    display: flex;
    flex-direction: column;
    flex: 1;
    --animated: 0; /* flipped to 1 when in view */
  }
  .title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-foreground);
  }
  .sub {
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-muted-foreground);
    margin-top: 4px;
    margin-bottom: 28px;
  }
  .foot {
    margin-top: auto;
    padding-top: 18px;
    font-size: 11px;
    line-height: 1.4;
    color: var(--color-muted-foreground);
    font-style: italic;
    border-top: 1px solid var(--color-border);
  }

  /* ============ Bars ============ */
  .bars {
    display: flex;
    flex-direction: column;
    gap: 24px;
    flex: 1;
  }
  .bar-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .bar-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .bar-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-foreground);
  }
  .bar-value {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 24px;
    color: var(--color-brand);
    letter-spacing: -0.01em;
  }
  .bar-track {
    height: 14px;
    background: var(--color-muted);
    overflow: hidden;
    position: relative;
  }
  .bar-fill {
    height: 100%;
    background: var(--color-foreground);
    width: 0;
    transition: width 1200ms var(--ease-out);
    transition-delay: calc(var(--i) * 120ms);
    position: relative;
  }
  .bars-chart[data-anim] .bar-fill {
    width: var(--pct);
  }
  .bar-fill::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--color-brand);
  }

  /* ============ Before/After ============ */
  .ba {
    display: flex;
    flex-direction: column;
    gap: 28px;
    flex: 1;
  }
  .ba-row {
    display: flex;
    flex-direction: column;
    gap: 14px;
    opacity: 0;
    transition: opacity 600ms;
    transition-delay: calc(var(--i) * 100ms);
  }
  .ba-chart[data-anim] .ba-row {
    opacity: 1;
  }
  .ba-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-foreground);
  }
  .ba-pair {
    display: grid;
    grid-template-columns: 1fr 36px 1fr;
    gap: 6px;
    align-items: stretch;
  }
  .ba-box {
    padding: 18px 20px;
    border-radius: var(--radius-sm);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .ba-before {
    background: var(--color-muted);
    color: var(--color-muted-foreground);
  }
  .ba-after {
    background: var(--neutral-900);
    color: var(--color-white);
  }
  .ba-after .big {
    color: var(--brand-300);
  }
  .big {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 36px;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .tag {
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .ba-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand);
  }

  /* ============ Dials ============ */
  .dials {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    flex: 1;
  }
  .dial {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 20px 8px;
    background: var(--color-card);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }
  .dial-path {
    transition: stroke-dashoffset 1200ms var(--ease-out);
    transition-delay: calc(var(--i) * 180ms);
  }
  .dial-chart[data-anim] .dial-path {
    stroke-dashoffset: var(--final-offset);
  }
  .dial-val {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 30px;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-brand);
  }
  .dial-val sup {
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 500;
    font-size: 0.5em;
    top: -0.6em;
  }
  .dial-label {
    font-size: 11px;
    line-height: 1.3;
    font-weight: 500;
    color: var(--color-muted-foreground);
    text-align: center;
    max-width: 120px;
  }

  /* ============ Line ============ */
  .line-svg {
    width: 100%;
    height: 260px;
  }
  .line-grad-top {
    stop-color: color-mix(in oklab, var(--color-brand) 22%, transparent);
  }
  .line-grad-bot {
    stop-color: color-mix(in oklab, var(--color-brand) 0%, transparent);
  }
  .line-grid {
    stroke: var(--color-border);
  }
  .line-axis-y,
  .line-axis-x {
    font-size: 11px;
    font-family: var(--font-sans);
    fill: var(--color-muted-foreground);
  }
  .line-area {
    opacity: 0;
    transition: opacity 800ms 700ms;
  }
  .line-control {
    fill: none;
    stroke: color-mix(in oklab, var(--color-foreground) 50%, transparent);
    stroke-width: 2;
    stroke-dasharray: 5 5;
    opacity: 0;
    transition: opacity 700ms 300ms;
  }
  .line-treatment {
    fill: none;
    stroke: var(--color-brand);
    stroke-width: 3;
    stroke-dasharray: 700;
    stroke-dashoffset: 700;
    transition: stroke-dashoffset 1600ms var(--ease-out);
  }
  .line-point {
    fill: var(--color-brand);
    stroke: var(--color-card);
    stroke-width: 2;
    opacity: 0;
    transition: opacity 300ms;
    transition-delay: calc(700ms + var(--i) * 100ms);
  }
  .line-chart[data-anim] .line-area,
  .line-chart[data-anim] .line-control,
  .line-chart[data-anim] .line-point {
    opacity: 1;
  }
  .line-chart[data-anim] .line-treatment {
    stroke-dashoffset: 0;
  }
  .line-legend {
    display: flex;
    gap: 22px;
    font-size: 11px;
    font-weight: 500;
    color: var(--color-muted-foreground);
    margin-top: 8px;
  }
  .line-legend span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .line-legend i {
    display: inline-block;
    width: 18px;
    height: 2px;
  }
  .legend-treatment {
    background: var(--color-brand);
  }
  .legend-control {
    border-top: 2px dashed color-mix(in oklab, var(--color-foreground) 55%, transparent);
  }

  /* ============ Competencies ============ */
  .comp {
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
  }
  .comp-row {
    display: grid;
    grid-template-columns: 1fr 200px 40px;
    align-items: center;
    gap: 16px;
  }
  .comp-label {
    font-size: 13px;
    line-height: 1.3;
    font-weight: 500;
    color: var(--color-foreground);
  }
  .comp-bar {
    height: 18px;
    background: var(--color-muted);
    position: relative;
    overflow: hidden;
  }
  .comp-bar-fill {
    position: absolute;
    inset: 0 auto 0 0;
    background: repeating-linear-gradient(
      90deg,
      var(--color-brand) 0,
      var(--color-brand) 2px,
      transparent 2px,
      transparent 6px
    );
    width: 0;
    transition: width 1200ms var(--ease-out);
    transition-delay: calc(var(--i) * 140ms);
  }
  .comp-chart[data-anim] .comp-bar-fill {
    width: var(--pct);
  }
  .comp-pct {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 18px;
    color: var(--color-brand);
    text-align: right;
  }

  @media (prefers-reduced-motion: reduce) {
    .bar-fill,
    .ba-row,
    .dial-path,
    .line-area,
    .line-control,
    .line-treatment,
    .line-point,
    .comp-bar-fill {
      transition: none !important;
    }
  }
</style>

<script>
  // Toggle [data-anim] on each chart when it enters the viewport. CSS does the rest.
  const charts = document.querySelectorAll<HTMLElement>('[data-chart]');
  if (charts.length) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.setAttribute('data-anim', '');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.3 },
    );
    charts.forEach((c) => io.observe(c));
  }
</script>
