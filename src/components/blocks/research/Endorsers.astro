---
// Calm row of research partners & endorsers — 3-column bordered grid.

interface Endorser {
  name: string;
  role: string;
}
interface Props {
  label: string;
  items: Endorser[];
}
const { label, items }: Props = Astro.props;
---

<section class="endorsers" aria-label={label}>
  <div class="end-inner">
    <div class="end-label">{label}</div>
    <div class="end-grid">
      {
        items.map((it) => (
          <div class="end-item">
            <div class="name">{it.name}</div>
            <div class="role">{it.role}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .endorsers {
    background: var(--color-muted);
    padding: 80px 0;
    color: var(--color-foreground);
  }
  .end-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .end-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
    margin-bottom: 40px;
  }
  .end-label::before,
  .end-label::after {
    content: '';
    flex: 0 0 80px;
    height: 1px;
    background: var(--color-border);
  }
  .end-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .end-item {
    text-align: center;
    padding: 28px 16px;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .end-item:nth-child(3n) {
    border-right: 0;
  }
  .end-item:nth-last-child(-n + 3) {
    border-bottom: 0;
  }
  .name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 20px;
    line-height: 1.15;
    letter-spacing: -0.005em;
    color: var(--color-foreground);
    margin-bottom: 6px;
  }
  .role {
    font-size: 12px;
    line-height: 1.3;
    color: var(--color-muted-foreground);
  }
  @media (max-width: 720px) {
    .end-grid {
      grid-template-columns: 1fr 1fr;
    }
    .end-item:nth-child(3n) {
      border-right: 1px solid var(--color-border);
    }
    .end-item:nth-child(2n) {
      border-right: 0;
    }
    .end-item:nth-last-child(-n + 3) {
      border-bottom: 1px solid var(--color-border);
    }
    .end-item:nth-last-child(-n + 2) {
      border-bottom: 0;
    }
  }
</style>
