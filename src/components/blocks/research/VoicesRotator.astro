---
// Voices — dark section with brand radial glows; auto-rotating quotes with manual
// dot pagination. No-JS: first quote stays visible; dots are a real navigation list.

interface Voice {
  quote: string;
  author: string;
  where: string;
}
interface Props {
  voices: Voice[];
}
const { voices }: Props = Astro.props;
---

<section class="vr" aria-label="Voices" data-rotator>
  <div class="vr-inner">
    <div class="vr-mark">&ldquo;</div>
    <div class="vr-track">
      {
        voices.map((v, i) => (
          <div class:list={['vr-slide', { on: i === 0 }]} data-i={i}>
            <p class="quote">{v.quote}</p>
            <div class="author">{v.author}</div>
            <div class="where">{v.where}</div>
          </div>
        ))
      }
    </div>
    <div class="vr-dots" role="tablist" aria-label="Rotate quotes">
      {
        voices.map((_, i) => (
          <button
            type="button"
            data-i={i}
            class:list={[{ on: i === 0 }]}
            aria-label={`Quote ${i + 1}`}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .vr {
    background: var(--neutral-950);
    color: var(--color-white);
    position: relative;
    overflow: hidden;
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 120px 0;
  }
  .vr::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        circle at 20% 50%,
        color-mix(in oklab, var(--brand-500) 35%, transparent),
        transparent 50%
      ),
      radial-gradient(
        circle at 80% 70%,
        color-mix(in oklab, var(--brand-700) 30%, transparent),
        transparent 50%
      );
    pointer-events: none;
  }
  .vr-inner {
    position: relative;
    z-index: 1;
    max-width: 980px;
    margin: 0 auto;
    padding: 0 32px;
    text-align: center;
  }
  .vr-mark {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 140px;
    line-height: 0.8;
    color: var(--brand-300);
    opacity: 0.6;
    margin-bottom: -20px;
  }
  .vr-track {
    position: relative;
    min-height: 280px;
  }
  .vr-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 600ms var(--ease-out),
      transform 600ms var(--ease-out);
    pointer-events: none;
  }
  .vr-slide.on {
    position: relative;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .quote {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(28px, 4vw, 56px);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-white);
    margin: 0 0 36px;
    text-wrap: balance;
  }
  .author {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.04em;
    color: var(--color-white);
  }
  .where {
    font-size: 13px;
    line-height: 1.4;
    color: color-mix(in oklab, var(--color-white) 60%, transparent);
    margin-top: 4px;
  }
  .vr-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 48px;
  }
  .vr-dots button {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: color-mix(in oklab, var(--color-white) 25%, transparent);
    border: 0;
    padding: 0;
    cursor: pointer;
    transition: all var(--dur-fast) var(--ease-out);
  }
  .vr-dots button.on {
    background: var(--brand-300);
    transform: scale(1.4);
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-rotator]');
  if (root) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('.vr-slide'));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('.vr-dots button'));
    let i = 0;
    let timer: number | undefined;
    const show = (n: number) => {
      i = (n + slides.length) % slides.length;
      slides.forEach((s, idx) => s.classList.toggle('on', idx === i));
      dots.forEach((d, idx) => d.classList.toggle('on', idx === i));
    };
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const start = () => {
      if (reduce) return;
      stop();
      timer = window.setInterval(() => show(i + 1), 7000);
    };
    const stop = () => {
      if (timer) {
        window.clearInterval(timer);
        timer = undefined;
      }
    };
    dots.forEach((d, idx) => {
      d.addEventListener('click', () => {
        show(idx);
        start();
      });
    });
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    start();
  }
</script>
