---
interface Props {
  chapterLabel: string;
  chapterNumber: string;
  headingHtml: string;
  paragraphs: string[];
  pullQuoteHtml: string;
  toggleStressedLabel?: string;
  toggleMindfulLabel?: string;
}
const {
  chapterLabel,
  chapterNumber,
  headingHtml,
  paragraphs,
  pullQuoteHtml,
  toggleStressedLabel = 'Stressed',
  toggleMindfulLabel = 'Mindful',
}: Props = Astro.props;

// 19 nodes + 32 edges — symmetric, evocative of a brain-network graph.
const nodes: Array<[number, number]> = [
  [50, 18],
  [35, 25],
  [68, 28],
  [22, 42],
  [80, 40],
  [15, 60],
  [88, 60],
  [20, 78],
  [82, 78],
  [40, 85],
  [62, 88],
  [42, 38],
  [58, 36],
  [35, 52],
  [65, 54],
  [50, 50],
  [40, 65],
  [60, 66],
  [50, 72],
];
const edges: Array<[number, number]> = [
  [0, 1],
  [0, 2],
  [1, 3],
  [2, 4],
  [3, 5],
  [4, 6],
  [5, 7],
  [6, 8],
  [7, 9],
  [8, 10],
  [9, 10],
  [0, 11],
  [0, 12],
  [11, 12],
  [11, 13],
  [12, 14],
  [13, 15],
  [14, 15],
  [15, 16],
  [15, 17],
  [16, 18],
  [17, 18],
  [9, 16],
  [10, 17],
  [1, 11],
  [2, 12],
  [3, 13],
  [4, 14],
  [5, 13],
  [6, 14],
  [7, 16],
  [8, 17],
];
---

<section class="brain" id="brain" data-screen-label={chapterLabel} aria-labelledby="brain-heading">
  <div class="wrap">
    <div class="chap-mark reveal">
      <span class="chap-num">{chapterNumber}</span>
      <span class="chap-rule" aria-hidden="true"></span>
      <span class="chap-label">{chapterLabel}</span>
    </div>
    <h2 class="chap-title reveal" id="brain-heading" set:html={headingHtml} />

    <div class="grid">
      <div class="viz" data-brain-viz data-state="mindful">
        <svg viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          <defs>
            <radialGradient id="brain-bg-glow" cx="50%" cy="50%" r="60%">
              <stop offset="0%" class="bg-stop"></stop>
              <stop offset="100%" stop-color="transparent"></stop>
            </radialGradient>
          </defs>
          <rect width="100" height="100" fill="url(#brain-bg-glow)"></rect>
          {
            edges.map(([a, b], i) => (
              <line
                class="edge"
                x1={nodes[a][0]}
                y1={nodes[a][1]}
                x2={nodes[b][0]}
                y2={nodes[b][1]}
                stroke-width="0.5"
                style={`--d:${(i * 0.07) % 2}s; --dur:${2.5 + (i % 4) * 0.4}s`}
              />
            ))
          }
          {
            nodes.map(([x, y], i) => (
              <g class="node">
                <circle class="node-core" cx={x} cy={y} r="1.4" style={`--d:${(i * 0.12) % 3}s`} />
                <circle class="node-halo" cx={x} cy={y} r="3" style={`--d:${(i * 0.18) % 4}s`} />
              </g>
            ))
          }
        </svg>
        <div class="viz-toggle" role="group" aria-label="Brain state">
          <button type="button" role="switch" aria-checked="false" data-state-toggle="stressed">
            {toggleStressedLabel}
          </button>
          <button type="button" role="switch" aria-checked="true" data-state-toggle="mindful">
            {toggleMindfulLabel}
          </button>
        </div>
      </div>

      <div class="copy">
        <div class="copy-block reveal">
          {paragraphs.slice(0, 2).map((p) => <p set:html={p} />)}
        </div>
        <blockquote class="pull reveal" set:html={pullQuoteHtml} />
        <div class="copy-block reveal">
          {paragraphs.slice(2).map((p) => <p set:html={p} />)}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .brain {
    padding: 140px 0 120px;
    background: var(--editorial-night);
    color: var(--editorial-paper);
  }
  .wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .chap-mark {
    display: flex;
    align-items: baseline;
    gap: 18px;
    margin-bottom: 28px;
  }
  .chap-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 36px;
    line-height: 1;
    color: var(--editorial-glow);
  }
  .chap-rule {
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.18;
    align-self: center;
  }
  .chap-label {
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    opacity: 0.55;
  }
  .chap-title {
    margin: 0 0 56px;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(44px, 6vw, 88px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }
  .chap-title :global(em) {
    font-style: italic;
    color: var(--editorial-glow);
    font-weight: 500;
  }
  .chap-title :global(.sans) {
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 300;
    letter-spacing: -0.025em;
  }
  .chap-title :global(.stk) {
    display: block;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: start;
  }
  .viz {
    position: sticky;
    top: 140px;
    aspect-ratio: 1 / 1.1;
    border-radius: 28px;
    padding: 32px;
    background: linear-gradient(
      165deg,
      var(--editorial-night-soft) 0%,
      var(--editorial-night) 100%
    );
    border: 1px solid color-mix(in oklab, var(--editorial-paper) 6%, transparent);
    overflow: hidden;
  }
  .viz svg {
    width: 100%;
    height: 100%;
  }
  .bg-stop {
    stop-color: color-mix(in oklab, var(--editorial-glow) 18%, transparent);
  }
  .viz[data-state='stressed'] .bg-stop {
    stop-color: color-mix(in oklab, var(--editorial-paper) 5%, transparent);
  }
  .edge {
    stroke: var(--editorial-glow);
    stroke-opacity: 0.8;
    animation: edgePulse var(--dur) ease-in-out infinite;
    animation-delay: var(--d);
  }
  .viz[data-state='stressed'] .edge {
    stroke: color-mix(in oklab, var(--editorial-paper) 35%, transparent);
    stroke-width: 0.25;
    stroke-opacity: 0.4;
    animation: none;
  }
  @keyframes edgePulse {
    0%,
    100% {
      stroke-opacity: 0.4;
    }
    50% {
      stroke-opacity: 0.95;
    }
  }
  .node-core {
    fill: var(--editorial-glow);
    animation: nodePulse 3s ease-in-out infinite;
    animation-delay: var(--d);
  }
  .node-halo {
    fill: var(--editorial-glow);
    opacity: 0.18;
    animation: haloPulse 4s ease-in-out infinite;
    animation-delay: var(--d);
  }
  .viz[data-state='stressed'] .node-core {
    fill: color-mix(in oklab, var(--editorial-paper) 55%, transparent);
    r: 0.9;
    animation: none;
  }
  .viz[data-state='stressed'] .node-halo {
    display: none;
  }
  @keyframes nodePulse {
    0%,
    100% {
      r: 1.1;
    }
    50% {
      r: 1.8;
    }
  }
  @keyframes haloPulse {
    0%,
    100% {
      r: 2;
      opacity: 0.3;
    }
    50% {
      r: 5;
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .edge,
    .node-core,
    .node-halo {
      animation: none;
    }
  }

  .viz-toggle {
    position: absolute;
    bottom: 24px;
    left: 24px;
    right: 24px;
    display: flex;
    padding: 4px;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--editorial-paper) 6%, transparent);
    border: 1px solid color-mix(in oklab, var(--editorial-paper) 10%, transparent);
    z-index: 2;
  }
  .viz-toggle button {
    flex: 1;
    padding: 10px 16px;
    border: 0;
    border-radius: 9999px;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.04em;
    color: color-mix(in oklab, var(--editorial-paper) 60%, transparent);
    cursor: pointer;
    transition: all 250ms var(--ease-out);
  }
  .viz-toggle button[aria-checked='true'] {
    background: var(--editorial-glow);
    color: var(--editorial-night);
  }
  .viz-toggle button:focus-visible {
    outline: 2px solid var(--editorial-glow);
    outline-offset: 2px;
  }

  .copy {
    font-size: 18px;
    line-height: 1.7;
    color: color-mix(in oklab, var(--editorial-paper) 85%, transparent);
  }
  .copy p {
    margin: 0 0 22px;
    max-width: 580px;
  }
  .copy-block:first-child p:first-of-type::first-letter {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 110px;
    line-height: 0.85;
    float: left;
    color: var(--editorial-glow);
    padding-right: 14px;
    padding-top: 8px;
    margin-bottom: -10px;
  }
  .copy :global(.inline-stat) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--editorial-glow);
    font-size: 1.15em;
  }
  .pull {
    margin: 32px 0;
    max-width: 580px;
    padding: 28px 0;
    border-top: 1px solid color-mix(in oklab, var(--editorial-paper) 12%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--editorial-paper) 12%, transparent);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--editorial-paper);
  }
  .pull :global(em) {
    color: var(--editorial-glow);
  }

  .reveal {
    opacity: 1;
    transform: none;
    transition:
      opacity 900ms var(--ease-out),
      transform 900ms var(--ease-out);
  }
  :global([data-js-ready]) .reveal:not(.in) {
    opacity: 0;
    transform: translateY(28px);
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .viz {
      position: relative;
      top: 0;
    }
  }
</style>

<script>
  import { observe } from '../../../lib/intersect';
  observe('.brain .reveal');

  // Brain state toggle (role=switch on each button; both buttons keep their
  // aria-checked in sync with the container's data-state attribute).
  const viz = document.querySelector<HTMLElement>('[data-brain-viz]');
  if (viz) {
    const buttons = Array.from(viz.querySelectorAll<HTMLButtonElement>('[data-state-toggle]'));
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const next = btn.dataset.stateToggle ?? 'mindful';
        viz.dataset.state = next;
        buttons.forEach((b) =>
          b.setAttribute('aria-checked', b.dataset.stateToggle === next ? 'true' : 'false'),
        );
      });
    });
  }
</script>
