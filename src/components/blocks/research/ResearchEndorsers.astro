---
interface Endorser {
  name: string;
  role: string;
}
interface Props {
  label: string;
  items: Endorser[];
}
const { label, items }: Props = Astro.props;
---

<section class="endorsers" id="endorsers" data-screen-label="Endorsers" aria-label={label}>
  <div class="wrap">
    <div class="label" aria-hidden="true">{label}</div>
    <div class="grid">
      {
        items.map((it) => (
          <div class="cell">
            <div class="name">{it.name}</div>
            <div class="role">{it.role}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .endorsers {
    padding: 80px 0;
    background: var(--editorial-paper-soft);
    color: var(--editorial-ink);
  }
  .wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-bottom: 40px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--editorial-ink-muted);
  }
  .label::before,
  .label::after {
    content: '';
    flex: 0 0 80px;
    height: 1px;
    background: color-mix(in oklab, var(--editorial-ink) 18%, transparent);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .cell {
    padding: 28px 16px;
    text-align: center;
    border-right: 1px solid color-mix(in oklab, var(--editorial-ink) 10%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--editorial-ink) 10%, transparent);
  }
  .cell:nth-child(3n) {
    border-right: 0;
  }
  .cell:nth-last-child(-n + 3) {
    border-bottom: 0;
  }
  .name {
    margin-bottom: 6px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 20px;
    line-height: 1.15;
    letter-spacing: -0.005em;
    color: var(--editorial-ink);
  }
  .role {
    font-size: 12px;
    line-height: 1.3;
    color: var(--editorial-ink-muted);
  }
  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
    .cell:nth-child(3n) {
      border-right: 1px solid color-mix(in oklab, var(--editorial-ink) 10%, transparent);
    }
    .cell:nth-child(2n) {
      border-right: 0;
    }
    .cell:nth-last-child(-n + 3) {
      border-bottom: 1px solid color-mix(in oklab, var(--editorial-ink) 10%, transparent);
    }
    .cell:nth-last-child(-n + 2) {
      border-bottom: 0;
    }
  }
</style>
