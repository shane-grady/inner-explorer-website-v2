---
export interface DialDatum {
  label: string;
  value: number;
}
interface Props {
  title: string;
  subtitle: string;
  foot: string;
  data: DialDatum[];
}
const { title, subtitle, foot, data }: Props = Astro.props;

const r = 44;
const circumference = Math.PI * r;
const max = 50; // % magnitude cap for visualization
---

<figure class="chart" data-anim>
  <figcaption class="head">
    <div class="title">{title}</div>
    <div class="sub">{subtitle}</div>
  </figcaption>
  <div class="dials">
    {
      data.map((d, i) => {
        const mag = Math.min(max, Math.abs(d.value));
        const pct = mag / max;
        const dashoffset = circumference * (1 - pct);
        const sign = d.value > 0 ? '+' : d.value < 0 ? '−' : '';
        const absValue = Math.abs(d.value);
        return (
          <div class="dial" style={`--off:${dashoffset}; --d:${i * 180}ms`}>
            <svg viewBox="0 0 110 60" width="110" height="60" aria-hidden="true">
              <path
                d="M 8 54 A 44 44 0 0 1 102 54"
                fill="none"
                stroke-width="6"
                stroke-linecap="round"
                class="dial-bg"
              />
              <path
                d="M 8 54 A 44 44 0 0 1 102 54"
                fill="none"
                stroke-width="6"
                stroke-linecap="round"
                class="dial-fg"
                stroke-dasharray={circumference}
              />
            </svg>
            <div class="value">
              {sign}
              {absValue}
              <sup>%</sup>
            </div>
            <div class="label">{d.label}</div>
          </div>
        );
      })
    }
  </div>
  <div class="foot">{foot}</div>
</figure>

<style>
  .chart {
    margin: 0;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .head {
    margin-bottom: 28px;
  }
  .title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--editorial-ink);
  }
  .sub {
    margin-top: 4px;
    font-size: 12px;
    line-height: 1.4;
    color: var(--editorial-ink-muted);
  }
  .dials {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    flex: 1;
  }
  .dial {
    padding: 20px 8px;
    border-radius: 16px;
    background: color-mix(in oklab, var(--color-white) 50%, transparent);
    border: 1px solid color-mix(in oklab, var(--editorial-ink) 6%, transparent);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .dial-bg {
    stroke: color-mix(in oklab, var(--editorial-ink) 10%, transparent);
  }
  /* Dial fill defaults to its final offset (visible). When JS is ready,
     [data-anim]:not(.in) resets to full-circumference offset (empty); the
     .in class animates back. */
  .dial-fg {
    stroke: var(--color-brand);
    stroke-dashoffset: calc(var(--off) * 1px);
    transition: stroke-dashoffset 1200ms var(--ease-out);
    transition-delay: var(--d);
  }
  :global([data-js-ready]) [data-anim]:not(.in) .dial-fg {
    stroke-dashoffset: calc(3.14159 * 44 * 1px);
  }
  .value {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 30px;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-brand);
  }
  .value sup {
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 500;
    font-size: 0.5em;
    top: -0.6em;
  }
  .label {
    max-width: 120px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1.3;
    text-align: center;
    color: var(--editorial-ink-muted);
  }
  .foot {
    margin-top: auto;
    padding-top: 18px;
    font-size: 11px;
    font-style: italic;
    line-height: 1.4;
    color: var(--editorial-ink-muted);
    border-top: 1px solid color-mix(in oklab, var(--editorial-ink) 10%, transparent);
  }
</style>
