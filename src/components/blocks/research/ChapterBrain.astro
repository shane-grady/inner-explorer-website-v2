---
// Chapter II — "The brain." Dark editorial section: sticky animated brain-network SVG
// (toggle stressed↔mindful) + editorial column with first-letter drop cap, pull quote
// between hairlines, inline brand-italic stats.

interface Props {
  eyebrow: string;
  label: string;
  headlineLines: { text: string; kind: 'sans' | 'serif'; tone?: 'default' | 'accent' }[];
  paragraphsBefore: string[];
  pullHtml: string; // may contain <em>...</em> for the brand accent
  paragraphsAfterHtml: string[]; // may contain <span class="inline-stat"> markup
}
const { eyebrow, label, headlineLines, paragraphsBefore, pullHtml, paragraphsAfterHtml }: Props =
  Astro.props;

// Brain SVG geometry (same nodes/edges as the prototype) — defined once at the top.
const nodes: [number, number][] = [
  [50, 18],
  [35, 25],
  [68, 28],
  [22, 42],
  [80, 40],
  [15, 60],
  [88, 60],
  [20, 78],
  [82, 78],
  [40, 85],
  [62, 88],
  [42, 38],
  [58, 36],
  [35, 52],
  [65, 54],
  [50, 50],
  [40, 65],
  [60, 66],
  [50, 72],
];
const edges: [number, number][] = [
  [0, 1],
  [0, 2],
  [1, 3],
  [2, 4],
  [3, 5],
  [4, 6],
  [5, 7],
  [6, 8],
  [7, 9],
  [8, 10],
  [9, 10],
  [0, 11],
  [0, 12],
  [11, 12],
  [11, 13],
  [12, 14],
  [13, 15],
  [14, 15],
  [15, 16],
  [15, 17],
  [16, 18],
  [17, 18],
  [9, 16],
  [10, 17],
  [1, 11],
  [2, 12],
  [3, 13],
  [4, 14],
  [5, 13],
  [6, 14],
  [7, 16],
  [8, 17],
];
---

<section class="brain" id="brain" aria-label={label}>
  <div class="brain-inner">
    <div class="chap-mark">
      <span class="num">{eyebrow}</span>
      <span class="rule"></span>
      <span class="label">{label}</span>
    </div>

    <h2 class="chap-title">
      {
        headlineLines.map((line) => (
          <span class:list={['stk', line.kind, { accent: line.tone === 'accent' }]}>
            {line.text}
          </span>
        ))
      }
    </h2>

    <div class="brain-grid">
      <div class="brain-viz">
        <svg
          viewBox="0 0 100 100"
          preserveAspectRatio="xMidYMid meet"
          data-state="mindful"
          id="brain-svg"
          aria-hidden="true"
        >
          <defs>
            <radialGradient id="brain-glow" cx="50%" cy="50%" r="60%">
              <stop offset="0%" class="bg-glow-stop"></stop>
              <stop offset="100%" stop-color="transparent"></stop>
            </radialGradient>
          </defs>
          <rect width="100" height="100" fill="url(#brain-glow)"></rect>
          {
            edges.map(([a, b], i) => (
              <line
                x1={nodes[a][0]}
                y1={nodes[a][1]}
                x2={nodes[b][0]}
                y2={nodes[b][1]}
                class="edge"
                style={`--i:${i}`}
              />
            ))
          }
          {
            nodes.map(([x, y], i) => (
              <g>
                <circle cx={x} cy={y} class="node" style={`--i:${i}`} />
                <circle cx={x} cy={y} class="node-halo" style={`--i:${i}`} />
              </g>
            ))
          }
        </svg>
        <div class="brain-toggle" role="tablist">
          <button type="button" data-state="stressed" id="brain-stressed">Stressed</button>
          <button type="button" data-state="mindful" id="brain-mindful" class="on">
            Mindful
          </button>
        </div>
      </div>
      <div class="brain-copy">
        {paragraphsBefore.map((p, i) => <p class:list={[{ dropcap: i === 0 }]}>{p}</p>)}
        <blockquote class="brain-pull" set:html={pullHtml} />
        {paragraphsAfterHtml.map((p) => <p class="after-p" set:html={p} />)}
      </div>
    </div>
  </div>
</section>

<style>
  .brain {
    background: var(--neutral-950);
    color: var(--color-white);
    padding: 140px 0 120px;
  }
  .brain-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .chap-mark {
    display: flex;
    align-items: baseline;
    gap: 18px;
    margin-bottom: 28px;
  }
  .chap-mark .num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 36px;
    line-height: 1;
    color: var(--brand-300);
  }
  .chap-mark .rule {
    flex: 1;
    height: 1px;
    background: color-mix(in oklab, var(--color-white) 18%, transparent);
    align-self: center;
  }
  .chap-mark .label {
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--color-white) 55%, transparent);
  }

  .chap-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(44px, 6vw, 88px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: 0 0 56px;
    text-wrap: balance;
  }
  .chap-title .stk {
    display: block;
  }
  .chap-title .sans {
    font-family: var(--font-sans);
    font-weight: 300;
    letter-spacing: -0.025em;
    font-style: normal;
  }
  .chap-title .serif {
    font-style: italic;
  }
  .chap-title .accent {
    color: var(--brand-300);
  }

  .brain-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: start;
  }

  .brain-viz {
    position: sticky;
    top: 140px;
    aspect-ratio: 1 / 1.1;
    border-radius: var(--radius-2xl);
    background: linear-gradient(
      165deg,
      color-mix(in oklab, var(--neutral-900) 80%, var(--brand-800)) 0%,
      var(--neutral-950) 100%
    );
    border: 1px solid color-mix(in oklab, var(--color-white) 6%, transparent);
    padding: 32px;
    overflow: hidden;
  }
  .brain-viz svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .brain-viz .bg-glow-stop {
    stop-color: color-mix(in oklab, var(--brand-300) 30%, transparent);
  }
  .brain-viz svg[data-state='stressed'] .bg-glow-stop {
    stop-color: color-mix(in oklab, var(--color-white) 4%, transparent);
  }

  /* Edges */
  .brain-viz .edge {
    stroke: var(--brand-300);
    stroke-width: 0.5;
    stroke-opacity: 0.8;
  }
  .brain-viz svg[data-state='stressed'] .edge {
    stroke: color-mix(in oklab, var(--color-white) 25%, transparent);
    stroke-width: 0.25;
    stroke-opacity: 0.4;
  }
  .brain-viz svg[data-state='mindful'] .edge {
    animation: edge-pulse calc(2.5s + (var(--i) * 0.07s)) ease-in-out infinite;
  }
  @keyframes edge-pulse {
    0%,
    100% {
      stroke-opacity: 0.4;
    }
    50% {
      stroke-opacity: 0.95;
    }
  }

  /* Nodes */
  .brain-viz .node {
    r: 1.4;
    fill: var(--brand-300);
  }
  .brain-viz svg[data-state='stressed'] .node {
    r: 0.9;
    fill: color-mix(in oklab, var(--color-white) 55%, transparent);
  }
  .brain-viz svg[data-state='mindful'] .node {
    animation: node-pulse 3s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.12s);
  }
  @keyframes node-pulse {
    0%,
    100% {
      r: 1.1;
    }
    50% {
      r: 1.8;
    }
  }

  .brain-viz .node-halo {
    r: 3;
    fill: var(--brand-300);
    opacity: 0;
  }
  .brain-viz svg[data-state='mindful'] .node-halo {
    opacity: 0.18;
    animation: halo-pulse 4s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.18s);
  }
  @keyframes halo-pulse {
    0%,
    100% {
      r: 2;
      opacity: 0.3;
    }
    50% {
      r: 5;
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brain-viz svg[data-state='mindful'] .edge,
    .brain-viz svg[data-state='mindful'] .node,
    .brain-viz svg[data-state='mindful'] .node-halo {
      animation: none;
    }
  }

  .brain-toggle {
    position: absolute;
    bottom: 24px;
    left: 24px;
    right: 24px;
    display: flex;
    background: color-mix(in oklab, var(--color-white) 6%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-white) 10%, transparent);
    border-radius: 9999px;
    padding: 4px;
  }
  .brain-toggle button {
    flex: 1;
    padding: 10px 16px;
    border-radius: 9999px;
    border: 0;
    background: transparent;
    color: color-mix(in oklab, var(--color-white) 60%, transparent);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: all var(--dur) var(--ease-out);
  }
  .brain-toggle button.on {
    background: var(--brand-300);
    color: var(--neutral-950);
  }

  .brain-copy {
    font-size: 18px;
    line-height: 1.7;
    color: color-mix(in oklab, var(--color-white) 85%, transparent);
  }
  .brain-copy p {
    margin: 0 0 22px;
    max-width: 580px;
  }
  .brain-copy p.dropcap::first-letter {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 110px;
    line-height: 0.85;
    float: left;
    color: var(--brand-300);
    padding-right: 14px;
    padding-top: 8px;
    margin-bottom: -10px;
  }
  .brain-pull {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-white);
    padding: 28px 0;
    border-top: 1px solid color-mix(in oklab, var(--color-white) 12%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--color-white) 12%, transparent);
    margin: 32px 0;
    max-width: 580px;
  }
  .brain-pull :global(em) {
    color: var(--brand-300);
  }
  .after-p :global(.inline-stat) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--brand-300);
    font-size: 1.15em;
  }

  @media (max-width: 920px) {
    .brain-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .brain-viz {
      position: relative;
      top: 0;
    }
  }
</style>

<script>
  // Toggle stressed↔mindful state on the brain SVG. CSS does the heavy lifting.
  const svg = document.getElementById('brain-svg');
  const btnS = document.getElementById('brain-stressed');
  const btnM = document.getElementById('brain-mindful');
  if (svg && btnS && btnM) {
    const set = (state: 'stressed' | 'mindful') => {
      svg.setAttribute('data-state', state);
      btnS.classList.toggle('on', state === 'stressed');
      btnM.classList.toggle('on', state === 'mindful');
    };
    btnS.addEventListener('click', () => set('stressed'));
    btnM.addEventListener('click', () => set('mindful'));
  }
</script>
