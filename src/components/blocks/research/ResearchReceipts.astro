---
export interface Study {
  id: string;
  year: number;
  tag: string;
  title: string;
  authors: string;
  institution: string;
  journal: string;
  leadStat: string;
  leadLabel: string;
}
interface Props {
  chapterLabel: string;
  chapterNumber: string;
  headingHtml: string;
  lede: string;
  studies: Study[];
}
const { chapterLabel, chapterNumber, headingHtml, lede, studies }: Props = Astro.props;
const sorted = [...studies].sort((a, b) => a.year - b.year);
---

<section
  class="receipts"
  id="receipts"
  data-screen-label={chapterLabel}
  aria-labelledby="receipts-heading"
>
  <div class="wrap">
    <div class="chap-mark reveal">
      <span class="chap-num">{chapterNumber}</span>
      <span class="chap-rule" aria-hidden="true"></span>
      <span class="chap-label">{chapterLabel}</span>
    </div>
    <div class="intro reveal">
      <h2 class="chap-title" id="receipts-heading" set:html={headingHtml} />
      <p class="lede">{lede}</p>
    </div>
    <ol class="rows">
      {
        sorted.map((s) => {
          const doctoral = s.tag.toLowerCase().includes('doctoral');
          return (
            <li class="row reveal" id={`r-${s.id}`}>
              <div class="row-year">{s.year}</div>
              <div class="row-mid">
                <span class:list={['tag', { doctoral }]}>{s.tag}</span>
                <h3 class="row-title">{s.title}</h3>
                <p class="row-meta">
                  <strong>{s.authors}</strong> · {s.institution} · <em>{s.journal}</em>
                </p>
              </div>
              <div class="row-finding">
                <div class="row-finding-stat">{s.leadStat}</div>
                <div class="row-finding-label">{s.leadLabel}</div>
              </div>
            </li>
          );
        })
      }
    </ol>
  </div>
</section>

<style>
  .receipts {
    position: relative;
    padding: 140px 0 120px;
    background: var(--editorial-paper);
    color: var(--editorial-ink);
  }
  .wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .chap-mark {
    display: flex;
    align-items: baseline;
    gap: 18px;
    margin-bottom: 28px;
  }
  .chap-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 36px;
    line-height: 1;
    color: var(--color-brand);
  }
  .chap-rule {
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.18;
    align-self: center;
  }
  .chap-label {
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    opacity: 0.55;
  }
  .intro {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 64px;
    align-items: end;
    margin-bottom: 80px;
  }
  .chap-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(44px, 6vw, 88px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }
  .chap-title :global(em) {
    font-style: italic;
    color: var(--color-brand);
    font-weight: 500;
  }
  .chap-title :global(.sans) {
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 300;
    letter-spacing: -0.025em;
  }
  .chap-title :global(.stk) {
    display: block;
  }
  .lede {
    margin: 0 0 8px;
    max-width: 480px;
    font-size: 19px;
    line-height: 1.6;
    color: var(--editorial-ink-muted);
  }

  .rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .row {
    display: grid;
    grid-template-columns: 200px 1fr 320px;
    gap: 40px;
    align-items: center;
    padding: 40px 0;
    border-top: 1px solid color-mix(in oklab, var(--editorial-ink) 12%, transparent);
    transition: background 400ms var(--ease-out);
  }
  .row:last-child {
    border-bottom: 1px solid color-mix(in oklab, var(--editorial-ink) 12%, transparent);
  }
  .row:hover {
    background: color-mix(in oklab, var(--editorial-ink) 3%, transparent);
  }
  .row:hover .row-year {
    color: var(--color-brand);
    transform: translateX(-6px);
  }
  .row-year {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(72px, 9vw, 140px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--editorial-ink);
    transition: all 400ms var(--ease-out);
  }
  .row-mid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand);
  }
  .tag::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-brand);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--color-brand) 18%, transparent);
  }
  .tag.doctoral {
    color: var(--editorial-ink-muted);
  }
  .tag.doctoral::before {
    background: var(--editorial-ink-muted);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--editorial-ink) 8%, transparent);
  }
  .row-title {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--editorial-ink);
  }
  .row-meta {
    margin: 0;
    font-size: 13px;
    line-height: 1.45;
    color: var(--editorial-ink-muted);
  }
  .row-meta strong {
    color: var(--editorial-ink);
    font-weight: 500;
  }

  .row-finding {
    position: relative;
    padding: 18px 22px;
    background: var(--editorial-ink);
    color: var(--editorial-paper);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow: hidden;
  }
  .row-finding::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 90% 100%,
      color-mix(in oklab, var(--editorial-glow) 20%, transparent),
      transparent 60%
    );
    pointer-events: none;
  }
  .row-finding-stat {
    position: relative;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 44px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--editorial-glow);
  }
  .row-finding-label {
    position: relative;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.4;
    color: color-mix(in oklab, var(--editorial-paper) 85%, transparent);
  }

  /* Reveal-on-scroll — content is fully visible by default. When JS is ready
     (intersect.ts sets data-js-ready on <html>), not-yet-revealed items hide
     to their initial state; the .in class then animates them back. */
  .reveal {
    opacity: 1;
    transform: none;
    transition:
      opacity 900ms var(--ease-out),
      transform 900ms var(--ease-out);
  }
  :global([data-js-ready]) .reveal:not(.in) {
    opacity: 0;
    transform: translateY(28px);
  }

  @media (max-width: 820px) {
    .intro {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .row {
      grid-template-columns: 1fr;
      gap: 18px;
      padding: 28px 0;
    }
    .row-year {
      font-size: 64px;
    }
  }
</style>

<script>
  import { observe } from '../../../lib/intersect';
  observe('.receipts .reveal');
</script>
