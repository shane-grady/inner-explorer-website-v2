---
interface Props {
  eyebrow: string;
  lines: string[];
  emphasisIndex?: number;
}
const { eyebrow, lines, emphasisIndex = lines.length - 1 }: Props = Astro.props;
---

<section class="void" id="open" data-screen-label="Opening" aria-labelledby="void-statement">
  <span class="void-eyebrow">{eyebrow}</span>
  <p class="void-statement" id="void-statement">
    {lines.map((line, i) => <span class:list={['stk', { em: i === emphasisIndex }]}>{line}</span>)}
  </p>
  <div class="void-scroll" aria-hidden="true">
    <span>Scroll</span>
    <span class="void-scroll-line"></span>
  </div>
</section>

<style>
  .void {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 140px 32px 80px;
    text-align: center;
    background: var(--editorial-night);
    color: var(--editorial-paper);
    overflow: hidden;
  }
  .void::before,
  .void::after {
    content: '';
    position: absolute;
    width: 70%;
    height: 70%;
    pointer-events: none;
  }
  .void::before {
    inset: -20% -20% auto auto;
    background: radial-gradient(
      circle,
      color-mix(in oklab, var(--editorial-glow) 18%, transparent),
      transparent 60%
    );
  }
  .void::after {
    inset: auto auto -20% -20%;
    background: radial-gradient(
      circle,
      color-mix(in oklab, var(--brand-700) 30%, transparent),
      transparent 60%
    );
  }
  .void-eyebrow {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 56px;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--editorial-glow);
  }
  .void-eyebrow::before,
  .void-eyebrow::after {
    content: '';
    width: 28px;
    height: 1px;
    background: color-mix(in oklab, var(--editorial-glow) 50%, transparent);
  }
  .void-statement {
    position: relative;
    margin: 0;
    max-width: 1000px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(40px, 6vw, 88px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--editorial-paper);
    text-wrap: balance;
  }
  .stk {
    display: block;
  }
  .em {
    color: var(--editorial-glow);
  }
  .void-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--editorial-paper) 45%, transparent);
  }
  .void-scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(
      to bottom,
      transparent,
      color-mix(in oklab, var(--editorial-paper) 40%, transparent),
      transparent
    );
    animation: voidPulse 2s ease-in-out infinite;
  }
  @keyframes voidPulse {
    0%,
    100% {
      opacity: 0.4;
      transform: scaleY(1);
    }
    50% {
      opacity: 1;
      transform: scaleY(1.2);
    }
  }
</style>
