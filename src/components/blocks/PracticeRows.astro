---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Numbered photo-strip rows (60px num · 200px image · title/meta · play · arrow).
// Editorial alternative to a card grid. Reusable on future Practices index pages.

export interface Practice {
  title: string;
  meta: string;
  image: ImageMetadata;
  href?: string;
}
interface Props {
  eyebrow?: string;
  headingHtml: string;
  practices: Practice[];
}
const { eyebrow, headingHtml, practices }: Props = Astro.props;
---

<section class="rows">
  <div class="head">
    {eyebrow && <span class="eb">{eyebrow}</span>}
    <h2 class="hd" set:html={headingHtml} />
  </div>

  <div class="list">
    {
      practices.map((p, i) => (
        <a class="row" href={p.href ?? '#'}>
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <div class="img-wrap">
            <Image src={p.image} alt="" widths={[280, 400]} sizes="200px" loading="lazy" />
          </div>
          <div class="body">
            <h3 class="title">{p.title}</h3>
            <span class="meta">{p.meta}</span>
          </div>
          <span class="play" aria-label={`Preview ${p.title}`}>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
          <span class="arrow" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .rows {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 32px 80px;
  }
  .head {
    margin-bottom: 48px;
    max-width: 800px;
  }
  .eb {
    display: block;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-muted-foreground);
  }
  .hd {
    margin: 14px 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(36px, 4.4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-foreground);
    text-wrap: balance;
  }
  .hd :global(.sans) {
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 500;
    color: var(--color-muted-foreground);
    letter-spacing: -0.025em;
  }

  .list {
    display: flex;
    flex-direction: column;
  }
  .row {
    display: grid;
    grid-template-columns: 60px 200px 1fr auto auto;
    align-items: center;
    gap: 28px;
    padding: 20px 4px;
    border-top: 1px solid var(--color-border);
    color: var(--color-foreground);
    transition:
      background var(--dur) var(--ease-out),
      padding var(--dur) var(--ease-out);
  }
  .row:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .row:hover {
    background: var(--color-background);
    padding-left: 16px;
    padding-right: 16px;
  }
  .num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 32px;
    line-height: 1;
    color: var(--color-muted-foreground);
  }
  .img-wrap {
    width: 200px;
    height: 110px;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-muted);
  }
  .img-wrap :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .title {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(24px, 2.4vw, 32px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }
  .meta {
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted-foreground);
  }
  .play {
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    background: var(--brand-100);
    color: var(--brand-700);
    border: 1px solid color-mix(in oklab, var(--color-brand) 18%, transparent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding-left: 2px;
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }
  .row:hover .play {
    background: var(--color-brand);
    color: var(--color-brand-foreground);
  }
  .arrow {
    width: 32px;
    height: 32px;
    color: var(--color-muted-foreground);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      transform var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }
  .row:hover .arrow {
    color: var(--color-foreground);
    transform: translateX(4px);
  }

  @media (max-width: 920px) {
    .rows {
      padding: 32px 16px 56px;
    }
    .row {
      grid-template-columns: 84px 1fr auto;
      gap: 14px;
      padding: 14px 4px;
    }
    .num {
      display: none;
    }
    .img-wrap {
      width: 84px;
      height: 84px;
      border-radius: var(--radius-sm);
    }
    .arrow {
      display: none;
    }
    .title {
      font-size: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .row,
    .play,
    .arrow {
      transition: none;
    }
    .row:hover {
      padding-left: 4px;
      padding-right: 4px;
    }
    .row:hover .arrow {
      transform: none;
    }
  }
</style>
