---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Wide editorial photo hero with corner labels and an italic-serif pull-quote
// overlay. 21:9 capped at 520px tall to keep it cinematic without dominating.
// Reusable for narrator profiles, staff pages, research vignettes, curriculum.

interface Props {
  photo: ImageMetadata;
  alt: string;
  cornerLeft?: string;
  cornerRight?: string;
  quote?: {
    text: string;
    attribution: string;
  };
  /** Optional view-transition name shared with the wall card photo. */
  transitionName?: string;
}
const { photo, alt, cornerLeft, cornerRight, quote, transitionName }: Props = Astro.props;
---

<section class="hero-wrap">
  <figure class="hero">
    <Image
      class="img"
      src={photo}
      alt={alt}
      widths={[760, 1100, 1600]}
      sizes="(max-width: 920px) 100vw, 1100px"
      loading="eager"
      fetchpriority="high"
      transition:name={transitionName}
    />
    <div class="grad" aria-hidden="true"></div>

    {
      cornerLeft && (
        <div class="corner top-left" aria-hidden="true">
          <span class="dot" />
          {cornerLeft}
        </div>
      )
    }
    {
      cornerRight && (
        <div class="corner top-right" aria-hidden="true">
          {cornerRight}
        </div>
      )
    }

    {
      quote && (
        <figcaption class="quote">
          <span class="mark" aria-hidden="true">
            &ldquo;
          </span>
          <p>{quote.text}</p>
          <span class="attrib">{quote.attribution}</span>
        </figcaption>
      )
    }
  </figure>
</section>

<style>
  .hero-wrap {
    padding: 16px 32px 28px;
  }
  .hero {
    position: relative;
    margin: 0 auto;
    max-width: 1280px;
    aspect-ratio: 21 / 9;
    max-height: 520px;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    background: var(--color-muted);
    box-shadow: var(--shadow-lg);
  }
  .img,
  .hero :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.94) saturate(1.05);
  }
  .grad {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        170deg,
        transparent 0%,
        transparent 45%,
        color-mix(in oklab, var(--color-black) 35%, transparent) 75%,
        color-mix(in oklab, var(--color-black) 72%, transparent) 100%
      ),
      linear-gradient(
        80deg,
        color-mix(in oklab, var(--color-black) 18%, transparent) 0%,
        transparent 50%
      );
  }

  .corner {
    position: absolute;
    top: 22px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--color-white) 8%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid color-mix(in oklab, var(--color-white) 18%, transparent);
    color: var(--color-white);
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .corner.top-left {
    left: 22px;
  }
  .corner.top-right {
    right: 22px;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 9999px;
    background: var(--brand-300);
    box-shadow: 0 0 8px color-mix(in oklab, var(--brand-300) 70%, transparent);
  }

  .quote {
    position: absolute;
    left: 36px;
    right: 36px;
    bottom: 32px;
    max-width: 540px;
    color: var(--color-white);
  }
  .mark {
    display: block;
    margin-bottom: -22px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(64px, 7vw, 96px);
    line-height: 0.6;
    color: color-mix(in oklab, var(--color-white) 55%, transparent);
  }
  .quote p {
    margin: 0 0 10px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(20px, 2.2vw, 24px);
    line-height: 1.32;
    letter-spacing: -0.005em;
    color: var(--color-white);
    text-wrap: pretty;
  }
  .attrib {
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: color-mix(in oklab, var(--color-white) 85%, transparent);
  }

  @media (max-width: 920px) {
    .hero-wrap {
      padding: 12px 16px 20px;
    }
    .hero {
      aspect-ratio: 4 / 5;
      max-height: none;
    }
    .quote {
      left: 22px;
      right: 22px;
      bottom: 24px;
    }
    .corner {
      top: 16px;
      padding: 6px 12px;
      font-size: 9.5px;
    }
    .corner.top-left {
      left: 16px;
    }
    .corner.top-right {
      right: 16px;
    }
  }
</style>
