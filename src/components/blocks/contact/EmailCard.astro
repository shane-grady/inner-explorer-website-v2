---
// Email-card body. Sits inside a subtle ContactCard.
//
// Three triaged email rows (General / Support / Press), each with a clickable
// mailto:, a short qualifier, and a copy-to-clipboard icon button that dispatches
// `contact:toast` to the page-level toast handler.

interface EmailItem {
  label: string;
  email: string;
  description: string;
}
interface Props {
  emails: EmailItem[];
}
const { emails }: Props = Astro.props;
---

<ul class="email-list">
  {
    emails.map((it) => (
      <li class="email-item">
        <span class="row-label">{it.label}</span>
        <a class="row-email" href={`mailto:${it.email}`}>
          {it.email}
        </a>
        <span class="row-desc">· {it.description}</span>
        <button
          type="button"
          class="row-copy"
          data-copy={it.email}
          data-copy-label={`${it.email}`}
          aria-label={`Copy ${it.email}`}
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="9" y="9" width="13" height="13" rx="2" />
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
          </svg>
        </button>
      </li>
    ))
  }
</ul>

<style>
  .email-list {
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .email-item {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.4;
    color: var(--color-muted-foreground);
  }
  .row-label {
    min-width: 96px;
    font-weight: 500;
    color: var(--color-foreground);
  }
  .row-email {
    color: var(--color-foreground);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid var(--color-border);
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .row-email:hover {
    color: var(--color-brand-emphasis);
    border-color: var(--color-brand-emphasis);
  }
  .row-desc {
    font-size: 13px;
    color: var(--color-muted-foreground);
  }
  .row-copy {
    margin-left: auto;
    background: transparent;
    border: 0;
    padding: 6px;
    border-radius: 6px;
    color: var(--color-muted-foreground);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .row-copy:hover {
    color: var(--color-foreground);
  }
  .row-copy svg {
    width: 14px;
    height: 14px;
  }

  @media (max-width: 540px) {
    .row-label {
      min-width: 0;
      flex-basis: 100%;
    }
  }
</style>
