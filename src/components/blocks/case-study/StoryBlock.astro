---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { ValueLabel } from './types';

// Editorial narrative split: a text column (eyebrow + heading + paragraphs) beside a
// tall photo with an optional glass stat chip. `reversed` flips the column order for
// rhythm (Challenge left-text, Approach right-text). Broadly reusable for any
// "story + supporting image" section.
interface Props {
  eyebrow: string;
  heading: string;
  body: string[];
  image: ImageMetadata;
  imageAlt: string;
  statChip?: ValueLabel;
  reversed?: boolean;
  id?: string;
}
const {
  eyebrow,
  heading,
  body,
  image,
  imageAlt,
  statChip,
  reversed = false,
  id,
}: Props = Astro.props;
---

<section class="story" id={id}>
  <div class="wrap">
    <div class:list={['grid', { reversed }]}>
      <div class="text" data-cs-reveal>
        <span class="eyebrow">{eyebrow}</span>
        <h2 class="h2">{heading}</h2>
        {body.map((p) => <p>{p}</p>)}
      </div>
      <div class="media" data-cs-reveal>
        <Image
          class="img"
          src={image}
          alt={imageAlt}
          widths={[560, 900, 1200]}
          sizes="(max-width: 880px) 100vw, 560px"
          loading="lazy"
        />
        {
          statChip && (
            <div class="chip">
              <div class="v">{statChip.value}</div>
              <div class="l">{statChip.label}</div>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .story {
    padding-top: clamp(72px, 9vw, 132px);
  }
  .wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 64px);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
  }
  .grid.reversed .text {
    order: 2;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-brand-emphasis);
  }
  .eyebrow::before {
    content: '';
    width: 22px;
    height: 1.5px;
    background: var(--color-brand-emphasis);
  }
  .h2 {
    margin: 18px 0 0;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(30px, 4.2vw, 46px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
    text-wrap: balance;
  }
  .text p {
    margin: 18px 0 0;
    font-size: 17px;
    line-height: 1.72;
    color: var(--color-foreground);
  }
  .text p:first-of-type {
    margin-top: 22px;
  }

  .media {
    position: relative;
  }
  .img {
    width: 100%;
    aspect-ratio: 5 / 6;
    object-fit: cover;
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-lg);
  }
  .chip {
    position: absolute;
    right: -16px;
    bottom: -16px;
    max-width: 230px;
    padding: 18px 22px;
    background: var(--glass-bg-strong);
    -webkit-backdrop-filter: blur(var(--glass-blur));
    backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-glass);
  }
  .chip .v {
    font-weight: 600;
    font-size: 30px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-brand-emphasis);
  }
  .chip .l {
    margin-top: 6px;
    font-size: 13px;
    line-height: 1.45;
    color: var(--color-muted-foreground);
  }

  @media (max-width: 880px) {
    .grid,
    .grid.reversed {
      grid-template-columns: 1fr;
    }
    .grid.reversed .text {
      order: 0;
    }
    .chip {
      right: 12px;
    }
  }
</style>
