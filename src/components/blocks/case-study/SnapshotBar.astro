---
import type { ValueLabel } from './types';

// "District at a glance" — a glass card of N stats with hairline dividers, sitting
// just below the case-study hero. Static (no count-up): the values mix numeric and
// non-numeric ("PreK–12", "4 yrs"), and the dramatic count-up belongs to ResultsBand.
// Reusable across every case study; column count derives from the data.
interface Props {
  stats: ValueLabel[];
  ariaLabel?: string;
}
const { stats, ariaLabel = 'District at a glance' }: Props = Astro.props;
---

<section class="snapshot" aria-label={ariaLabel} data-cs-reveal>
  <div class="card" style={`--n: ${stats.length}`}>
    {
      stats.map((s) => (
        <div class="cell">
          <div class="val">{s.value}</div>
          <div class="lbl">{s.label}</div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .snapshot {
    position: relative;
    z-index: 5;
    max-width: 1180px;
    margin: clamp(40px, 6vw, 72px) auto 0;
    padding-inline: clamp(20px, 5vw, 64px);
  }
  .card {
    display: grid;
    grid-template-columns: repeat(var(--n, 5), 1fr);
    gap: 16px;
    padding: clamp(22px, 3vw, 34px) clamp(20px, 3vw, 40px);
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(var(--glass-blur));
    backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-glass);
  }
  .cell {
    position: relative;
    text-align: center;
    padding: 6px 8px;
  }
  /* Partial-height hairline between cells. */
  .cell + .cell::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12%;
    height: 76%;
    width: 1px;
    background: var(--color-border);
  }
  .val {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-brand-emphasis);
  }
  .lbl {
    margin-top: 8px;
    font-size: 12.5px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-muted-foreground);
  }

  @media (max-width: 760px) {
    .card {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px 16px;
    }
    .cell + .cell::before {
      display: none;
    }
  }
</style>
