---
import type { Pillar, PillarIcon } from './types';

// Crafted "approach" cards: a gradient icon chip with an inset rim, a large serif-italic
// index (01/02/03) in the brand display face, then title + text. Deliberately not the
// generic number-bubble card. Icons are referenced by name (CMS-friendly strings) and
// resolved from a small inline-SVG registry here.
interface Props {
  items: Pillar[];
}
const { items }: Props = Astro.props;

// Lucide-style glyphs matching the prototype (play / repeat / bar-chart), plus
// calendar / palette / heart / compass for implementation-strategy pillars.
const ICONS: Record<PillarIcon, string> = {
  play: '<polygon points="6 3 20 12 6 21 6 3" fill="currentColor" stroke="none"></polygon>',
  repeat:
    '<path d="m17 2 4 4-4 4"></path><path d="M3 11v-1a4 4 0 0 1 4-4h14"></path><path d="m7 22-4-4 4-4"></path><path d="M21 13v1a4 4 0 0 1-4 4H3"></path>',
  chart:
    '<path d="M3 3v18h18"></path><rect x="7" y="12" width="3" height="6" rx="1"></rect><rect x="12" y="8" width="3" height="10" rx="1"></rect><rect x="17" y="4" width="3" height="14" rx="1"></rect>',
  calendar:
    '<rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4"></path><path d="M8 2v4"></path><path d="M3 10h18"></path>',
  palette:
    '<circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"></circle><circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"></circle><circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"></circle><circle cx="6.5" cy="12.5" r="0.5" fill="currentColor"></circle><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"></path>',
  heart:
    '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>',
  compass:
    '<circle cx="12" cy="12" r="10"></circle><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>',
};
---

<section class="pillars">
  <div class="wrap">
    <div class="grid">
      {
        items.map((p, i) => (
          <div class="pillar" data-cs-reveal>
            <div class="top">
              <span class="icon">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={ICONS[p.icon] ?? ICONS.play}
                />
              </span>
              <span class="idx">{String(i + 1).padStart(2, '0')}</span>
            </div>
            <h3 class="title">{p.title}</h3>
            <p class="text">{p.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Sits just under the Approach story (a tight gap — part of the same section). */
  .pillars {
    margin-top: clamp(28px, 4vw, 44px);
  }
  .wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 64px);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  /* Four pillars read better as a 2×2 (and their copy gets a wider measure). */
  .grid:has(> :nth-child(4)) {
    grid-template-columns: repeat(2, 1fr);
  }
  .grid:has(> :nth-child(4)) .text {
    max-width: 52ch;
  }
  .pillar {
    position: relative;
    overflow: hidden;
    padding: 28px 26px 30px;
    border-radius: var(--radius-xl);
    background: var(--color-card);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out);
  }
  /* Top-edge light catch. */
  .pillar::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in oklab, var(--color-white) 90%, transparent) 35%,
      color-mix(in oklab, var(--color-white) 90%, transparent) 65%,
      transparent
    );
    pointer-events: none;
  }
  .pillar:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--brand-200);
  }

  .top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .icon {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: var(--radius-sm);
    color: var(--color-brand-emphasis);
    background: linear-gradient(
      155deg,
      var(--brand-100),
      color-mix(in oklab, var(--brand-200) 45%, var(--color-white))
    );
    box-shadow:
      inset 0 0 0 1px color-mix(in oklab, var(--color-brand) 16%, transparent),
      inset 0 1px 0 color-mix(in oklab, var(--color-white) 75%, transparent);
    transition: transform var(--dur) var(--ease-out);
  }
  .icon svg {
    width: 22px;
    height: 22px;
  }
  .pillar:hover .icon {
    transform: scale(1.06);
  }
  .idx {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 42px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--brand-200);
    transition: color var(--dur) var(--ease-out);
  }
  .pillar:hover .idx {
    color: var(--brand-300);
  }
  .title {
    margin: 24px 0 0;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 18.5px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
  }
  .text {
    margin: 10px 0 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--color-muted-foreground);
    max-width: 30ch;
  }

  @media (max-width: 760px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
