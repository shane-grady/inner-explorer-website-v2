---
import { Image } from 'astro:assets';
import type { GalleryImage } from './types';

// A deliberate, fully-tiled photo mosaic (the designer's landed direction — not
// auto-flow masonry, which left holes). With exactly six photos it composes a square
// hero + wide banner + paired tiles + two wide tiles, every cell filled. For any other
// count it falls back to a clean uniform grid. `object-fit: cover` keeps mismatched
// sources consistent; a hairline rim + calm hover lift/zoom add polish.
interface Props {
  eyebrow: string;
  heading: string;
  images: GalleryImage[];
  id?: string;
}
const { eyebrow, heading, images, id }: Props = Astro.props;
const deliberate = images.length === 6;
---

<section class="gallery" id={id}>
  <div class="wrap">
    <div class="head" data-cs-reveal>
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="h2">{heading}</h2>
    </div>
    <div class:list={['grid', { deliberate }]} data-cs-reveal>
      {
        images.map((im) => (
          <figure class="item">
            <Image
              src={im.src}
              alt={im.alt}
              widths={[400, 700, 1100]}
              sizes="(max-width: 480px) 100vw, (max-width: 860px) 50vw, 33vw"
              loading="lazy"
            />
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .gallery {
    padding-top: clamp(72px, 9vw, 132px);
  }
  .wrap {
    max-width: 1340px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 64px);
  }
  .head {
    max-width: 640px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-brand-emphasis);
  }
  .eyebrow::before {
    content: '';
    width: 22px;
    height: 1.5px;
    background: var(--color-brand-emphasis);
  }
  .h2 {
    margin: 18px 0 0;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(30px, 4.2vw, 46px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
    text-wrap: balance;
  }

  .grid {
    margin-top: clamp(36px, 4vw, 52px);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: clamp(190px, 18vw, 268px);
    gap: 16px;
  }
  /* Deliberate 4×3 composition for exactly six photos. */
  .grid.deliberate {
    grid-template-columns: repeat(4, 1fr);
  }
  .grid.deliberate .item:nth-child(1) {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }
  .grid.deliberate .item:nth-child(2) {
    grid-column: 3 / 5;
    grid-row: 1;
  }
  .grid.deliberate .item:nth-child(3) {
    grid-column: 3;
    grid-row: 2;
  }
  .grid.deliberate .item:nth-child(4) {
    grid-column: 4;
    grid-row: 2;
  }
  .grid.deliberate .item:nth-child(5) {
    grid-column: 1 / 3;
    grid-row: 3;
  }
  .grid.deliberate .item:nth-child(6) {
    grid-column: 3 / 5;
    grid-row: 3;
  }

  .item {
    position: relative;
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition:
      transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  /* Hairline "light-catching" rim keeps every tile crisp. */
  .item::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow:
      inset 0 0 0 1px color-mix(in oklab, var(--color-white) 18%, transparent),
      inset 0 1px 0 color-mix(in oklab, var(--color-white) 35%, transparent);
    pointer-events: none;
  }
  .item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .item:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .item:hover :global(img) {
    transform: scale(1.04);
  }

  @media (max-width: 860px) {
    .grid,
    .grid.deliberate {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-flow: dense;
      grid-auto-rows: clamp(160px, 30vw, 230px);
    }
    .grid.deliberate .item:nth-child(n) {
      grid-column: auto;
      grid-row: auto;
    }
    .grid.deliberate .item:nth-child(1) {
      grid-column: span 2;
      grid-row: span 2;
    }
    .grid.deliberate .item:nth-child(5) {
      grid-column: span 2;
    }
  }
  @media (max-width: 480px) {
    .grid,
    .grid.deliberate {
      grid-template-columns: 1fr;
      grid-auto-rows: clamp(190px, 56vw, 240px);
    }
    .grid.deliberate .item:nth-child(n) {
      grid-column: auto;
      grid-row: auto;
    }
    .grid.deliberate .item:nth-child(1) {
      grid-row: span 2;
    }
  }
</style>
