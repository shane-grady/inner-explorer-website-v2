---
// Centralized meta: canonical, Open Graph, Twitter. Rendered once in BaseLayout.
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
}
const {
  title,
  description,
  image = '/og-default.png',
  type = 'website',
  canonical,
}: Props = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const imageURL = new URL(image, Astro.site).href;
---

<link rel="canonical" href={canonicalURL} />
{description && <meta name="description" content={description} />}

<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={imageURL} />
<meta property="og:site_name" content="Inner Explorer" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
<meta name="twitter:image" content={imageURL} />
