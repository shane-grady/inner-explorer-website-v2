---
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/primitives/Container.astro';
import Section from '../../components/layout/Section.astro';
import Stack from '../../components/layout/Stack.astro';
import Heading from '../../components/primitives/Heading.astro';
import Text from '../../components/primitives/Text.astro';
import Button from '../../components/primitives/Button.astro';
import Badge from '../../components/primitives/Badge.astro';
import Link from '../../components/primitives/Link.astro';
import Counter from '../../components/islands/Counter';

const swatches = [
  { name: 'background', cls: 'bg-background', text: 'text-foreground' },
  { name: 'card', cls: 'bg-card', text: 'text-card-foreground' },
  { name: 'muted', cls: 'bg-muted', text: 'text-muted-foreground' },
  { name: 'brand', cls: 'bg-brand', text: 'text-brand-foreground' },
  { name: 'brand-subtle', cls: 'bg-brand-subtle', text: 'text-brand' },
  { name: 'brand-emphasis', cls: 'bg-brand-emphasis', text: 'text-brand-foreground' },
  { name: 'accent', cls: 'bg-accent', text: 'text-accent-foreground' },
  { name: 'accent-subtle', cls: 'bg-accent-subtle', text: 'text-accent' },
  { name: 'success', cls: 'bg-success', text: 'text-success-foreground' },
  { name: 'warning', cls: 'bg-warning', text: 'text-warning-foreground' },
  { name: 'danger', cls: 'bg-danger', text: 'text-danger-foreground' },
  { name: 'info', cls: 'bg-info', text: 'text-info-foreground' },
];

const typeRamp = [
  { cls: 'text-5xl', label: 'text-5xl · display' },
  { cls: 'text-4xl', label: 'text-4xl' },
  { cls: 'text-3xl', label: 'text-3xl' },
  { cls: 'text-2xl', label: 'text-2xl' },
  { cls: 'text-xl', label: 'text-xl' },
  { cls: 'text-lg', label: 'text-lg' },
  { cls: 'text-base', label: 'text-base · body' },
  { cls: 'text-sm', label: 'text-sm' },
  { cls: 'text-xs', label: 'text-xs' },
];

const buttonVariants = ['solid', 'outline', 'ghost', 'link'] as const;
const buttonTones = ['brand', 'accent', 'neutral'] as const;
---

<PageLayout title="Style Guide — Inner Explorer" description="Design tokens and component catalog.">
  <Section space="md">
    <Container>
      <Badge tone="brand">Design system</Badge>
      <Heading as="h1" size="xl" class="mt-4">Style Guide</Heading>
      <Text size="lg" tone="muted" class="mt-3 max-w-2xl">
        The single source of truth for Inner Explorer's interface. Every color, size, and space
        below is a design token. Reuse these components — do not hand-roll new ones.
      </Text>
    </Container>
  </Section>

  <Section space="sm" surface="muted">
    <Container>
      <Heading as="h2" size="md">Color tokens</Heading>
      <Text tone="muted" class="mt-2">Semantic only — there is no raw palette in components.</Text>
      <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {
          swatches.map((s) => (
            <figure class="overflow-hidden rounded-lg border border-border bg-card">
              <div class={`flex h-20 items-center justify-center ${s.cls} ${s.text}`}>
                <span class="font-serif text-2xl">Aa</span>
              </div>
              <figcaption class="px-3 py-2">
                <Text size="sm" weight="medium">
                  {s.name}
                </Text>
                <code class="text-xs text-muted-foreground">{s.cls}</code>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </Container>
  </Section>

  <Section space="sm">
    <Container>
      <Heading as="h2" size="md">Type ramp</Heading>
      <Text tone="muted" class="mt-2"
        >Fluid (clamp). Use Heading / Text — never raw font sizes.</Text
      >
      <Stack gap="md" class="mt-6">
        {
          typeRamp.map((t) => (
            <div class="flex flex-wrap items-baseline gap-x-4 border-b border-border pb-3">
              <p class={`${t.cls} font-serif text-foreground`}>The quiet mind</p>
              <code class="text-xs text-muted-foreground">{t.label}</code>
            </div>
          ))
        }
      </Stack>
    </Container>
  </Section>

  <Section space="sm" surface="muted">
    <Container>
      <Heading as="h2" size="md">Buttons</Heading>
      <Stack gap="lg" class="mt-6">
        {
          buttonVariants.map((variant) => (
            <div>
              <Text size="sm" tone="muted" weight="medium" class="mb-3 capitalize">
                {variant}
              </Text>
              <div class="flex flex-wrap items-center gap-3">
                {buttonTones.map((tone) => (
                  <Button variant={variant} tone={tone}>
                    Begin practice
                  </Button>
                ))}
              </div>
            </div>
          ))
        }
        <div>
          <Text size="sm" tone="muted" weight="medium" class="mb-3">Sizes</Text>
          <div class="flex flex-wrap items-center gap-3">
            <Button size="sm">Small</Button>
            <Button size="md">Medium</Button>
            <Button size="lg">Large</Button>
          </div>
        </div>
      </Stack>
    </Container>
  </Section>

  <Section space="sm">
    <Container>
      <div class="grid gap-10 sm:grid-cols-2">
        <div>
          <Heading as="h2" size="md">Badges</Heading>
          <div class="mt-4 flex flex-wrap gap-3">
            <Badge tone="brand">Brand</Badge>
            <Badge tone="accent">Accent</Badge>
            <Badge tone="neutral">Neutral</Badge>
            <Badge tone="outline">Outline</Badge>
          </div>
        </div>
        <div>
          <Heading as="h2" size="md">Links</Heading>
          <div class="mt-4 flex flex-col gap-2">
            <Link href="#">Default link</Link>
            <Link href="#" variant="subtle">Subtle link</Link>
            <Link href="#" variant="nav">Nav link</Link>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section space="sm" surface="muted">
    <Container>
      <Heading as="h2" size="md">Interactive island (React)</Heading>
      <Text tone="muted" class="mt-2">
        Hydrated with <code class="text-sm">client:visible</code>. Marketing pages ship zero JS —
        reach for a React island only when interactivity is genuinely needed.
      </Text>
      <div class="mt-6">
        <Counter client:visible />
      </div>
    </Container>
  </Section>
</PageLayout>
