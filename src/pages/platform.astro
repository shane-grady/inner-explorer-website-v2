const pageTitle = 'Platform — daily mindfulness for every classroom | Inner Explorer';
const pageDescription =
  'One platform, three connected apps — the Classroom practice player, the District impact dashboard, and the Home family app — bringing daily, research-backed mindfulness to K-12.';

const base = new URL(Astro.site ?? 'https://www.innerexplorer.org').origin;
const platformLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  url: `${base}/platform`,
  description: pageDescription,
  isPartOf: { '@type': 'WebSite', name: 'Inner Explorer', url: base },
  about: {
    '@type': 'ItemList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Classroom app' },
      { '@type': 'ListItem', position: 2, name: 'District dashboard' },
      { '@type': 'ListItem', position: 3, name: 'Home family app' },
    ],
  },
};
---

<PageLayout title={pageTitle} description={pageDescription} flushTop>
  <JsonLd slot="head" schema={platformLd} />

  <div class="appearance-light">
    <PlatformHero {...hero} />
    <TrustLogos {...trust} />
    <PlatformTrio {...trio} />
    <FeatureSection {...classroom} />
    <FeatureSection {...district} />
    <FeatureSection {...home} />
    <SignOn {...signOn} />
    <ImpactStories {...impact} />
    <OutcomesExplorer {...research} />
    <Safety {...safety} />
    <LatestUpdates {...updates} />
    <PlatformCTA {...cta} />
  </div>
</PageLayout>
