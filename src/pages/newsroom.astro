// ── SEO — CollectionPage + ItemList (mirrors /narrators) ────────────────────
const base = new URL(Astro.site ?? 'https://www.innerexplorer.org').origin;
const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  url: `${base}/newsroom`,
  description: pageDescription,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: stories.length,
    itemListElement: stories.map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: s.title,
    })),
  },
};
---

<PageLayout title={pageTitle} description={pageDescription} flushTop>
  <JsonLd slot="head" schema={collectionLd} />

  <div class="appearance-light page-wash">
    <EditorialMasthead
      layout="inline"
      size="lg"
      glow
      lead="Our"
      display="Newsroom"
      intro="The latest research, announcements, and lessons from the Inner Explorer community."
    />

    <NewsroomFilters categories={[...categories]} total={stories.length} />

    <StoryGrid stories={stories} cols={4} initial={12} step={8} />

    <GlowCTA
      sans="Calm classrooms"
      serif="start with you"
      subtitle="Bring daily, research-backed mindfulness to every student in your school."
      primary={{ label: 'Request a demo', href: '/contact' }}
      secondary={{ label: 'Take a tour', href: '/educators' }}
      trust="Trusted by 50,000+ educators across 8,000 schools"
    />
  </div>
</PageLayout>

<style>
  /* The page rides on the site's standard gray surface, painted by `.appearance-light`
     (var(--background)) like the rest of the marketing pages — no bespoke wash. flushTop
     drops the layout's default nav clearance, so this top padding gives the masthead room
     to breathe below the floating nav (the band still fills to the top edge, so no dark
     body seam shows behind it). */
  .page-wash {
    padding-top: clamp(72px, 8vw, 112px);
  }
</style>

<script>
  // Newsroom controller (progressive enhancement): wires the filter tabs, sort
  // toggle, live count, and "Load more" to the cards via data-attributes. With no
  // JS, every card renders unfiltered and the button/empty-state stay hidden.
  const grid = document.querySelector<HTMLElement>('[data-news-grid]');
  const gridInner = grid?.querySelector<HTMLElement>('.grid');

  if (grid && gridInner) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-cat]'));
    const loadMore = grid.querySelector<HTMLButtonElement>('[data-load-more]');
    const empty = grid.querySelector<HTMLElement>('[data-empty]');
    const initial = Number(grid.dataset.initial) || 12;
    const step = Number(grid.dataset.step) || 8;

    const tabs = Array.from(document.querySelectorAll<HTMLElement>('[data-filter]'));
    const sorts = Array.from(document.querySelectorAll<HTMLElement>('[data-sort]'));
    const countEl = document.querySelector<HTMLElement>('[data-count]');

    let activeCat = 'all';
    let sortMode = 'newest';
    let limit = initial;

    const render = () => {
      const list = cards
        .filter((c) => activeCat === 'all' || c.dataset.cat === activeCat)
        .sort((a, b) =>
          sortMode === 'newest'
            ? (b.dataset.date ?? '').localeCompare(a.dataset.date ?? '')
            : Number(b.dataset.pop) - Number(a.dataset.pop),
        );

      // Reorder matched cards into sorted order; hide the rest.
      list.forEach((c) => gridInner.appendChild(c));
      cards.forEach((c) => (c.hidden = !list.includes(c)));
      // Clamp the visible matched set to the current limit.
      list.forEach((c, i) => (c.hidden = i >= limit));

      const total = list.length;
      if (countEl) countEl.textContent = `${total} ${total === 1 ? 'story' : 'stories'}`;
      if (loadMore) loadMore.hidden = total <= limit;
      if (empty) empty.hidden = total > 0;
    };

    render();

    tabs.forEach((tab) =>
      tab.addEventListener('click', () => {
        activeCat = tab.dataset.filter ?? 'all';
        limit = initial;
        tabs.forEach((t) => {
          const on = t === tab;
          t.classList.toggle('on', on);
          t.setAttribute('aria-pressed', String(on));
        });
        render();
      }),
    );

    sorts.forEach((btn) =>
      btn.addEventListener('click', () => {
        sortMode = btn.dataset.sort ?? 'newest';
        sorts.forEach((b) => {
          const on = b === btn;
          b.classList.toggle('on', on);
          b.setAttribute('aria-pressed', String(on));
        });
        render();
      }),
    );

    loadMore?.addEventListener('click', () => {
      limit += step;
      render();
    });
  }
</script>
