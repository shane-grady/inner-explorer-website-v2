---
import PageLayout from '../layouts/PageLayout.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import EditorialMasthead from '../components/blocks/EditorialMasthead.astro';
import ContactCard from '../components/blocks/ContactCard.astro';
import DemoForm from '../components/blocks/contact/DemoForm.astro';
import PhoneCard from '../components/blocks/contact/PhoneCard.astro';
import EmailCard from '../components/blocks/contact/EmailCard.astro';

// ── Page content (structured data; CMS-ready seam) ──────────────────────────
//
// All copy lives here so it can be lifted into a content collection later.
// Phone, team initials, and email aliases are the designer's placeholders —
// flagged in tasks/todo.md to swap before publish.

const hero = {
  lead: 'Reach a real person ',
  display: 'now.',
  intro: 'No phone trees, no chatbot detours — just someone on the other end who answers.',
};

const demo = {
  badge: 'Most popular',
  title: 'Book a demo',
  blurb:
    "See Inner Explorer in your classroom in twenty minutes. We'll walk through the educator app, the district dashboard, and what a Tuesday morning looks like with daily practice.",
  roles: [
    { value: 'teacher', label: 'Teacher' },
    { value: 'counselor', label: 'Counselor / Social Worker' },
    { value: 'principal', label: 'Principal' },
    { value: 'district', label: 'District Administrator' },
    { value: 'curriculum', label: 'Curriculum Director' },
    { value: 'other', label: 'Other' },
  ],
  sizes: [
    { value: 'self', label: 'Just me' },
    { value: 'school-small', label: '2 – 25 (a school)' },
    { value: 'school-mid', label: '26 – 100' },
    { value: 'district-small', label: '101 – 500' },
    { value: 'district-large', label: '500+ (a district)' },
  ],
  avatars: [
    { initials: 'SC', variant: 'mint' as const },
    { initials: 'MR', variant: 'amber' as const },
    { initials: 'JP', variant: 'sky' as const },
    { initials: 'AK', variant: 'lilac' as const },
  ],
  teamSizeLabel: '4-person schools team',
  responseLabel: 'under 4 hours',
  rep: { name: 'Sarah Chen', qualifier: 'from our schools team' },
};

const phone = {
  title: 'Call us',
  blurb:
    'We are one of the only ed-tech companies where a human answers the phone — every time, on the first ring when we can. No menu trees, no ticket numbers.',
  display: '+1 (508) 657-1755',
  e164: '+15086571755',
  openLabel: 'Open now',
  hours: 'Mon – Fri, 8am – 6pm ET',
  pickup: '11 seconds',
  team: [
    { initials: 'SC', variant: 'mint' as const },
    { initials: 'MR', variant: 'amber' as const },
    { initials: 'JP', variant: 'sky' as const },
  ],
  teamLeadHtml: '<strong>Sarah, Marcus, and Jenny</strong> are who you’ll most likely talk to.',
  teamNoteHtml:
    'All three are former classroom teachers. They’ve been with Inner Explorer for an average of 6 years — so the person who picks up will know the answer.',
};

const email = {
  title: 'Send an email',
  blurb:
    'Best for documents, RFPs, formal requests, or anything you’d like to keep a written record of. We reply within one business day.',
  items: [
    {
      label: 'General',
      email: 'hello@innerexplorer.org',
      description: 'Anything that doesn’t fit below',
    },
    {
      label: 'Support',
      email: 'support@innerexplorer.org',
      description: 'For current educators and admins',
    },
    {
      label: 'Press',
      email: 'press@innerexplorer.org',
      description: 'Media, interviews, research requests',
    },
  ],
};

const closing = {
  quote:
    'Whatever you’re writing about, we’ve probably already thought about it with a teacher who was up at 5 a.m. — so don’t worry about the wording.',
  attribution: 'The Inner Explorer team',
  location: 'Headquartered in Marlborough, MA',
};

const pageTitle = 'Contact — Inner Explorer';
const pageDescription =
  'Reach a real person now. Book a demo, call us, or send an email — three ways to start a daily mindfulness practice in your school or district.';

const base = new URL(Astro.site ?? 'https://www.innerexplorer.org').origin;
const contactLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: pageTitle,
  url: `${base}/contact`,
  description: pageDescription,
  mainEntity: {
    '@type': 'Organization',
    name: 'Inner Explorer',
    url: base,
    logo: `${base}/logo.png`,
    contactPoint: [
      {
        '@type': 'ContactPoint',
        contactType: 'customer support',
        telephone: phone.e164,
        email: email.items[0]?.email,
        areaServed: 'US',
        availableLanguage: ['English', 'Spanish'],
        hoursAvailable: {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
          opens: '08:00',
          closes: '18:00',
        },
      },
      {
        '@type': 'ContactPoint',
        contactType: 'technical support',
        email: email.items[1]?.email,
      },
      {
        '@type': 'ContactPoint',
        contactType: 'press',
        email: email.items[2]?.email,
      },
    ],
  },
};
---

<PageLayout title={pageTitle} description={pageDescription}>
  <JsonLd slot="head" schema={contactLd} />

  <div class="appearance-light contact-page">
    <div class="ambient" aria-hidden="true"></div>

    <EditorialMasthead
      lead={hero.lead}
      display={hero.display}
      intro={hero.intro}
      layout="inline"
      maxWidth="760px"
    />

    <div class="shell">
      <div class="stack">
        <ContactCard tone="primary" badge={demo.badge} title={demo.title} blurb={demo.blurb}>
          <svg
            slot="icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="5" width="18" height="16" rx="2"></rect>
            <path d="M8 3v4M16 3v4M3 11h18"></path>
          </svg>
          <DemoForm
            roles={demo.roles}
            sizes={demo.sizes}
            avatars={demo.avatars}
            teamSizeLabel={demo.teamSizeLabel}
            responseLabel={demo.responseLabel}
            rep={demo.rep}
          />
        </ContactCard>

        <ContactCard tone="subtle" title={phone.title} blurb={phone.blurb}>
          <svg
            slot="icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          <PhoneCard
            display={phone.display}
            e164={phone.e164}
            openLabel={phone.openLabel}
            hours={phone.hours}
            pickup={phone.pickup}
            team={phone.team}
            teamLeadHtml={phone.teamLeadHtml}
            teamNoteHtml={phone.teamNoteHtml}
          />
        </ContactCard>

        <ContactCard tone="subtle" title={email.title} blurb={email.blurb}>
          <svg
            slot="icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="m3 7 9 6 9-6"></path>
          </svg>
          <EmailCard emails={email.items} />
        </ContactCard>
      </div>

      <section class="closing">
        <p class="closing-quote">{closing.quote}</p>
        <div class="closing-meta">
          <strong>{closing.attribution}</strong>
          <span>{closing.location}</span>
        </div>
      </section>
    </div>

    <output id="contact-toast" aria-live="polite" class="toast">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      <span data-toast-msg>Copied</span>
    </output>
  </div>
</PageLayout>

<style>
  .contact-page {
    position: relative;
    isolation: isolate;
    padding-bottom: 96px;
  }

  /* Soft ambient atmosphere — fixed full-viewport glow behind everything. Light
     greens at top corners + a warm amber bloom, very subtle. Mirrors the handoff
     body::before but tinted through token surfaces. */
  .ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    background:
      radial-gradient(
        60% 50% at 12% 8%,
        color-mix(in oklab, var(--color-brand) 14%, transparent),
        transparent 60%
      ),
      radial-gradient(
        45% 40% at 92% 14%,
        color-mix(in oklab, var(--color-accent) 12%, transparent),
        transparent 60%
      ),
      radial-gradient(
        55% 45% at 80% 95%,
        color-mix(in oklab, var(--color-brand) 10%, transparent),
        transparent 60%
      );
  }

  .shell {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .stack {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .closing {
    margin-top: 56px;
    padding: 28px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .closing-quote {
    margin: 0;
    max-width: 540px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    line-height: 1.3;
    color: var(--color-foreground);
  }
  .closing-meta {
    text-align: right;
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-muted-foreground);
  }
  .closing-meta strong {
    display: block;
    color: var(--color-foreground);
    font-weight: 600;
  }

  /* Toast — fixed, slides up on .show, honors prefers-reduced-motion. */
  .toast {
    position: fixed;
    left: 50%;
    bottom: 32px;
    transform: translate(-50%, 80px);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 18px;
    background: var(--color-foreground);
    color: var(--color-background);
    border-radius: 9999px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    box-shadow: var(--shadow-lg);
    opacity: 0;
    pointer-events: none;
    transition:
      transform var(--dur) var(--ease-out),
      opacity var(--dur) var(--ease-out);
    z-index: 50;
  }
  .toast.show {
    transform: translate(-50%, 0);
    opacity: 1;
  }
  .toast svg {
    width: 16px;
    height: 16px;
  }

  @media (prefers-reduced-motion: reduce) {
    .toast {
      transform: translate(-50%, 0);
      transition: opacity var(--dur) var(--ease-out);
    }
  }

  @media (max-width: 720px) {
    .shell {
      padding: 0 18px;
    }
    .closing {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
      padding: 24px 4px;
    }
    .closing-meta {
      text-align: left;
    }
  }
</style>

<script>
  // Page-wide copy-to-clipboard + toast coordinator. Any element with
  // [data-copy] copies its value, flashes the toast, and (for buttons that
  // own a .is-copied affordance) toggles their state briefly.
  const toast = document.getElementById('contact-toast');
  const toastMsg = toast?.querySelector<HTMLElement>('[data-toast-msg]');
  let toastTimer: ReturnType<typeof setTimeout> | null = null;

  const showToast = (message: string) => {
    if (!toast || !toastMsg) return;
    toastMsg.textContent = message;
    toast.classList.add('show');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 1800);
  };

  const writeToClipboard = async (text: string): Promise<boolean> => {
    if (navigator.clipboard?.writeText) {
      try {
        await navigator.clipboard.writeText(text);
        return true;
      } catch {
        /* fall through to legacy path */
      }
    }
    // Legacy path for older iOS Safari and headless environments.
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.setAttribute('readonly', '');
    ta.style.position = 'absolute';
    ta.style.left = '-9999px';
    document.body.appendChild(ta);
    ta.select();
    let ok = false;
    try {
      ok = document.execCommand('copy');
    } catch {
      /* swallow — `ok` stays false */
    }
    document.body.removeChild(ta);
    return ok;
  };

  document.querySelectorAll<HTMLElement>('[data-copy]').forEach((el) => {
    el.addEventListener('click', async (event) => {
      event.preventDefault();
      const value = el.getAttribute('data-copy') ?? '';
      const label = el.getAttribute('data-copy-label') ?? value;
      const ok = await writeToClipboard(value);
      if (ok) {
        showToast(`${label} copied`);
        // If this button has a paired .is-copied affordance, flash it.
        if (el.classList.contains('copy-btn')) {
          el.classList.add('is-copied');
          setTimeout(() => el.classList.remove('is-copied'), 2000);
        }
      }
    });
  });
</script>
