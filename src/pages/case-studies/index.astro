---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import EditorialMasthead from '../../components/blocks/EditorialMasthead.astro';
import GlowCTA from '../../components/blocks/GlowCTA.astro';

// Case-study hub: every non-draft story in the collection, in editorial order.
// This page is the nav's "Case studies" target, giving each study a crawl path
// from every page on the site (per the SEO audit's internal-linking findings).
const all = await getCollection('caseStudies', ({ data }) => !data.draft);
const studies = all.sort((a, b) => a.data.order - b.data.order);

const pageTitle = 'Case Studies — Real Results from Schools & Districts | Inner Explorer';
const pageDescription =
  'Real schools, measured results: how districts and therapeutic schools use Inner Explorer’s daily 5–10 minute mindfulness practice to cut behavioral incidents and build calmer classrooms.';

const base = new URL(Astro.site ?? 'https://www.innerexplorer.org').origin;
const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  url: `${base}/case-studies/`,
  description: pageDescription,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: studies.length,
    itemListElement: studies.map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: `${s.data.meta.titleLead} ${s.data.meta.titleEmphasis}`,
      url: `${base}/case-studies/${s.id}/`,
    })),
  },
};
---

<PageLayout title={pageTitle} description={pageDescription} flushTop>
  <JsonLd slot="head" schema={collectionLd} />

  <div class="appearance-light page-wash">
    <EditorialMasthead
      layout="inline"
      size="lg"
      glow
      lead="Case"
      display="Studies"
      intro="Real schools, measured results. How partners across the country turned a daily five-minute practice into calmer, more focused classrooms."
    />

    <section class="hub" aria-label="All case studies">
      <div class="wrap">
        {
          studies.map((s) => (
            <a class="story" href={`/case-studies/${s.id}/`}>
              <div class="media">
                <Image
                  src={s.data.meta.heroImage}
                  alt={s.data.meta.heroImageAlt}
                  widths={[480, 760, 1000]}
                  sizes="(max-width: 820px) 100vw, 480px"
                  loading="lazy"
                />
              </div>
              <div class="body">
                <span class="kicker">{s.data.meta.kicker}</span>
                <h2 class="title">
                  {s.data.meta.titleLead} <em>{s.data.meta.titleEmphasis}</em>
                </h2>
                <p class="dek">{s.data.meta.dek}</p>
                <div class="foot">
                  <span class="stat">
                    <b>{s.data.metrics.featured.value}</b>
                    <span>{s.data.metrics.featured.label}</span>
                  </span>
                  <span class="meta">
                    {s.data.district.location}
                    {s.data.meta.readingTime ? ` · ${s.data.meta.readingTime}` : ''}
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <GlowCTA
      sans="Your school could be"
      serif="the next story"
      subtitle="See what a daily mindfulness practice could do for your classrooms. We'll walk you through the playbook our partners used."
      primary={{ label: 'Book a demo', href: '/contact' }}
      secondary={{ label: 'See the research', href: '/research' }}
    />
  </div>
</PageLayout>

<style>
  .hub {
    padding-top: clamp(40px, 6vw, 72px);
  }
  .wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 64px);
    display: grid;
    gap: clamp(20px, 2.6vw, 32px);
  }

  .story {
    display: grid;
    grid-template-columns: minmax(0, 480px) 1fr;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition:
      transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out);
  }
  .story:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--brand-200);
  }

  .media {
    position: relative;
    min-height: 260px;
  }
  .media :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: clamp(24px, 3.4vw, 44px);
  }
  .kicker {
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-brand-emphasis);
  }
  .title {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(24px, 2.8vw, 34px);
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
    text-wrap: balance;
  }
  .title em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    color: var(--color-brand-emphasis);
  }
  .dek {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-muted-foreground);
    text-wrap: pretty;
  }

  .foot {
    margin-top: auto;
    padding-top: clamp(16px, 2vw, 24px);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }
  .stat {
    display: flex;
    align-items: baseline;
    gap: 10px;
    min-width: 0;
  }
  .stat b {
    flex: none;
    font-weight: 600;
    font-size: clamp(24px, 2.4vw, 30px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-brand-emphasis);
  }
  .stat span {
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-muted-foreground);
  }
  .meta {
    flex: none;
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--color-muted-foreground);
  }

  @media (max-width: 820px) {
    .story {
      grid-template-columns: 1fr;
    }
    .media {
      min-height: 0;
      aspect-ratio: 16 / 9;
    }
    .foot {
      flex-wrap: wrap;
    }
  }
</style>
