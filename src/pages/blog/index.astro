---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/primitives/Container.astro';
import Section from '../../components/layout/Section.astro';
import Heading from '../../components/primitives/Heading.astro';
import Text from '../../components/primitives/Text.astro';
import Link from '../../components/primitives/Link.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const dateFmt = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' });
---

<PageLayout
  title="Blog — Inner Explorer"
  description="Insights on bringing mindfulness to schools."
>
  <Section space="lg">
    <Container width="narrow">
      <Heading as="h1" size="xl">Blog</Heading>
      <Text size="lg" tone="muted" class="mt-3">Insights on bringing mindfulness to schools.</Text>
      <ul class="mt-10 space-y-10">
        {
          posts.map((post) => (
            <li class="border-b border-border pb-10 last:border-0">
              <Text size="sm" tone="muted">
                <time datetime={post.data.pubDate.toISOString()}>
                  {dateFmt.format(post.data.pubDate)}
                </time>
              </Text>
              <Heading as="h2" size="md" class="mt-2">
                <a href={`/blog/${post.id}/`} class="transition-colors hover:text-brand">
                  {post.data.title}
                </a>
              </Heading>
              <Text tone="muted" class="mt-2">
                {post.data.description}
              </Text>
              <Link href={`/blog/${post.id}/`} class="mt-3 inline-block text-sm">
                Read more &rarr;
              </Link>
            </li>
          ))
        }
      </ul>
    </Container>
  </Section>
</PageLayout>
