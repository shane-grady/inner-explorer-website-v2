---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import Breadcrumb from '../../components/primitives/Breadcrumb.astro';
import EditorialMasthead from '../../components/blocks/EditorialMasthead.astro';
import PhotoQuote from '../../components/blocks/PhotoQuote.astro';
import VoiceBar from '../../components/blocks/VoiceBar.astro';
import StatStrip from '../../components/blocks/StatStrip.astro';
import Interview from '../../components/blocks/Interview.astro';
import MediaRows from '../../components/blocks/MediaRows.astro';
import TeamGrid from '../../components/blocks/TeamGrid.astro';
import { personSchema, breadcrumbSchema } from '../../lib/schema';

export async function getStaticPaths() {
  // Every non-draft narrator with a portrait gets a detail page — even those
  // who only have wall-level data so far. Optional editorial sections (intro,
  // quote, voiceIntro, facts, qa, practices) hide gracefully on absence.
  const all = await getCollection('narrators', ({ data }) => !data.draft && !!data.photo);
  const sorted = all.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((entry) => ({
    params: { slug: entry.id },
    props: {
      narrator: entry,
      others: sorted.filter((n) => n.id !== entry.id).slice(0, 4),
    },
  }));
}

const { narrator, others } = Astro.props;
const d = narrator.data;
const firstName = d.name.split(' ')[0];
const path = `/narrators/${narrator.id}/`;

// Editorial fallbacks for narrators still being authored.
const intro = d.intro ?? `${d.role} in residence at the Inner Explorer studio in Boston.`;
const heroImage = d.photoWide ?? d.photo!;
const heroAlt = d.photoAlt ?? `Portrait of ${d.name}`;

const personLd = personSchema(Astro.site, {
  name: d.name,
  jobTitle: d.role,
  description: intro,
  path,
});
const crumbLd = breadcrumbSchema(Astro.site, [
  { name: 'Narrators', path: '/narrators/' },
  { name: d.name, path },
]);

const practicesHeading = `<span class="serif">The practices</span><span class="sans"> ${firstName} guides in classrooms.</span>`;
---

<PageLayout title={`${d.name} — Inner Explorer`} description={intro}>
  <JsonLd slot="head" schema={personLd} />
  <JsonLd slot="head" schema={crumbLd} />

  <div class="appearance-light">
    <div class="bc">
      <Breadcrumb items={[{ label: 'Narrators', href: '/narrators/' }, { label: d.name }]} />
    </div>

    <EditorialMasthead eyebrow={d.role} lead="Meet" display={`${d.name}.`} intro={intro} />

    {
      d.quote && (
        <PhotoQuote
          image={heroImage}
          imageAlt={heroAlt}
          cornerStart="PORTRAIT"
          cornerEnd={d.location}
          quote={d.quote}
          eager
        />
      )
    }

    {
      d.voiceIntro && (
        <VoiceBar
          audioSrc={d.voiceIntro.audioSrc}
          durationSec={d.voiceIntro.durationSec}
          title={d.voiceIntro.title}
          transcriptHref={d.voiceIntro.transcriptHref}
          captionsSrc={d.voiceIntro.captionsSrc}
        />
      )
    }

    {
      d.facts.length > 0 && (
        <StatStrip
          stats={d.facts}
          labelCase="upper"
          contained
          maxWidth="1200px"
          ariaLabel={`Facts about ${d.name}`}
        />
      )
    }

    {
      d.qa.length > 0 && (
        <Interview
          eyebrow={`Get to know ${firstName}`}
          headingHtml='<span class="serif">Five questions,</span><span class="sans"> on the practice.</span>'
          items={d.qa}
        />
      )
    }

    {
      d.practices.length > 0 && (
        <MediaRows
          eyebrow={`${firstName}'s library`}
          headingHtml={practicesHeading}
          rows={d.practices}
        />
      )
    }

    {
      others.length > 0 && (
        <TeamGrid
          eyebrow="From the studio"
          headingHtml='<span class="serif">More voices</span><span class="sans"> on Inner Explorer.</span>'
          variant="voices"
          maxWidth="1200px"
          people={others.map((o) => ({
            name: o.data.name,
            role: o.data.role,
            photo: o.data.photo,
            href: `/narrators/${o.id}/`,
          }))}
        />
      )
    }
  </div>
</PageLayout>

<style>
  .bc {
    max-width: 1200px;
    margin: 0 auto;
    padding: 28px 32px 0;
  }
</style>
