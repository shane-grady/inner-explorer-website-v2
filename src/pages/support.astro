// ── SEO ─────────────────────────────────────────────────────────────────────

const pageTitle = 'Help & Support — Inner Explorer';
const pageDescription =
  'Answers to the questions teachers, leaders, and families ask us most about Inner Explorer’s daily K–12 audio-guided mindfulness practice.';

const base = new URL(Astro.site ?? 'https://www.innerexplorer.org').origin;

const stripTags = (html: string): string => html.replace(/<[^>]*>/g, '');

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  url: `${base}/support`,
  name: pageTitle,
  description: pageDescription,
  mainEntity: sections.flatMap((sec) =>
    sec.items.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.aHtml ? stripTags(item.aHtml) : (item.a ?? ''),
      },
    })),
  ),
};
---

<PageLayout title={pageTitle} description={pageDescription}>
  <JsonLd slot="head" schema={faqSchema} />

  <EditorialMasthead
    eyebrow={hero.eyebrow}
    display={hero.display}
    intro={hero.intro}
    layout="display"
    maxWidth="900px"
  />

  <div class="support-shell">
    <FAQSidebar sections={sidebarSections} />
    <main id="faq-main">
      {sections.map((sec) => <FAQSection id={sec.id} title={sec.title} items={sec.items} />)}
    </main>
  </div>

  <PricingCard
    eyebrow={pricing.eyebrow}
    headlineHtml={pricing.headlineHtml}
    sub={pricing.sub}
    plan={pricing.plan}
    features={pricing.features}
  />

  <QuoteRow
    lead={closer.lead}
    leadDisplay={closer.leadDisplay}
    leadSub={closer.leadSub}
    ctas={closer.ctas}
    quotes={closer.quotes}
  />
</PageLayout>

<style>
  .support-shell {
    max-width: 1320px;
    margin: 0 auto;
    padding: 24px 32px 80px;
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 80px;
    align-items: start;
  }

  @media (max-width: 880px) {
    .support-shell {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 16px 20px 60px;
    }
  }
</style>
