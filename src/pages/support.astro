---
import PageLayout from '../layouts/PageLayout.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import EditorialMasthead from '../components/blocks/EditorialMasthead.astro';
import FAQSection from '../components/blocks/FAQSection.astro';
import PricingCard from '../components/blocks/PricingCard.astro';
import QuoteRow from '../components/blocks/QuoteRow.astro';
import FAQSidebar from '../components/blocks/support/FAQSidebar.astro';
import type { FAQItem } from '../components/blocks/FAQSection.astro';

// ── Page content (structured data — CMS-ready seam) ─────────────────────────
//
// All copy lives here so it can later be lifted into a content collection. The
// section ids match the sidebar's jump-to links. Some answers use `aHtml` for
// inline links or <em>; plain answers use `a`.

const hero = {
  eyebrow: 'Help & Support',
  display: 'FAQs.',
  intro: 'Find answers to the questions teachers, leaders, and families ask us most.',
};

interface Section {
  id: string;
  label: string;
  title: string;
  items: FAQItem[];
}

const sections: Section[] = [
  {
    id: 'getting-started',
    label: 'Getting started',
    title: 'Getting started',
    items: [
      {
        q: 'What is Inner Explorer?',
        a: 'Inner Explorer is the leading provider of daily audio-guided mindfulness for K–12 schools. Educators press play; the class follows along with a short, research-backed practice. Over time, students build attention, emotional regulation, and resilience — and teachers reclaim calmer, more focused classrooms.',
        open: true,
      },
      {
        q: 'Who is Inner Explorer for?',
        a: 'Teachers, counselors, principals, district leaders, and the students they serve — from pre-K through high school. Many families also use Inner Explorer at home to extend the practice beyond the school day.',
      },
      {
        q: 'Where is Inner Explorer used?',
        a: 'In more than 26,000 classrooms across all 50 U.S. states and in international schools across more than 30 countries. We are headquartered in Marlborough, MA.',
      },
      {
        q: 'Why was Inner Explorer created?',
        a: 'Our co-founder spent years watching the toll that stress, trauma, and constant distraction took on students and the adults who teach them. We built Inner Explorer so any teacher — with no special training — could lead a short, daily practice that gives the whole class a moment to settle, breathe, and come back to learning.',
      },
      {
        q: 'How do I create an account?',
        aHtml:
          'Click <em>Start free</em> at the top of the page. You’ll be asked for your name, school email, school, and grade level. Most teachers are inside their first practice in under three minutes.',
      },
      {
        q: 'Do I need any training to begin?',
        a: 'No. The practices are fully audio-guided — you don’t lead the meditation; the recording does. We recommend a 20-minute orientation video before your first session, but it isn’t required.',
      },
      {
        q: 'Is there a free trial?',
        a: 'Yes. Individual educators can use a generous selection of practices free for 30 days. Schools and districts can request a 60-day pilot with full access for every classroom.',
      },
      {
        q: 'How long until I see results?',
        a: 'Many teachers report a calmer transition into the next activity within the first week. Independent research shows measurable shifts in attention and behavior within 6–8 weeks of daily practice.',
      },
      {
        q: 'Do I need student rosters or accounts?',
        aHtml:
          'No. Inner Explorer is teacher-led — students never need to log in. You can create unnamed “classroom” entries in your dashboard to track progress across multiple sections.',
      },
      {
        q: 'Does Inner Explorer replace SEL or counseling programs?',
        a: 'No — it complements them. Inner Explorer is the daily Tier-1 practice that creates the conditions for any social-emotional curriculum or counseling intervention to work better. Many counselors use our content directly in small-group sessions, too.',
      },
    ],
  },
  {
    id: 'daily-practice',
    label: 'Daily practice',
    title: 'Daily practice',
    items: [
      {
        q: 'How long is each session?',
        a: 'Sessions are 5 to 10 minutes, depending on grade band. Pre-K and early elementary practices are shorter; middle and high school practices run a few minutes longer.',
      },
      {
        q: 'How often should we practice?',
        a: 'Daily. The benefits of mindfulness — like any meaningful practice — come from consistency, not intensity. One short session every school day is far more effective than one long session a week.',
      },
      {
        q: 'What time of day works best?',
        a: 'Most classrooms anchor it to a transition — first thing in the morning, right after lunch or recess, or just before dismissal. Pick a moment when your students reliably need to settle, and keep it consistent.',
      },
      {
        q: 'Can I choose the practice each day?',
        a: 'You can. Our recommended sequence follows a research-aligned arc, but you can substitute any practice — by theme, length, or focus area — from the library at any time.',
      },
      {
        q: 'What if students can’t sit still or close their eyes?',
        a: 'That’s completely normal, especially in the first few weeks. Eyes closed is invited, never required. Students can rest their gaze on the desk, on the floor, or out a window. Stillness builds gradually — and surprisingly fast.',
      },
      {
        q: 'Can we practice with the whole school at once?',
        a: 'Yes — many of our partner schools play a practice over the PA system once or twice a week. We have practices specifically scripted for school-wide moments and morning announcements.',
      },
      {
        q: 'What happens if we miss a day?',
        a: 'Nothing breaks. Pick up the next day where you left off. The dashboard shows your streak and recent themes so you can stay oriented even after a disrupted week.',
      },
      {
        q: 'Can I do a practice on my own as a teacher?',
        aHtml:
          'Absolutely — and we encourage it. Educators have access to a dedicated <em>For Educators</em> library of practices designed for adult use: morning grounding, end-of-day decompression, and short resets between classes.',
      },
    ],
  },
  {
    id: 'lessons-content',
    label: 'Lessons & content',
    title: 'Lessons & content',
    items: [
      {
        q: 'How is the library organized?',
        aHtml:
          'By grade band (Pre-K, K–2, 3–5, 6–8, 9–12), by length, and by theme. Themes group practices into multi-day series so a class can spend a week on, say, <em>Gratitude</em>, <em>Focus</em>, or <em>Breath</em>.',
      },
      {
        q: 'How are practices structured?',
        a: 'Each practice opens with a settle-in, moves through a short body-and-breath anchor, introduces one focus skill, and closes with a brief reflection. The same arc repeats so students build familiarity over time.',
      },
      {
        q: 'Are practices available in Spanish?',
        a: 'Yes. A growing portion of the library is available in Spanish, recorded by native speakers rather than translated voiceovers. We add new bilingual content every quarter.',
      },
      {
        q: 'Is there a journaling component?',
        a: 'Yes. Most practices end with an optional 1–2 minute journal prompt. Students can write in any notebook; we also provide printable journal pages and a digital journal for older grades.',
