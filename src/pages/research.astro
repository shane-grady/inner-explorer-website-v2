---
import PageLayout from '../layouts/PageLayout.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import CinematicHero from '../components/blocks/CinematicHero.astro';
import EditorialCTA from '../components/blocks/EditorialCTA.astro';
import OpeningVoid from '../components/blocks/research/OpeningVoid.astro';
import ChapterReceipts from '../components/blocks/research/ChapterReceipts.astro';
import ChapterBrain from '../components/blocks/research/ChapterBrain.astro';
import ChapterOutcomes from '../components/blocks/research/ChapterOutcomes.astro';
import Endorsers from '../components/blocks/research/Endorsers.astro';
import VoicesRotator from '../components/blocks/research/VoicesRotator.astro';

// Photography — stand-ins reused from the About page until real research photos are
// supplied. See tasks/todo.md.
import heroImg from '../assets/images/about/hero-classroom-mindfulness.png';
import ctaImg from '../assets/images/about/impact-diverse-classroom.jpg';

// ── Page content (structured data; CMS-ready) ────────────────────────────────

const opening = {
  eyebrow: 'Inner Explorer · The research',
  lines: [
    { text: 'Two of every three children' },
    { text: 'carry stress that quietly' },
    { text: 'disables their ability to learn.', emphasis: true },
  ],
};

const hero = {
  eyebrow: 'A quiet revolution · Since 2011',
  headlineLines: [
    { text: "We've spent", kind: 'sans' as const },
    { text: 'fifteen years', kind: 'serif' as const },
    { text: 'changing that.', kind: 'serif' as const },
    { text: "Here's the proof.", kind: 'serif' as const, tone: 'accent' as const },
  ],
  lede: 'Six independent controlled trials. Tens of thousands of classrooms. A daily five-minute practice, grounded in 40+ years of Mindfulness-Based Stress Reduction research.',
  imageAlt: 'A classroom of students settling into a quiet practice',
  primaryCta: { label: 'See the receipts', href: '#receipts' },
  secondaryCta: { label: 'Book a demo', href: '/contact' },
};

const studies = [
  {
    id: 'bakosh-2016',
    tag: 'RCT',
    year: 2016,
    authors: 'Bakosh, Snow, Houlihan, Tobias, Barbosa-Leiker',
    journal: 'Journal of Mindfulness',
    institution: 'Loyola Marymount University',
    title: 'Maximizing mindful learning',
    findings: [
      { stat: '+14%', label: 'Reading grades' },
      { stat: '+11%', label: 'Science grades' },
      { stat: '−42%', label: 'Behavior referrals' },
    ],
  },
  {
    id: 'bakosh-2018',
    tag: 'Controlled study',
    year: 2018,
    authors: 'Bakosh, Houlihan, Tobias',
    journal: 'Learning & Instruction',
    institution: 'Loyola Marymount University',
    title: 'Audio-guided mindfulness training in schools',
    findings: [
      { stat: '+18%', label: 'Math grades' },
      { stat: '+17%', label: 'Overall GPA' },
      { stat: '−21%', label: 'Teacher stress' },
    ],
  },
  {
    id: 'dunlap-2023',
    tag: 'Doctoral study',
    year: 2023,
    authors: 'Dunlap',
    journal: 'Pending publication',
    institution: 'UNC — Charlotte',
    title: 'Inner Explorer and academic growth',
    findings: [
