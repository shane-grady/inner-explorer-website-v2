      { stat: '+Math', label: 'Standardized scores' },
      { stat: '+Reading', label: 'Standardized scores' },
    ],
  },
  {
    id: 'lopez-2020',
    tag: 'RCT',
    year: 2020,
    authors: 'Lopez et al.',
    journal: 'Pending publication',
    institution: 'University of South Florida',
    title: 'A randomized trial in 39 Head Start classrooms',
    findings: [
      { stat: '−34%', label: 'Teacher stress' },
      { stat: '+27%', label: 'Classroom management' },
      { stat: '+EF', label: 'Student executive function' },
    ],
  },
  {
    id: 'treves-2023',
    tag: 'RCT',
    year: 2023,
    authors: 'Treves et al.',
    journal: 'Journal of Mindfulness',
    institution: 'MIT — McGovern Institute',
    title: 'At-home use of app-based mindfulness for children',
    findings: [
      { stat: '−28%', label: 'Student stress' },
      { stat: '−24%', label: 'Negative affect' },
      { stat: 'RCT', label: 'Active control' },
    ],
  },
  {
    id: 'stager-2022',
    tag: 'Doctoral study',
    year: 2022,
    authors: 'Stager',
    journal: 'Pending publication',
    institution: 'University of La Verne',
    title: 'Mindfulness with elementary students and state tests',
    findings: [
      { stat: '+Math', label: 'State test scores' },
      { stat: 'Active', label: 'Use vs. inactive' },
      { stat: 'Annual', label: 'Year-over-year' },
    ],
  },
];

const receipts = {
  eyebrow: 'I.',
  label: 'The receipts',
  headlineLines: [
    { text: 'Six independent', kind: 'serif' as const },
    { text: 'controlled trials.', kind: 'serif' as const, tone: 'accent' as const },
  ],
  lede: "Every study below was conducted by independent researchers in real classrooms — four randomized and controlled, two doctoral dissertations. We didn't write them. We just made them possible.",
  studies,
};

const brain = {
  eyebrow: 'II.',
  label: 'The brain',
  headlineLines: [
    { text: 'When stress goes,', kind: 'sans' as const },
    { text: 'learning returns.', kind: 'serif' as const, tone: 'accent' as const },
  ],
  paragraphsBefore: [
    'Stress comes from many sources, both inside and outside of school. When it overwhelms the brain through the automatic fight-flight-freeze response, higher-order thinking takes a back seat. Working memory shrinks. Attention narrows. The capacity to absorb information collapses.',
    "Research suggests two of every three children experience Adverse Childhood Experiences that lead to lasting effects. Toxic stress doesn't just sit on top of learning — it physically rewires the developing brain, dampening executive function and amplifying the very stress response that began the cycle.",
  ],
  pullHtml:
    'Daily mindful practice rewires those networks <em>quietly, measurably, day by day.</em>',
  paragraphsAfterHtml: [
    `Inner Explorer's daily practice is aligned with Mindfulness-Based Stress Reduction — the most widely studied mindfulness curriculum on Earth, with <span class="inline-stat">10,000+ studies</span> over four decades. We translate that science into five minutes a day, led by the teacher, in the classroom.`,
    'The result, measured again and again in controlled trials: classrooms become calmer. Behavior referrals drop. Grades rise. Teachers report less stress. Students report less stress. And the cycle starts to reverse.',
  ],
};

const outcomes = {
  eyebrow: 'III.',
  label: 'The outcomes',
  headlineLines: [
    { text: 'Five outcomes,', kind: 'serif' as const },
    { text: 'measured rigorously,', kind: 'sans' as const },
    { text: 'across five spreads.', kind: 'serif' as const, tone: 'accent' as const },
  ],
  list: [
    {
      id: 'academics',
      label: 'Academics',
      eyebrow: 'Reading, math & GPA',
      headline: 'Higher grades. Better test scores.',
      statValue: '+18',
      statUnit: '%',
      statCaption: 'average GPA lift across treatment groups',
      copy: 'Daily audio-guided practice rewires the brain for focus. Three independent studies — including a randomized controlled trial — found measurable gains in reading, math, science grades and standardized test scores for both general-ed and special-ed students.',
      studies: ['bakosh-2016', 'bakosh-2018', 'dunlap-2023', 'stager-2022'],
      chart: 'bars' as const,
      data: [
        { label: 'Reading', value: 14 },
        { label: 'Math', value: 18 },
        { label: 'Science', value: 11 },
        { label: 'Overall GPA', value: 17 },
      ],
    },
    {
      id: 'behavior',
      label: 'Behavior',
      eyebrow: 'Climate & referrals',
      headline: 'Fewer disruptions. Calmer classrooms.',
      statValue: '−42',
      statUnit: '%',
      statCaption: 'drop in behavior referrals in 4th-grade study',
      copy: 'When students learn to self-regulate through guided breathing, fight-flight-freeze reactions give way to focus. Schools using Inner Explorer daily report meaningful reductions in behavior referrals and a measurable shift in classroom climate.',
      studies: ['bakosh-2016', 'lopez-2020'],
      chart: 'before-after' as const,
      data: [
        { label: 'Behavior referrals', before: 100, after: 58 },
        { label: 'Classroom disruptions', before: 100, after: 64 },
      ],
    },
    {
      id: 'teacher-stress',
      label: 'Teacher stress',
      eyebrow: 'Workforce wellbeing',
      headline: 'Teachers stay. Teachers thrive.',
      statValue: '−34',
      statUnit: '%',
      statCaption: 'reduction in teacher stress, RCT in 39 Head Start classrooms',
      copy: 'Inner Explorer is the rare program that benefits the adult in the room as much as the children. Daily practice, led by the teacher, reduces stress and improves classroom management — and the teacher gets to do the practice too.',
      studies: ['lopez-2020', 'bakosh-2018'],
      chart: 'dial' as const,
      data: [
        { label: 'Stress', value: -34 },
        { label: 'Classroom management', value: 27 },
        { label: 'Job satisfaction', value: 19 },
      ],
    },
    {
      id: 'student-stress',
      label: 'Student stress',
      eyebrow: 'Mental health & wellbeing',
      headline: 'Lower stress. Less anxiety.',
      statValue: '−28',
      statUnit: '%',
      statCaption: 'reduction in student stress & negative affect',
      copy: "A randomized, active-controlled trial at MIT's McGovern Institute found that children using Inner Explorer at home showed clinically meaningful reductions in stress and negative affect — a rigorous test of effect, not just engagement.",
      studies: ['treves-2023'],
      chart: 'line' as const,
      data: [
        { week: 0, stress: 100, control: 100 },
        { week: 2, stress: 88, control: 98 },
        { week: 4, stress: 78, control: 96 },
        { week: 6, stress: 74, control: 95 },
        { week: 8, stress: 72, control: 96 },
      ],
    },
    {
      id: 'sel',
      label: 'SEL',
      eyebrow: 'CASEL competencies',
      headline: 'All five CASEL competencies.',
      statValue: '5',
      statUnit: '/5',
      statCaption: 'CASEL competencies explicitly mapped',
      copy: 'Inner Explorer is a CASEL-approved program. Practices explicitly map to all five core competencies — self-awareness, self-management, social awareness, relationship skills, and responsible decision-making — woven through daily lessons across the school year.',
      studies: [],
      chart: 'competencies' as const,
      data: [
        { label: 'Self-awareness', value: 95 },
        { label: 'Self-management', value: 92 },
        { label: 'Social awareness', value: 84 },
        { label: 'Relationship skills', value: 80 },
        { label: 'Responsible decision-making', value: 78 },
      ],
    },
  ],
};

const endorsers = [
  { name: 'CASEL', role: 'Approved SEL program' },
  { name: 'MIT — McGovern Institute', role: 'Independent RCT' },
  { name: 'University of South Florida', role: 'Head Start RCT' },
  { name: 'UNC Charlotte', role: 'Academic-growth study' },
  { name: 'University of La Verne', role: 'State-test study' },
  { name: 'Loyola Marymount', role: 'Foundational study' },
];

const voices = [
  {
    quote:
      'We saw a measurable drop in behavior referrals within a single semester. Teachers feel less reactive — and the kids notice.',
    author: 'District SEL Coordinator',
    where: 'Broward County, FL',
  },
  {
    quote:
      'It is the rare program that helps the adult in the room as much as the children. Five minutes a day, every day.',
    author: 'Principal',
    where: 'Title I elementary, TX',
  },
  {
    quote:
      "The hardest skeptics in our building have become the strongest advocates. Inner Explorer didn't ask anyone to believe — it just asked them to try it for two weeks.",
    author: 'Dr. Elaine Reyes',
    where: 'Principal · Saint Paul, MN',
  },
];

const cta = {
  eyebrow: 'Bring it to your district',
  headlineLines: [
    { text: 'Five minutes a day,', kind: 'sans' as const },
    { text: 'changes the year.', kind: 'serif' as const, tone: 'accent' as const },
  ],
  lede: 'Inner Explorer is in tens of thousands of classrooms across the country. Talk to our team about bringing a daily mindful practice to yours.',
  primaryCta: { label: 'Book a demo', href: '/contact' },
  secondaryCta: { label: 'Download research one-pager', href: '/contact' },
};

const pageTitle = 'Research — Inner Explorer';
const pageDescription =
  "Six independent controlled trials. Fifteen years in classrooms. The research behind Inner Explorer's daily, audio-guided mindfulness practice for K-12 schools.";

const base = new URL(Astro.site ?? 'https://www.innerexplorer.org').origin;
const researchLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  url: `${base}/research`,
  description: pageDescription,
  about: {
    '@type': 'Thing',
    name: 'Evidence-based mindfulness in K-12 schools',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Inner Explorer',
    url: base,
    logo: `${base}/logo.png`,
  },
};
---

<PageLayout title={pageTitle} description={pageDescription} flushTop>
  <JsonLd slot="head" schema={researchLd} />

  <div class="appearance-light research-page">
    <div class="breath" id="breath" aria-hidden="true">
      <div class="breath-rail">
        <div class="breath-dot" id="breath-dot"></div>
      </div>
      <div class="breath-label" id="breath-label">Opening</div>
    </div>

    <OpeningVoid eyebrow={opening.eyebrow} lines={opening.lines} />
    <CinematicHero
      eyebrow={hero.eyebrow}
      headlineLines={hero.headlineLines}
      lede={hero.lede}
      primaryCta={hero.primaryCta}
      secondaryCta={hero.secondaryCta}
      image={heroImg}
      imageAlt={hero.imageAlt}
      height="full"
    />
    <ChapterReceipts
      eyebrow={receipts.eyebrow}
      label={receipts.label}
      headlineLines={receipts.headlineLines}
      lede={receipts.lede}
      studies={receipts.studies}
    />
    <ChapterBrain
      eyebrow={brain.eyebrow}
      label={brain.label}
      headlineLines={brain.headlineLines}
      paragraphsBefore={brain.paragraphsBefore}
      pullHtml={brain.pullHtml}
      paragraphsAfterHtml={brain.paragraphsAfterHtml}
    />
    <ChapterOutcomes
      eyebrow={outcomes.eyebrow}
      label={outcomes.label}
      headlineLines={outcomes.headlineLines}
      outcomes={outcomes.list}
      studies={studies}
    />
    <Endorsers label="Research partners & endorsements" items={endorsers} />
    <VoicesRotator voices={voices} />
    <EditorialCTA
      eyebrow={cta.eyebrow}
      headlineLines={cta.headlineLines}
      lede={cta.lede}
      primaryCta={cta.primaryCta}
      secondaryCta={cta.secondaryCta}
      image={ctaImg}
      imageAlt="A diverse classroom in calm shared practice"
    />
  </div>
</PageLayout>

<style>
  /* Breath meter — sticky scroll indicator on the right edge. */
  .breath {
    position: fixed;
    right: 28px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    pointer-events: none;
  }
  .breath-rail {
    width: 2px;
    height: 220px;
    background: linear-gradient(
      to bottom,
      transparent,
      color-mix(in oklab, var(--color-foreground) 18%, transparent) 20%,
      color-mix(in oklab, var(--color-foreground) 18%, transparent) 80%,
      transparent
    );
    position: relative;
  }
  .breath-dot {
    position: absolute;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-brand);
    box-shadow:
      0 0 0 4px color-mix(in oklab, var(--color-brand) 22%, transparent),
      0 0 24px color-mix(in oklab, var(--color-brand) 45%, transparent);
    top: 0;
    transition: top 600ms var(--ease-out);
  }
  .breath-label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    margin-top: 8px;
    transition: color var(--dur) var(--ease-out);
  }

  @media (max-width: 1024px) {
    .breath {
      display: none;
    }
  }
</style>

<script>
  // Track scroll progress + which chapter is in view; drive the breath meter dot.
  const dot = document.getElementById('breath-dot');
  const label = document.getElementById('breath-label');
  const chapters = [
    { id: 'opening', label: 'Opening' },
    { id: 'cinematic-hero', label: 'Intro' },
    { id: 'receipts', label: 'I — Receipts' },
    { id: 'brain', label: 'II — Brain' },
    { id: 'outcomes', label: 'III — Outcomes' },
  ];

  if (dot) {
    const onScroll = () => {
      const doc = document.documentElement;
      const max = doc.scrollHeight - window.innerHeight;
      const p = max <= 0 ? 0 : Math.min(1, window.scrollY / max);
      dot.style.top = `${p * 100}%`;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  if (label) {
    const sections = chapters
      .map((c) => ({ ...c, el: document.getElementById(c.id) }))
      .filter((c): c is typeof c & { el: HTMLElement } => c.el !== null);
    const io = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) {
          const id = visible[0].target.id;
          const match = chapters.find((c) => c.id === id);
          if (match) label.textContent = match.label;
        }
      },
      { rootMargin: '-30% 0px -60% 0px', threshold: 0 },
    );
    sections.forEach((s) => io.observe(s.el));
  }
</script>
