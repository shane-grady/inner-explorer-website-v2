const pageTitle = 'For Districts — Inner Explorer';
const pageDescription =
  'A 30-minute working session for K-12 district leaders. Daily, audio-guided mindfulness now in 2,400 schools across 41 states. Funding pathways, outcomes data, and what a 90-day pilot looks like in a district your size.';

const base = new URL(Astro.site ?? 'https://www.innerexplorer.org').origin;
const districtsLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  url: `${base}/districts`,
  description: pageDescription,
  audience: {
    '@type': 'EducationalAudience',
    audienceType: 'K-12 school district leaders',
  },
  about: {
    '@type': 'Service',
    name: 'Inner Explorer for Districts',
    provider: {
      '@type': 'Organization',
      name: 'Inner Explorer',
      url: base,
      logo: `${base}/logo.png`,
    },
  },
};
---

<PageLayout title={pageTitle} description={pageDescription} flushTop>
  <JsonLd slot="head" schema={districtsLd} />

  <div class="appearance-light">
    <CinematicHero
      eyebrow={hero.eyebrow}
      serialChips={hero.serialChips}
      headlineLines={hero.headlineLines}
      lede={hero.lede}
